@page
@model AdminMembers.Pages.Stock.IndexModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.SharedResources> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Stock"];
    ViewData["LayoutPage"] = "stock";
    ViewData["LayoutUser"] = Model.CurrentUser;
}

<div class="page-body">

    <div class="sidebar form-panel" id="formPanel">
        @if (Model.CanWrite)
        {
        <div class="card">
            <div class="card-header">
                <span class="card-title" id="formTitle">@Localizer["AddItem"]</span>
                <button type="button" class="btn btn-xs btn-icon" onclick="resetForm()">@Localizer["Reset"]</button>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label>@Localizer["Name"] *</label>
                    <input id="f_name" placeholder="@Localizer["ItemName"]" required />
                </div>
                <div class="form-group">
                    <label>@Localizer["Category"]</label>
                    <input id="f_category" placeholder="@Localizer["CategoryExample"]" />
                </div>
                <div class="form-group">
                    <label>@Localizer["Description"]</label>
                    <input id="f_description" placeholder="@Localizer["OptionalDescription"]" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>@Localizer["Unit"]</label>
                        <select id="f_unit">
                            <option value="stuks">@Localizer["Stuks"]</option>
                            <option value="kg">@Localizer["Kg"]</option>
                            <option value="liter">@Localizer["Liter"]</option>
                            <option value="dozen">@Localizer["Dozen"]</option>
                            <option value="pakken">@Localizer["Pakken"]</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>@Localizer["CurrentStock"]</label>
                        <input id="f_stock" type="number" min="0" step="0.001" placeholder="0" value="0" />
                    </div>
                </div>
                <div class="form-group">
                    <label>@Localizer["MinimumStock"] <span style="color:var(--text-muted);font-weight:400;">(@Localizer["AlertThreshold"])</span></label>
                    <input id="f_minstock" type="number" min="0" step="0.001" placeholder="@Localizer["Optional"]" />
                </div>
                <input type="hidden" id="f_id" value="0" />
                <div style="display:flex;gap:8px;margin-top:16px;">
                    <button class="btn btn-primary" style="flex:1;" onclick="saveItem()">@Localizer["AddItem"]</button>
                    <button class="btn btn-secondary" onclick="resetForm()">@Localizer["Reset"]</button>
                </div>
            </div>
        </div>

        <div class="card" style="margin-top:16px;">
            <div class="card-header"><span class="card-title">@Localizer["Export"]</span></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
                <button class="btn btn-icon" onclick="showModal('exportModal')">
                    <svg class="icon icon-md"><use href="#icon-download" /></svg> @Localizer["Export"]
                </button>
            </div>
        </div>
        }
        else
        {
        <div class="card">
            <div class="card-header"><span class="card-title">@Localizer["Stock"]</span></div>
            <div class="card-body">
                <div class="viewer-notice">
                    <svg class="icon icon-xl" style="color:var(--text-muted);"><use href="#icon-lock" /></svg>
                    <div>
                        <div style="font-weight:600;font-size:13px;">@Localizer["ReadOnlyAccess"]</div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">@Localizer["StockReadOnlyDescription"]</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card" style="margin-top:16px;">
            <div class="card-header"><span class="card-title">@Localizer["Export"]</span></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
                <button class="btn btn-icon" onclick="showModal('exportModal')">
                    <svg class="icon icon-md"><use href="#icon-download" /></svg> @Localizer["Export"]
                </button>
            </div>
        </div>
        }
    </div>

    <div class="main-col">
        <div class="stat-strip">
            <div class="stat-item">
                <div class="stat-value">@Model.TotalItems</div>
                <div class="stat-label">@Localizer["TotalItems"]</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" style="color:var(--warning, #f59e0b);">@Model.LowStockItems</div>
                <div class="stat-label">@Localizer["LowStock"]</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" style="color:var(--danger);">@Model.OutOfStockItems</div>
                <div class="stat-label">@Localizer["OutOfStock"]</div>
            </div>
        </div>

        @if (Model.Items.Any())
        {
        <div class="stock-charts">
            <div class="card stock-chart-card">
                <div class="card-header"><span class="card-title">@Localizer["StockPerCategory"]</span></div>
                <div class="card-body" style="padding:12px;">
                    <canvas id="chartCategory" height="180"></canvas>
                </div>
            </div>
            <div class="card stock-chart-card">
                <div class="card-header"><span class="card-title">@Localizer["StatusDistribution"]</span></div>
                <div class="card-body" style="padding:12px;display:flex;justify-content:center;">
                    <canvas id="chartStatus" style="max-width:220px;max-height:220px;"></canvas>
                </div>
            </div>
        </div>
        }

        @if (Model.Items.Any())
        {
            foreach (var group in Model.Items.GroupBy(i => i.Category ?? Localizer["Overig"].Value).OrderBy(g => g.Key))
            {
                <div class="stock-category-header">@group.Key</div>
                <div class="member-list">
                    @foreach (var item in group)
                    {
                        var statusClass = item.Status switch {
                            AdminMembers.Models.StockStatus.Out => "badge-red",
                            AdminMembers.Models.StockStatus.Low => "badge-orange",
                            _                                   => "badge-green"
                        };
                        var statusLabel = item.Status switch {
                            AdminMembers.Models.StockStatus.Out => Localizer["SoldOut"].Value,
                            AdminMembers.Models.StockStatus.Low => Localizer["StockLow"].Value,
                            _                                   => Localizer["StockOK"].Value
                        };
                        <div class="member-list-item"
                             onclick="openStockCard(this)"
                             data-id="@item.Id"
                             data-name="@item.Name"
                             data-description="@(item.Description ?? "")"
                             data-category="@(item.Category ?? "")"
                             data-unit="@item.Unit"
                             data-stock="@item.CurrentStock.ToString("G29")"
                             data-minstock="@(item.MinimumStock.HasValue ? item.MinimumStock.Value.ToString("G29") : "")"
                             data-statusclass="@statusClass"
                             data-statuslabel="@statusLabel"
                             data-created="@item.CreatedAt.ToString("yyyy-MM-dd")">
                            <div class="member-avatar" style="background:var(--primary-light,#ede9fe);color:var(--primary);font-size:18px;">
                                <svg class="icon icon-md"><use href="#icon-box" /></svg>
                            </div>
                            <div class="member-info">
                                <div class="member-name">@item.Name</div>
                                <div class="member-details">
                                    @(item.Description ?? "")
                                    @if (item.MinimumStock.HasValue)
                                    {
                                        <span style="color:var(--text-muted);">&middot; @Localizer["MinPrefix"] @item.MinimumStock @item.Unit</span>
                                    }
                                </div>
                            </div>
                            <div class="member-meta" style="gap:8px;align-items:flex-end;">
                                <div style="font-size:20px;font-weight:800;text-align:right;">
                                    @item.CurrentStock.ToString("G29") <span style="font-size:12px;font-weight:400;color:var(--text-muted);">@item.Unit</span>
                                </div>
                                <span class="badge @statusClass">@statusLabel</span>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="no-members">
                <h3>@Localizer["NoItems"]</h3>
                <p>@Localizer["NoItemsDescription"]</p>
            </div>
        }
    </div>
</div>

<button class="fab-add" onclick="toggleFormPanel()" title="@Localizer["AddItem"]">&#43;</button>

<div id="exportModal" class="modal" onclick="if(event.target===this)hideModal('exportModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>&#128229; @Localizer["ExportStock"]</h3>
            <button class="modal-close-btn" onclick="hideModal('exportModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>@Localizer["Format"]</label>
                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                    <label class="export-format-pill"><input type="radio" name="stockFmt" value="excel" checked onchange="onFmtChange()" /> Excel (.xlsx)</label>
                    <label class="export-format-pill"><input type="radio" name="stockFmt" value="csv" onchange="onFmtChange()" /> CSV</label>
                    <label class="export-format-pill"><input type="radio" name="stockFmt" value="pdf" onchange="onFmtChange()" /> PDF</label>
                </div>
            </div>
            <div id="exportMovementsRow" style="display:none;margin-top:10px;">
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" id="exportIncludeMovements" />
                    @Localizer["IncludeMovementHistoryPerItem"]
                </label>
            </div>
            <p style="font-size:12px;color:var(--text-muted);margin-top:8px;">
                @Localizer["ExportStockDescription"]
            </p>
        </div>
        <div class="modal-footer">
            <span id="exportStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('exportModal')">@Localizer["Cancel"]</button>
            <button class="btn btn-accent" onclick="runExport()">&#128229; @Localizer["Download"]</button>
        </div>
    </div>
</div>

<!-- ══ STOCK CARD MODAL ══ -->
<div id="stockCardModal" class="modal" onclick="if(event.target===this)closeStockCard()">
    <div class="modal-box">
        <div class="modal-head">
            <h3 id="stockCardTitle">@Localizer["StockDetails"]</h3>
            <button class="modal-close-btn" onclick="closeStockCard()">&times;</button>
        </div>
        <div class="modal-tabs">
            <button class="modal-tab active" onclick="switchStockTab('info',this)">@Localizer["ItemInfo"]</button>
            <button class="modal-tab" onclick="switchStockTab('history',this)">
                <svg class="icon icon-sm" style="margin-right:4px;"><use href="#icon-clock" /></svg>@Localizer["MovementHistory"]
            </button>
        </div>
        <div class="modal-body">
            <!-- Info Tab -->
            <div id="stockTabInfo" class="modal-tab-panel active">
                <div id="stockCardBody"></div>
                @if (Model.CanWrite)
                {
                <div style="border-top:1px solid var(--border);margin-top:18px;padding-top:18px;">
                    <div style="font-weight:700;font-size:14px;margin-bottom:12px;">@Localizer["AddMovement"]</div>
                    <input type="hidden" id="mv_itemId" />
                    <div class="form-group">
                        <label>@Localizer["Type"]</label>
                        <div style="display:flex;gap:8px;">
                            <label class="export-format-pill"><input type="radio" name="mvType" value="In" checked /> &#43; @Localizer["AddIn"]</label>
                            <label class="export-format-pill"><input type="radio" name="mvType" value="Out" /> &#8722; @Localizer["RemoveOut"]</label>
                            <label class="export-format-pill"><input type="radio" name="mvType" value="Correction" /> &#61; @Localizer["CorrectionType"]</label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Quantity"] <span id="mv_unit" style="color:var(--text-muted);"></span></label>
                        <input id="mv_quantity" type="number" min="0.001" step="0.001" placeholder="0" />
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Note"]</label>
                        <input id="mv_note" placeholder="@Localizer["OptionalNote"]" />
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Date"] <span style="color:var(--text-muted);font-weight:400;">(@Localizer["EmptyMeansToday"])</span></label>
                        <input id="mv_date" type="date" />
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;margin-top:8px;">
                        <span id="mv_status" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
                        <button class="btn btn-accent" onclick="saveMovement()">@Localizer["Save"]</button>
                    </div>
                </div>
                }
            </div>
            <!-- History Tab -->
            <div id="stockTabHistory" class="modal-tab-panel">
                <div id="stockHistoryList" style="max-height:400px;overflow-y:auto;"></div>
            </div>
        </div>
        <div class="modal-footer" id="stockCardFooter"></div>
    </div>
</div>

<div id="deleteModal" class="modal" onclick="if(event.target===this)hideModal('deleteModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>@Localizer["DeleteItem"]</h3>
            <button class="modal-close-btn" onclick="hideModal('deleteModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:14px;">@Localizer["DeleteItemConfirmPrefix"] <strong id="deleteName"></strong>? @Localizer["DeleteCannotBeUndone"]</p>
        </div>
        <div class="modal-footer">
            <input type="hidden" id="deleteId" />
            <button class="btn btn-icon" onclick="hideModal('deleteModal')">@Localizer["Cancel"]</button>
            <button class="btn btn-danger" onclick="confirmDelete()">@Localizer["Delete"]</button>
        </div>
    </div>
</div>

<!-- Chart.js loaded before inline script -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

@section Scripts {
<script>
const AUTH_TOKEN = '@Model.AuthToken';
const canWrite   = @(Model.CanWrite ? "true" : "false");

const L = {
    addItem: '@Html.Raw(Localizer["AddItem"].Value.Replace("'", "\\'"))',
    editItem: '@Html.Raw(Localizer["EditItem"].Value.Replace("'", "\\'"))',
    updateItem: '@Html.Raw(Localizer["UpdateItem"].Value.Replace("'", "\\'"))',
    nameIsRequired: '@Html.Raw(Localizer["NameIsRequired"].Value.Replace("'", "\\'"))',
    saving: '@Html.Raw(Localizer["Saving"].Value.Replace("'", "\\'"))',
    saved: '@Html.Raw(Localizer["Saved"].Value.Replace("'", "\\'"))',
    saveFailed: '@Html.Raw(Localizer["SaveFailed"].Value.Replace("'", "\\'"))',
    requestFailed: '@Html.Raw(Localizer["RequestFailed"].Value.Replace("'", "\\'"))',
    deleteFailed: '@Html.Raw(Localizer["DeleteFailed"].Value.Replace("'", "\\'"))',
    failed: '@Html.Raw(Localizer["Failed"].Value.Replace("'", "\\'"))',
    movementPrefix: '@Html.Raw(Localizer["MovementPrefix"].Value.Replace("'", "\\'"))',
    enterValidQuantity: '@Html.Raw(Localizer["EnterValidQuantity"].Value.Replace("'", "\\'"))',
    historyPrefix: '@Html.Raw(Localizer["HistoryPrefix"].Value.Replace("'", "\\'"))',
    loading: '@Html.Raw(Localizer["Loading"].Value.Replace("'", "\\'"))',
    noMovementsFound: '@Html.Raw(Localizer["NoMovementsFound"].Value.Replace("'", "\\'"))',
    inType: '@Html.Raw(Localizer["InType"].Value.Replace("'", "\\'"))',
    outType: '@Html.Raw(Localizer["OutType"].Value.Replace("'", "\\'"))',
    correctionType: '@Html.Raw(Localizer["CorrectionType"].Value.Replace("'", "\\'"))',
    generatingExport: '@Html.Raw(Localizer["GeneratingExport"].Value.Replace("'", "\\'"))',
    exportFailedPrefix: '@Html.Raw(Localizer["ExportFailedPrefix"].Value.Replace("'", "\\'"))',
    totalStock: '@Html.Raw(Localizer["TotalStock"].Value.Replace("'", "\\'"))',
    loadFailed: '@Html.Raw(Localizer["LoadFailed"].Value.Replace("'", "\\'"))',
    description: '@Html.Raw(Localizer["Description"].Value.Replace("'", "\\'"))',
    category: '@Html.Raw(Localizer["Category"].Value.Replace("'", "\\'"))',
    unit: '@Html.Raw(Localizer["Unit"].Value.Replace("'", "\\'"))',
    currentStockLabel: '@Html.Raw(Localizer["CurrentStockLabel"].Value.Replace("'", "\\'"))',
    minimumStockLabel: '@Html.Raw(Localizer["MinimumStockLabel"].Value.Replace("'", "\\'"))',
    createdOn: '@Html.Raw(Localizer["CreatedOn"].Value.Replace("'", "\\'"))',
    notSet: '@Html.Raw(Localizer["NotSet"].Value.Replace("'", "\\'"))',
    close: '@Html.Raw(Localizer["Close"].Value.Replace("'", "\\'"))',
    edit: '@Html.Raw(Localizer["Edit"].Value.Replace("'", "\\'"))',
    delete_: '@Html.Raw(Localizer["Delete"].Value.Replace("'", "\\'"))',
};

function showModal(id) { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; }
function hideModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }
function toggleFormPanel() { document.getElementById('formPanel').classList.toggle('show'); }

function authHeaders() {
    return { 'Content-Type': 'application/json', ...(AUTH_TOKEN ? { 'Authorization': `Bearer ${AUTH_TOKEN}` } : {}) };
}

// ?? Form ??????????????????????????????????
let _currentStockId = null;

function resetForm() {
    document.getElementById('f_id').value          = '0';
    document.getElementById('f_name').value        = '';
    document.getElementById('f_category').value    = '';
    document.getElementById('f_description').value = '';
    document.getElementById('f_unit').value        = 'stuks';
    document.getElementById('f_stock').value       = '0';
    document.getElementById('f_minstock').value    = '';
    document.getElementById('formTitle').textContent = L.addItem;
    document.querySelector('[onclick="saveItem()"]').textContent = L.addItem;
    document.getElementById('formPanel').classList.remove('show');
}

function openEdit(id, name, desc, cat, unit, stock, minstock) {
    document.getElementById('f_id').value          = id;
    document.getElementById('f_name').value        = name;
    document.getElementById('f_description').value = desc;
    document.getElementById('f_category').value    = cat;
    document.getElementById('f_unit').value        = unit;
    document.getElementById('f_stock').value       = stock;
    document.getElementById('f_minstock').value    = (minstock === 'null' || minstock === '') ? '' : minstock;
    document.getElementById('formTitle').textContent = L.editItem;
    document.querySelector('[onclick="saveItem()"]').textContent = L.updateItem;
    document.getElementById('formPanel').classList.add('show');
    document.getElementById('formPanel').scrollIntoView({ behavior: 'smooth' });
}

async function saveItem() {
    const id   = parseInt(document.getElementById('f_id').value);
    const name = document.getElementById('f_name').value.trim();
    if (!name) { alert(L.nameIsRequired); return; }

    const body = {
        name,
        description:  document.getElementById('f_description').value.trim() || null,
        category:     document.getElementById('f_category').value.trim()    || null,
        unit:         document.getElementById('f_unit').value,
        currentStock: parseFloat(document.getElementById('f_stock').value)   || 0,
        minimumStock: document.getElementById('f_minstock').value ? parseFloat(document.getElementById('f_minstock').value) : null
    };

    const url    = id === 0 ? '/api/stock' : `/api/stock/${id}`;
    const method = id === 0 ? 'POST' : 'PUT';

    try {
        const r = await fetch(url, { method, headers: authHeaders(), body: JSON.stringify(body) });
        if (r.ok) { location.reload(); }
        else { const d = await r.json().catch(() => ({})); alert(d.error ?? L.saveFailed); }
    } catch { alert(L.requestFailed); }
}

// ?? Delete ????????????????????????????????
function deleteItem(id, name) {
    document.getElementById('deleteId').value = id;
    document.getElementById('deleteName').textContent = name;
    showModal('deleteModal');
}

async function confirmDelete() {
    const id = document.getElementById('deleteId').value;
    try {
        const r = await fetch(`/api/stock/${id}`, { method: 'DELETE', headers: authHeaders() });
        if (r.ok) { hideModal('deleteModal'); location.reload(); }
        else { const d = await r.json().catch(() => ({})); alert(d.error ?? L.deleteFailed); }
    } catch { alert(L.requestFailed); }
}

// ?? Stock Card ????????????????????????????
function openStockCard(el) {
    const d = el.dataset;
    _currentStockId = d.id;

    // Reset to Info tab
    document.querySelectorAll('#stockCardModal .modal-tab').forEach((t,i) => t.classList.toggle('active', i===0));
    document.querySelectorAll('#stockCardModal .modal-tab-panel').forEach((p,i) => p.classList.toggle('active', i===0));

    document.getElementById('stockCardTitle').textContent = d.name;

    // Build info body
    const minStockDisplay = d.minstock ? `${d.minstock} ${d.unit}` : L.notSet;
    const minStockEditHtml = canWrite
        ? `<div id="minStockView">
               <span>${minStockDisplay}</span>
               <button class="btn btn-xs btn-icon" style="margin-left:6px;" onclick="toggleMinStockEdit(true)" title="${L.edit}">&#9998;</button>
           </div>
           <div id="minStockEdit" style="display:none;">
               <div style="display:flex;gap:6px;align-items:center;">
                   <input id="card_minstock" type="number" min="0" step="0.001" style="width:100px;" value="${d.minstock || ''}" placeholder="${L.notSet}" />
                   <span style="font-size:12px;color:var(--text-muted);">${d.unit}</span>
                   <button class="btn btn-xs btn-accent" onclick="saveMinStock()">&#10003;</button>
                   <button class="btn btn-xs btn-icon" onclick="toggleMinStockEdit(false)">&times;</button>
               </div>
               <span id="minStockStatus" style="font-size:11px;color:var(--text-muted);"></span>
           </div>`
        : `<span>${minStockDisplay}</span>`;

    document.getElementById('stockCardBody').innerHTML = `
        <div style="text-align:center;padding-bottom:18px;border-bottom:1px solid var(--border);margin-bottom:18px;">
            <div class="contact-avatar-lg" style="background:var(--primary-light,#ede9fe);color:var(--primary);">
                <svg class="icon" style="width:32px;height:32px;"><use href="#icon-box" /></svg>
            </div>
            <div class="contact-name">${d.name}</div>
            <div class="contact-sub" style="margin-top:8px;">
                ${d.category ? `<span class="badge badge-gray">${d.category}</span>` : ''}
                <span class="badge ${d.statusclass}">${d.statuslabel}</span>
                <span class="badge badge-gray">${d.unit}</span>
            </div>
        </div>
        <div class="info-grid">
            <div class="info-block"><div class="info-label">${L.currentStockLabel}</div><div class="info-value" style="font-size:20px;font-weight:800;">${d.stock} ${d.unit}</div></div>
            <div class="info-block"><div class="info-label">${L.minimumStockLabel}</div><div class="info-value">${minStockEditHtml}</div></div>
            <div class="info-block"><div class="info-label">${L.description}</div><div class="info-value">${d.description || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.category}</div><div class="info-value">${d.category || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.createdOn}</div><div class="info-value">${d.created || '—'}</div></div>
        </div>`;

    // Setup movement form
    const mvItemId = document.getElementById('mv_itemId');
    if (mvItemId) {
        mvItemId.value = d.id;
        document.getElementById('mv_unit').textContent = d.unit;
        document.getElementById('mv_quantity').value = '';
        document.getElementById('mv_note').value = '';
        document.getElementById('mv_date').value = '';
        document.getElementById('mv_status').textContent = '';
        const inRadio = document.querySelector('input[name="mvType"][value="In"]');
        if (inRadio) inRadio.checked = true;
    }

    // Footer
    document.getElementById('stockCardFooter').innerHTML = `
        <button class="btn btn-icon" onclick="closeStockCard()">${L.close}</button>
        ${canWrite ? `
        <button class="btn btn-accent" onclick="editFromCard()">${L.edit}</button>
        <button class="btn btn-danger" onclick="deleteFromCard()">${L.delete_}</button>
        ` : ''}`;

    // Load history into tab
    loadStockHistory(d.id);

    showModal('stockCardModal');
}

function closeStockCard() { hideModal('stockCardModal'); }

function switchStockTab(tab, btn) {
    document.querySelectorAll('#stockCardModal .modal-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('stockTabInfo').classList.toggle('active', tab === 'info');
    document.getElementById('stockTabHistory').classList.toggle('active', tab === 'history');
}

function editFromCard() {
    const el = document.querySelector(`[data-id="${_currentStockId}"]`);
    if (!el) return;
    const d = el.dataset;
    closeStockCard();
    openEdit(d.id, d.name, d.description, d.category, d.unit, d.stock, d.minstock || 'null');
}

function deleteFromCard() {
    const el = document.querySelector(`[data-id="${_currentStockId}"]`);
    if (!el) return;
    const d = el.dataset;
    closeStockCard();
    deleteItem(d.id, d.name);
}

function toggleMinStockEdit(show) {
    document.getElementById('minStockView').style.display = show ? 'none' : '';
    document.getElementById('minStockEdit').style.display = show ? '' : 'none';
}

async function saveMinStock() {
    const el = document.querySelector(`[data-id="${_currentStockId}"]`);
    if (!el) return;
    const d = el.dataset;
    const val = document.getElementById('card_minstock').value;
    const minStock = val ? parseFloat(val) : null;
    const statusEl = document.getElementById('minStockStatus');
    statusEl.textContent = L.saving;

    const body = {
        name: d.name,
        description: d.description || null,
        category: d.category || null,
        unit: d.unit,
        currentStock: parseFloat(d.stock) || 0,
        minimumStock: minStock
    };

    try {
        const r = await fetch(`/api/stock/${d.id}`, {
            method: 'PUT',
            headers: authHeaders(),
            body: JSON.stringify(body)
        });
        if (r.ok) { location.reload(); }
        else { statusEl.textContent = ''; const data = await r.json().catch(() => ({})); alert(data.error ?? L.saveFailed); }
    } catch { statusEl.textContent = ''; alert(L.requestFailed); }
}

// ?? Movement (inline in card) ?????????????
async function saveMovement() {
    const id  = document.getElementById('mv_itemId').value;
    const qty = parseFloat(document.getElementById('mv_quantity').value);
    if (!qty || qty <= 0) { alert(L.enterValidQuantity); return; }

    const type    = document.querySelector('input[name="mvType"]:checked').value;
    const note    = document.getElementById('mv_note').value.trim() || null;
    const dateVal = document.getElementById('mv_date').value || null;
    const statusEl = document.getElementById('mv_status');
    statusEl.textContent = L.saving;

    try {
        const r = await fetch(`/api/stock/${id}/movement`, {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ type: type === 'In' ? 0 : type === 'Out' ? 1 : 2, quantity: qty, note, movementDate: dateVal })
        });
        if (r.ok) { location.reload(); }
        else { statusEl.textContent = ''; const d = await r.json().catch(() => ({})); alert(d.error ?? L.failed); }
    } catch { statusEl.textContent = ''; alert(L.requestFailed); }
}

// ?? History (inline in card tab) ??????????
async function loadStockHistory(id) {
    const listEl = document.getElementById('stockHistoryList');
    listEl.innerHTML = `<p style="color:var(--text-muted);font-size:13px;">${L.loading}</p>`;

    try {
        const r = await fetch(`/api/stock/${id}/movements`, { headers: authHeaders() });
        const data = await r.json();

        if (!data.length) {
            listEl.innerHTML = `<p style="color:var(--text-muted);font-size:13px;">${L.noMovementsFound}</p>`;
            return;
        }

        const typeLabel = { 0: L.inType, 1: L.outType, 2: L.correctionType };
        const typeClass = { 0: 'badge-green', 1: 'badge-red', 2: 'badge-purple' };

        listEl.innerHTML = data.map(m => `
            <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);">
                <span class="badge ${typeClass[m.Type]}">${typeLabel[m.Type]}</span>
                <div style="flex:1;">
                    <div style="font-size:14px;font-weight:600;">${m.Quantity} <span style="font-size:12px;font-weight:400;color:var(--text-muted);">${m.Unit ?? ''}</span></div>
                    <div style="font-size:12px;color:var(--text-muted);">${m.Note ?? ''}</div>
                </div>
                <div style="text-align:right;font-size:12px;color:var(--text-muted);">
                    <div style="font-weight:600;">${m.CreatedByUsername}</div>
                    <div>${new Date(m.MovementDate ?? m.CreatedAt).toLocaleString('nl-BE')}</div>
                </div>
            </div>`).join('');
    } catch {
        listEl.innerHTML = `<p style="color:var(--danger);font-size:13px;">${L.loadFailed}</p>`;
    }
}
// ?? Export ???????????????????????????????
function onFmtChange() {
    const fmt = document.querySelector('input[name="stockFmt"]:checked')?.value;
    document.getElementById('exportMovementsRow').style.display = fmt === 'pdf' ? '' : 'none';
    if (fmt !== 'pdf') document.getElementById('exportIncludeMovements').checked = false;
}
async function runExport() {
    const fmt = document.querySelector('input[name="stockFmt"]:checked')?.value ?? 'excel';
    const includeMovements = fmt === 'pdf' && document.getElementById('exportIncludeMovements').checked;
    const extMap  = { excel: 'xlsx', csv: 'csv', pdf: 'pdf' };
    const statusEl = document.getElementById('exportStatus');
    statusEl.textContent = L.generatingExport;
    try {
        const url = `/api/stock/export/${fmt}${includeMovements ? '?includeMovements=true' : ''}`;
        const r = await fetch(url, { headers: authHeaders() });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const blob = await r.blob();
        const dlUrl = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = dlUrl;
        a.download = `stock_${new Date().toISOString().slice(0,10)}.${extMap[fmt]}`;
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(dlUrl);
        statusEl.textContent = '';
        hideModal('exportModal');
    } catch(e) {
        statusEl.textContent = '';
        alert(L.exportFailedPrefix + ' ' + e.message);
    }
}

// ?? Charts ???????????????????????????????
async function loadCharts() {
    if (!document.getElementById('chartCategory')) return;
    try {
        const r    = await fetch('/api/stock/chart-data', { headers: authHeaders() });
        const data = await r.json();

        // Category bar chart
        new Chart(document.getElementById('chartCategory'), {
            type: 'bar',
            data: {
                labels:   data.categoryData.map(d => d.label),
                datasets: [{
                    label:           L.totalStock,
                    data:            data.categoryData.map(d => d.value),
                    backgroundColor: 'rgba(79,70,229,0.7)',
                    borderColor:     'rgba(79,70,229,1)',
                    borderWidth:     1,
                    borderRadius:    4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { font: { size: 11 } } }, x: { ticks: { font: { size: 11 } } } }
            }
        });

        // Status doughnut
        new Chart(document.getElementById('chartStatus'), {
            type: 'doughnut',
            data: {
                labels:   data.statusData.map(d => d.label),
                datasets: [{
                    data:            data.statusData.map(d => d.value),
                    backgroundColor: ['#86efac', '#fed7aa', '#fca5a5'],
                    borderColor:     ['#16a34a', '#ea580c', '#dc2626'],
                    borderWidth:     1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 11 } } }
                }
            }
        });
    } catch(e) { console.warn('Charts failed:', e); }
}

document.addEventListener('DOMContentLoaded', loadCharts);
</script>
