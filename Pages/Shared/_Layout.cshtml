<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Gilde Van De Stroppendragers</title>
    <link rel="stylesheet" href="~/styles.css">
    @RenderSection("Styles", required: false)
</head>
<body>

@{
    var layoutUser   = ViewData["LayoutUser"]   as AdminMembers.Pages.AuthenticatedPageModel.UserInfo;
    var layoutPage   = ViewData["LayoutPage"]   as string ?? "";
    var userInitials = layoutUser?.Username?.Length > 0 ? layoutUser.Username[0].ToString().ToUpper() : "?";
    var userRoles    = string.Join(", ", layoutUser?.Roles ?? new List<string>());
}

<!-- ???????????????????????????????????
     HEADER  (sticky, dark)
???????????????????????????????????? -->
<header class="app-header">

    <!-- Brand -->
    <a href="/Home" class="brand">
        <span class="brand-dot"></span>
        <span class="brand-text">Gilde Van De Stroppendragers</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav desktop-nav" aria-label="Main navigation">
        <a href="/Home"     class="@(layoutPage == "home"     ? "active" : "")">Home</a>
        <a href="/Members"  class="@(layoutPage == "members"  ? "active" : "")">Members</a>
        <a href="/Settings" class="@(layoutPage == "settings" ? "active" : "")">Settings</a>
    </nav>

    <!-- Right side: user + logout + hamburger -->
    <div class="header-right">
        @if (layoutUser != null)
        {
            <div class="user-pill">
                <div class="user-avatar" title="@userRoles">@userInitials</div>
                <span class="user-name-label">@layoutUser.Username</span>
            </div>
            <form method="post" asp-page="/Home" asp-page-handler="Logout" style="margin:0;">
                <button class="btn btn-ghost btn-sm">Sign&nbsp;Out</button>
            </form>
        }
        <!-- Mobile hamburger -->
        <button class="hamburger" id="hamburger" aria-label="Open menu" onclick="toggleMobileMenu()">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

<!-- Mobile drawer nav -->
<div class="mobile-nav-overlay" id="mobileOverlay" onclick="closeMobileMenu()"></div>
<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
    <div class="mobile-nav-head">
        @if (layoutUser != null)
        {
            <div class="user-avatar" style="width:40px;height:40px;font-size:16px;">@userInitials</div>
            <div>
                <div style="font-weight:700;color:var(--text);">@layoutUser.Username</div>
                <div style="font-size:12px;color:var(--text-muted);">@userRoles</div>
            </div>
        }
    </div>
    <a href="/Home"     class="mobile-nav-item @(layoutPage == "home"     ? "active" : "")" onclick="closeMobileMenu()">Home</a>
    <a href="/Members"  class="mobile-nav-item @(layoutPage == "members"  ? "active" : "")" onclick="closeMobileMenu()">Members</a>
    <a href="/Settings" class="mobile-nav-item @(layoutPage == "settings" ? "active" : "")" onclick="closeMobileMenu()">Settings</a>
    @if (layoutUser != null)
    {
        <form method="post" asp-page="/Home" asp-page-handler="Logout" style="padding:16px 20px;">
            <button class="btn btn-danger" style="width:100%;">Sign Out</button>
        </form>
    }
</nav>

<!-- ???????????????????????????????????
     PAGE CONTENT
???????????????????????????????????? -->
@RenderBody()

@RenderSection("Scripts", required: false)

<script>
function toggleMobileMenu() {
    document.getElementById('mobileNav').classList.toggle('open');
    document.getElementById('mobileOverlay').classList.toggle('open');
    document.getElementById('hamburger').classList.toggle('open');
    document.body.style.overflow = document.getElementById('mobileNav').classList.contains('open') ? 'hidden' : '';
}
function closeMobileMenu() {
    document.getElementById('mobileNav').classList.remove('open');
    document.getElementById('mobileOverlay').classList.remove('open');
    document.getElementById('hamburger').classList.remove('open');
    document.body.style.overflow = '';
}
</script>
</body>
</html>
