<!DOCTYPE html>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.Resources.SharedResources> Localizer
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")@Localizer["AppTitle"]</title>
    <link rel="stylesheet" href="/styles.css">
    @RenderSection("Styles", required: false)
</head>
<body>
@* Inject SVG sprite — hidden, referenced by <use href="#icon-name"> *@
<div style="display:none" id="svg-sprite-container">
    @Html.Raw(System.IO.File.ReadAllText(System.IO.Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "icons.svg")))
</div>

@{
    var layoutUser   = ViewData["LayoutUser"]   as AdminMembers.Pages.AuthenticatedPageModel.UserInfo;
    var layoutPage   = ViewData["LayoutPage"]   as string ?? "";
    var userInitials = layoutUser?.Username?.Length > 0 ? layoutUser.Username[0].ToString().ToUpper() : "?";
    var userRoles    = string.Join(", ", layoutUser?.Roles ?? new List<string>());
}

<header class="app-header">
    <a href="/Home" class="brand">
        <span class="brand-dot"></span>
        <span class="brand-text">@Localizer["AppTitle"]</span>
    </a>

    <nav class="nav desktop-nav" aria-label="Main navigation">
        <a href="/Home" class="@(layoutPage == "home" ? "active" : "")">@Localizer["Home"]</a>
        @{
            var canSeeMembersNav = layoutUser?.Roles?.Contains("Super Admin") == true
                || layoutUser?.Roles?.Contains("Admin") == true
                || layoutUser?.Roles?.Contains("Member Editor") == true
                || layoutUser?.Roles?.Contains("Member Viewer") == true;
            var canSeeStockNav = layoutUser?.Roles?.Contains("Super Admin") == true
                || layoutUser?.Roles?.Contains("Admin") == true
                || layoutUser?.Roles?.Contains("Stock Editor") == true
                || layoutUser?.Roles?.Contains("Stock Viewer") == true;
            var canSeeUsersNav = layoutUser?.Roles?.Contains("Super Admin") == true
                || layoutUser?.Roles?.Contains("Admin") == true;
        }
        @if (canSeeMembersNav)
        {
            <a href="/Members" class="@(layoutPage == "members" ? "active" : "")">@Localizer["Members"]</a>
        }
        @if (canSeeStockNav)
        {
            <a href="/Stock" class="@(layoutPage == "stock" ? "active" : "")">@Localizer["Stock"]</a>
        }
        @if (canSeeUsersNav)
        {
            <a href="/Admin/Users" class="@(layoutPage == "admin-users" ? "active" : "")">Users</a>
        }
        @if (layoutUser?.Roles?.Contains("Super Admin") == true)
        {
            <a href="/Admin/AuditLogs" class="@(layoutPage == "admin-audit" ? "active" : "")">@Localizer["AuditLogs"]</a>
        }
        <a href="/Settings" class="@(layoutPage == "settings" ? "active" : "")">@Localizer["Settings"]</a>
    </nav>

    <div class="header-right">
        @if (layoutUser != null)
        {
            <div class="user-pill">
                <div class="user-avatar" title="@userRoles">@userInitials</div>
                <a href="/Account" class="user-name-label">@layoutUser.Username</a>
            </div>
            <form method="post" asp-page="/Home" asp-page-handler="Logout" style="margin:0;">
                <button class="btn btn-ghost btn-sm">@Localizer["Logout"]</button>
            </form>
        }
        <button class="hamburger" id="hamburger" aria-label="Open menu" onclick="toggleMobileMenu()">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

<div class="mobile-nav-overlay" id="mobileOverlay" onclick="closeMobileMenu()"></div>
<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
    <div class="mobile-nav-head">
        @if (layoutUser != null)
        {
            <div class="user-avatar" style="width:40px;height:40px;font-size:16px;">@userInitials</div>
            <div>
                <div style="font-weight:700;color:var(--text);">@layoutUser.Username</div>
                <div style="font-size:12px;color:var(--text-muted);">@userRoles</div>
            </div>
        }
    </div>
    <a href="/Home" class="mobile-nav-item @(layoutPage == "home" ? "active" : "")" onclick="closeMobileMenu()">@Localizer["Home"]</a>
    @if (canSeeMembersNav)
    {
        <a href="/Members" class="mobile-nav-item @(layoutPage == "members" ? "active" : "")" onclick="closeMobileMenu()">@Localizer["Members"]</a>
    }
    @if (canSeeStockNav)
    {
        <a href="/Stock" class="mobile-nav-item @(layoutPage == "stock" ? "active" : "")" onclick="closeMobileMenu()">@Localizer["Stock"]</a>
    }
    @if (canSeeUsersNav)
    {
        <a href="/Admin/Users" class="mobile-nav-item @(layoutPage == "admin-users" ? "active" : "")" onclick="closeMobileMenu()">Users</a>
    }
    @if (layoutUser?.Roles?.Contains("Super Admin") == true)
    {
        <a href="/Admin/AuditLogs" class="mobile-nav-item @(layoutPage == "admin-audit" ? "active" : "")" onclick="closeMobileMenu()">@Localizer["AuditLogs"]</a>
    }
    <a href="/Settings" class="mobile-nav-item @(layoutPage == "settings" ? "active" : "")" onclick="closeMobileMenu()">@Localizer["Settings"]</a>
    @if (layoutUser != null)
    {
        <form method="post" asp-page="/Home" asp-page-handler="Logout" style="padding:16px 20px;">
            <button class="btn btn-danger" style="width:100%;">@Localizer["Logout"]</button>
        </form>
    }
</nav>

@RenderBody()

@RenderSection("Scripts", required: false)

<script>
function toggleMobileMenu() {
    document.getElementById('mobileNav').classList.toggle('open');
    document.getElementById('mobileOverlay').classList.toggle('open');
    document.getElementById('hamburger').classList.toggle('open');
    document.body.style.overflow = document.getElementById('mobileNav').classList.contains('open') ? 'hidden' : '';
}
function closeMobileMenu() {
    document.getElementById('mobileNav').classList.remove('open');
    document.getElementById('mobileOverlay').classList.remove('open');
    document.getElementById('hamburger').classList.remove('open');
    document.body.style.overflow = '';
}
</script>
</body>
</html>
