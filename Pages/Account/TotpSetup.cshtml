@page
@model AdminMembers.Pages.Account.TotpSetupModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.SharedResources> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["TwoFactorAuthenticationSetup"];
    ViewData["LayoutUser"] = Model.CurrentUser;
    ViewData["LayoutPage"] = "";
}

<div class="page-body-full" style="max-width:520px;padding-top:32px;">

    <div style="margin-bottom:24px;">
        <a href="/Account" style="font-size:13px;color:var(--accent);font-weight:600;text-decoration:none;">&#8592; @Localizer["MyAccount"]</a>
        <h1 style="font-size:22px;font-weight:800;margin-top:10px;letter-spacing:-.3px;">
            @Localizer["AuthenticatorSetup"]
        </h1>
        <p style="color:var(--text-muted);font-size:13px;margin-top:4px;">
            @Localizer["AuthenticatorSetupDescription"]
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert-success" style="margin-bottom:20px;">&#10003; @Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert-error" style="margin-bottom:20px;">&#33; @Model.ErrorMessage</div>
    }

    @if (!Model.TotpEnabled)
    {
        <!-- Step 1: QR -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header">
                <span class="card-title">
                    <span class="totp-step-badge">1</span> @Localizer["ScanQrCode"]
                </span>
            </div>
            <div class="card-body" style="text-align:center;padding:28px 20px;">
                <div class="totp-qr-wrap">
                    <img src="@Model.QrCodeDataUri" alt="TOTP QR Code" />
                </div>
                <div class="totp-secret-label">
                    @Localizer["CantScanEnterKeyManually"]
                </div>
                <code class="totp-secret-code">@Model.FormattedSecret</code>
            </div>
        </div>

        <!-- Step 2: Confirm -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">
                    <span class="totp-step-badge">2</span> @Localizer["ConfirmWithCode"]
                </span>
            </div>
            <div class="card-body">
                <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                    @Localizer["EnterSixDigitCodeDescription"]
                </p>
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Secret" />
                    <div class="form-group">
                        <label>@Localizer["SixDigitCode"]</label>
                        <input asp-for="VerifyCode" type="text"
                               class="totp-code-input"
                               placeholder="000000"
                               inputmode="numeric" pattern="[0-9]{6}" maxlength="6"
                               autocomplete="one-time-code" autofocus />
                    </div>
                    <button type="submit" class="btn btn-accent" style="width:auto;margin-top:4px;">
                        &#10003; @Localizer["Enable2FA"]
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">@Localizer["TwoFactorAuthenticationIsActive"]</span>
                <span class="badge badge-green">&#10003; @Localizer["Enabled"]</span>
            </div>
            <div class="card-body">
                <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                    @Localizer["TwoFactorActiveDescription"]
                </p>
                <form method="post" asp-page-handler="Disable">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger" style="width:auto;"
                            onclick="return confirm('@Localizer["Disable2FADescription"]')">
                        &#128275; @Localizer["Disable2FA"]
                    </button>
                </form>
            </div>
        </div>
    }
</div>
