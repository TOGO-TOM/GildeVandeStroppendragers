@page
@model AdminMembers.Pages.ErrorModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-wrap">
    <div class="login-card" style="text-align:center;">
        <div class="login-head">
            <div class="logo-dot"></div>
            <h1>Something went wrong</h1>
            <p>An unexpected error occurred. Please try again or contact your administrator.</p>
        </div>
        <div class="login-body">
            <a href="/Home" class="btn-login" style="display:inline-block;text-decoration:none;margin-top:8px;">
                &#8592; Back to Home
            </a>
            @if (!string.IsNullOrEmpty(Model.ExceptionType))
            {
                <div style="margin-top:20px;padding:12px;background:#fdecea;border:1px solid #c62828;border-radius:6px;text-align:left;">
                    <div style="font-weight:700;font-size:12px;color:#c62828;">@Model.ExceptionType</div>
                    <div style="font-size:12px;color:#333;margin-top:4px;word-break:break-word;">@Model.ExceptionMessage</div>
                </div>
            }
            @if (Model.ShowRequestId)
            {
                <p style="font-size:11px;color:var(--text-muted);margin-top:16px;">
                    Request ID: <code>@Model.RequestId</code>
                </p>
            }
        </div>
    </div>
</body>
</html>
