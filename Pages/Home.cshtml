@page
@model AdminMembers.Pages.HomeModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
    ViewData["LayoutPage"] = "home";
    ViewData["LayoutUser"] = Model.CurrentUser;
    var roles = string.Join(", ", Model.CurrentUser?.Roles ?? new List<string>());
}

<div class="page-body-full" style="padding-top:28px;padding-bottom:40px;">

    <!-- Welcome strip -->
    <div style="margin-bottom:28px;">
        <h1 style="font-size:22px;font-weight:800;line-height:1.2;">
            Welcome back, @Model.CurrentUser?.Username
        </h1>
        <p style="color:var(--text-muted);margin-top:5px;font-size:13px;">
            @roles &mdash; @DateTime.Now.ToString("dddd, d MMMM yyyy")
        </p>
    </div>

    <!-- Dashboard cards -->
    <div class="dashboard-grid">

        <a href="/Members" class="dash-card">
            <div class="dash-icon purple">&#128101;</div>
            <div>
                <div class="dash-title">Members</div>
                <div class="dash-desc">Browse, add and manage all members, addresses and seniority dates.</div>
                <div class="dash-arrow">View members &rarr;</div>
            </div>
        </a>

        <a href="/Settings" class="dash-card">
            <div class="dash-icon slate">&#9881;</div>
            <div>
                <div class="dash-title">Settings</div>
                <div class="dash-desc">Manage company info, logo, custom fields, users and permissions.</div>
                <div class="dash-arrow">Open settings &rarr;</div>
            </div>
        </a>

        @if (Model.CurrentUser?.Roles?.Contains("Admin") == true ||
             Model.CurrentUser?.Roles?.Contains("Super Admin") == true ||
             Model.CurrentUser?.Roles?.Contains("Stock Editor") == true ||
             Model.CurrentUser?.Roles?.Contains("Stock Viewer") == true)
        {
        <a href="/Stock" class="dash-card">
            <div class="dash-icon green">
                <svg class="icon" style="width:22px;height:22px;"><use href="#icon-box" /></svg>
            </div>
            <div>
                <div class="dash-title">Stock</div>
                <div class="dash-desc">Beheer voorraden, log bewegingen en bekijk de stockgeschiedenis.</div>
                <div class="dash-arrow">Bekijk stock &rarr;</div>
            </div>
        </a>
        }
    </div>
</div>
