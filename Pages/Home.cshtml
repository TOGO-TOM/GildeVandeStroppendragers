@page
@model AdminMembers.Pages.HomeModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.SharedResources> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Home"];
    ViewData["LayoutPage"] = "home";
    ViewData["LayoutUser"] = Model.CurrentUser;
    var roles = string.Join(", ", Model.CurrentUser?.Roles ?? new List<string>());
}

<div class="page-body-full" style="padding-top:28px;padding-bottom:40px;">

    <!-- Welcome strip -->
    <div style="margin-bottom:28px;">
        <h1 style="font-size:22px;font-weight:800;line-height:1.2;">
            @Localizer["WelcomeBack"], @Model.CurrentUser?.Username
        </h1>
        <p style="color:var(--text-muted);margin-top:5px;font-size:13px;">
            @roles &mdash; @DateTime.Now.ToString("dddd, d MMMM yyyy")
        </p>
    </div>

    <!-- Dashboard cards -->
    <div class="dashboard-grid">

        <a href="/Members" class="dash-card">
            <div class="dash-icon purple">&#128101;</div>
            <div>
                <div class="dash-title">@Localizer["Members"]</div>
                <div class="dash-desc">@Localizer["MembersDashboardDescription"]</div>
                <div class="dash-arrow">@Localizer["ViewMembers"] &rarr;</div>
            </div>
        </a>

        <a href="/Settings" class="dash-card">
            <div class="dash-icon slate">&#9881;</div>
            <div>
                <div class="dash-title">@Localizer["Settings"]</div>
                <div class="dash-desc">@Localizer["SettingsDashboardDescription"]</div>
                <div class="dash-arrow">@Localizer["OpenSettings"] &rarr;</div>
            </div>
        </a>

        @if (Model.CurrentUser?.Roles?.Contains("Admin") == true ||
             Model.CurrentUser?.Roles?.Contains("Super Admin") == true ||
             Model.CurrentUser?.Roles?.Contains("Stock Editor") == true ||
             Model.CurrentUser?.Roles?.Contains("Stock Viewer") == true)
        {
        <a href="/Stock" class="dash-card">
            <div class="dash-icon green">
                <svg class="icon" style="width:22px;height:22px;"><use href="#icon-box" /></svg>
            </div>
            <div>
                <div class="dash-title">@Localizer["Stock"]</div>
                <div class="dash-desc">@Localizer["StockDashboardDescription"]</div>
                <div class="dash-arrow">@Localizer["ViewStock"] &rarr;</div>
            </div>
        </a>
        }
    </div>

    <!-- ??? AGENDA CALENDAR ??? -->
    <div class="agenda-section">
        <div class="card">
            <div class="cal-header">
                <div style="display:flex;align-items:center;gap:12px;">
                    <h3><svg class="icon" style="width:20px;height:20px;vertical-align:-3px;margin-right:4px;color:var(--accent);"><use href="#icon-calendar" /></svg> @Localizer["Agenda"]</h3>
                    @if (Model.CanWriteAgenda)
                    {
                        <button class="btn btn-xs btn-accent" onclick="openEventForm()">
                            <svg class="icon icon-sm"><use href="#icon-plus" /></svg> @Localizer["AddEvent"]
                        </button>
                    }
                </div>
                <div class="cal-nav">
                    <button class="cal-today-btn" onclick="goToday()">@Localizer["Today"]</button>
                    <button class="cal-nav-btn" onclick="changeMonth(-1)">&#8249;</button>
                    <span class="cal-month-label" id="calMonthLabel"></span>
                    <button class="cal-nav-btn" onclick="changeMonth(1)">&#8250;</button>
                </div>
            </div>

            <!-- Calendar grid -->
            <div class="cal-grid" id="calGrid"></div>

            <!-- Day detail panel -->
            <div class="cal-day-panel" id="calDayPanel" style="display:none;">
                <div class="cal-day-panel-title" id="calDayTitle"></div>
                <div id="calDayEvents"></div>
            </div>
        </div>
    </div>
</div>

<!-- ??? EVENT FORM MODAL ??? -->
<div id="eventFormModal" class="modal" onclick="if(event.target===this)hideModal('eventFormModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3 id="eventFormTitle">@Localizer["AddEvent"]</h3>
            <button class="modal-close-btn" onclick="hideModal('eventFormModal')">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="ev_id" value="0" />
            <div class="form-group">
                <label>@Localizer["EventTitle"] *</label>
                <input id="ev_title" placeholder="@Localizer["EventTitle"]" required />
            </div>
            <div class="form-group">
                <label>@Localizer["EventDescription"]</label>
                <textarea id="ev_desc" rows="3" placeholder="@Localizer["Optional"]"
                    style="width:100%;padding:10px 13px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:inherit;resize:vertical;background:var(--bg);"></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>@Localizer["EventStartDate"] *</label>
                    <input id="ev_start" type="date" required />
                </div>
                <div class="form-group">
                    <label>@Localizer["EventEndDate"]</label>
                    <input id="ev_end" type="date" />
                </div>
            </div>
            <div class="form-row" style="align-items:end;">
                <div class="form-group">
                    <label>@Localizer["StartTime"]</label>
                    <input id="ev_start_time" type="text" value="09:00" maxlength="5" placeholder="HH:mm" pattern="[0-2][0-9]:[0-5][0-9]" class="time-input-24h" />
                </div>
                <div class="form-group">
                    <label>@Localizer["EndTime"]</label>
                    <input id="ev_end_time" type="text" value="10:00" maxlength="5" placeholder="HH:mm" pattern="[0-2][0-9]:[0-5][0-9]" class="time-input-24h" />
                </div>
            </div>
            <div class="form-group" style="margin-top:2px;">
                <button type="button" id="ev_allday_btn" class="allday-toggle active" onclick="toggleAllDay()">
                    <span class="allday-toggle-dot"></span>
                    <span id="ev_allday_label">@Localizer["AllDay"]</span>
                </button>
                <input type="hidden" id="ev_allday" value="true" />
            </div>
            <div class="form-group">
                <label>@Localizer["EventLocation"]</label>
                <input id="ev_location" placeholder="@Localizer["Optional"]" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>@Localizer["EventColor"]</label>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:4px;" id="colorPicker">
                        <label class="color-swatch" style="background:#6366f1;"><input type="radio" name="evColor" value="#6366f1" checked /></label>
                        <label class="color-swatch" style="background:#22c55e;"><input type="radio" name="evColor" value="#22c55e" /></label>
                        <label class="color-swatch" style="background:#ef4444;"><input type="radio" name="evColor" value="#ef4444" /></label>
                        <label class="color-swatch" style="background:#f59e0b;"><input type="radio" name="evColor" value="#f59e0b" /></label>
                        <label class="color-swatch" style="background:#06b6d4;"><input type="radio" name="evColor" value="#06b6d4" /></label>
                        <label class="color-swatch" style="background:#8b5cf6;"><input type="radio" name="evColor" value="#8b5cf6" /></label>
                        <label class="color-swatch" style="background:#ec4899;"><input type="radio" name="evColor" value="#ec4899" /></label>
                        <label class="color-swatch" style="background:#1e293b;"><input type="radio" name="evColor" value="#1e293b" /></label>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <span id="ev_status" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('eventFormModal')">@Localizer["Cancel"]</button>
            <button class="btn btn-accent" onclick="saveEvent()">@Localizer["Save"]</button>
        </div>
    </div>
</div>

<!-- ??? EVENT DETAIL MODAL ??? -->
<div id="eventDetailModal" class="modal" onclick="if(event.target===this)hideModal('eventDetailModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3 id="eventDetailTitle">@Localizer["EventDetails"]</h3>
            <button class="modal-close-btn" onclick="hideModal('eventDetailModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div id="eventDetailBody"></div>
        </div>
        <div class="modal-footer" id="eventDetailFooter"></div>
    </div>
</div>

<!-- ??? DELETE CONFIRM MODAL ??? -->
<div id="deleteEventModal" class="modal" onclick="if(event.target===this)hideModal('deleteEventModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>@Localizer["DeleteEvent"]</h3>
            <button class="modal-close-btn" onclick="hideModal('deleteEventModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:14px;">@Localizer["DeleteEventConfirm"]</p>
        </div>
        <div class="modal-footer">
            <input type="hidden" id="deleteEventId" />
            <button class="btn btn-icon" onclick="hideModal('deleteEventModal')">@Localizer["Cancel"]</button>
            <button class="btn btn-danger" onclick="confirmDeleteEvent()">@Localizer["Delete"]</button>
        </div>
    </div>
</div>

<style>
.color-swatch {
    display:inline-flex; align-items:center; justify-content:center;
    width:28px; height:28px; border-radius:50%; cursor:pointer;
    border:2px solid transparent; transition:all .15s;
}
.color-swatch:hover { transform:scale(1.15); }
.color-swatch input { display:none; }
.color-swatch:has(input:checked) { border-color:var(--text); box-shadow:0 0 0 2px var(--surface),0 0 0 4px var(--text); }

/* All-day toggle button */
.allday-toggle {
    display:inline-flex; align-items:center; gap:8px;
    padding:6px 14px; border-radius:999px; border:1.5px solid var(--border);
    background:var(--bg); cursor:pointer; font-size:13px; font-weight:600;
    color:var(--text-muted); transition:all .18s; user-select:none;
}
.allday-toggle:hover { border-color:var(--accent); color:var(--text); }
.allday-toggle.active {
    background:var(--accent); border-color:var(--accent); color:#fff;
}
.allday-toggle-dot {
    width:10px; height:10px; border-radius:50%;
    border:2px solid currentColor; transition:all .18s;
}
.allday-toggle.active .allday-toggle-dot {
    background:#fff; border-color:#fff;
}

/* Greyed-out time inputs when all-day */
#ev_start_time:disabled,
#ev_end_time:disabled {
    opacity:.4; pointer-events:none; background:var(--bg);
    color:var(--text-light); border-style:dashed;
}

/* 24h time input styling */
.time-input-24h {
    font-variant-numeric:tabular-nums;
    letter-spacing:.5px;
    text-align:center;
    font-weight:600;
}

/* Calendar event hover tooltip */
.cal-tooltip {
    position:fixed; z-index:9999; pointer-events:none;
    background:var(--primary); color:#fff;
    border-radius:var(--radius-sm); padding:10px 14px;
    font-size:12px; line-height:1.6;
    box-shadow:0 8px 24px rgba(0,0,0,.22);
    max-width:260px; white-space:normal;
    opacity:0; transition:opacity .12s;
}
.cal-tooltip.visible { opacity:1; }
.cal-tooltip-title { font-weight:700; font-size:13px; margin-bottom:4px; }
.cal-tooltip-row { display:flex; align-items:center; gap:5px; color:#cbd5e1; }
.cal-tooltip-row svg { flex-shrink:0; width:12px; height:12px; }
</style>

@section Scripts {
<script>
const AUTH_TOKEN = '@Model.AuthToken';
const canWrite   = @(Model.CanWriteAgenda ? "true" : "false");
let calYear, calMonth;
let calEvents = [];
let selectedDay = null;

const L = {
    addEvent: '@Html.Raw(Localizer["AddEvent"].Value.Replace("'", "\\'"))',
    editEvent: '@Html.Raw(Localizer["EditEvent"].Value.Replace("'", "\\'"))',
    save: '@Html.Raw(Localizer["Save"].Value.Replace("'", "\\'"))',
    cancel: '@Html.Raw(Localizer["Cancel"].Value.Replace("'", "\\'"))',
    delete_: '@Html.Raw(Localizer["Delete"].Value.Replace("'", "\\'"))',
    edit: '@Html.Raw(Localizer["Edit"].Value.Replace("'", "\\'"))',
    close: '@Html.Raw(Localizer["Close"].Value.Replace("'", "\\'"))',
    titleRequired: '@Html.Raw(Localizer["TitleRequired"].Value.Replace("'", "\\'"))',
    saving: '@Html.Raw(Localizer["Saving"].Value.Replace("'", "\\'"))',
    noEvents: '@Html.Raw(Localizer["NoEventsOnDay"].Value.Replace("'", "\\'"))',
    allDay: '@Html.Raw(Localizer["AllDay"].Value.Replace("'", "\\'"))',
    location: '@Html.Raw(Localizer["EventLocation"].Value.Replace("'", "\\'"))',
    description: '@Html.Raw(Localizer["EventDescription"].Value.Replace("'", "\\'"))',
    startDate: '@Html.Raw(Localizer["EventStartDate"].Value.Replace("'", "\\'"))',
    endDate: '@Html.Raw(Localizer["EventEndDate"].Value.Replace("'", "\\'"))',
    createdBy: '@Html.Raw(Localizer["CreatedBy"].Value.Replace("'", "\\'"))',
    eventDetails: '@Html.Raw(Localizer["EventDetails"].Value.Replace("'", "\\'"))',
    failed: '@Html.Raw(Localizer["Failed"].Value.Replace("'", "\\'"))',
    requestFailed: '@Html.Raw(Localizer["RequestFailed"].Value.Replace("'", "\\'"))',
};

const DOW = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.AbbreviatedDayNames
        .Skip(1).Concat(System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.AbbreviatedDayNames.Take(1))
        .ToArray()
));
const MONTHS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.MonthNames
        .Where(m => m != "").ToArray()
));

function showModal(id) { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; }
function hideModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }
function authHeaders() {
    return { 'Content-Type': 'application/json', ...(AUTH_TOKEN ? { 'Authorization': `Bearer ${AUTH_TOKEN}` } : {}) };
}

const browserLocale = document.documentElement.lang || navigator.language || 'nl';
function fmtLocalDate(isoStr) {
    if (!isoStr) return '—';
    const d = new Date(isoStr + 'T00:00:00');
    return d.toLocaleDateString(browserLocale, { weekday: 'short', year: 'numeric', month: 'long', day: 'numeric' });
}
function fmtLocalDateShort(isoStr) {
    if (!isoStr) return '—';
    const d = new Date(isoStr + 'T00:00:00');
    return d.toLocaleDateString(browserLocale, { day: 'numeric', month: 'short', year: 'numeric' });
}
function fmtLocalTime(timeStr) {
    if (!timeStr) return '';
    const [h, m] = timeStr.split(':');
    const d = new Date(2000, 0, 1, parseInt(h), parseInt(m));
    return d.toLocaleTimeString(browserLocale, { hour: '2-digit', minute: '2-digit', hour12: false });
}

// ?? Calendar rendering ?????????????????
function renderCalendar() {
    const label = MONTHS[calMonth] + ' ' + calYear;
    document.getElementById('calMonthLabel').textContent = label;

    const firstDay = new Date(calYear, calMonth, 1);
    const lastDay  = new Date(calYear, calMonth + 1, 0);
    // Monday=0 start
    let startDow = (firstDay.getDay() + 6) % 7;
    const totalDays = lastDay.getDate();

    const today = new Date();
    const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;

    let html = DOW.map(d => `<div class="cal-dow">${d}</div>`).join('');

    // Previous month filler
    const prevLast = new Date(calYear, calMonth, 0).getDate();
    for (let i = startDow - 1; i >= 0; i--) {
        const day = prevLast - i;
        html += `<div class="cal-day outside" data-date="${fmtDate(calYear, calMonth - 1, day)}"><div class="cal-day-num">${day}</div></div>`;
    }

    // Current month
    for (let d = 1; d <= totalDays; d++) {
        const dateStr = fmtDate(calYear, calMonth, d);
        const isToday = dateStr === todayStr;
        const isSel   = dateStr === selectedDay;
        const dayEvents = getEventsForDate(dateStr);
        const dots = dayEvents.slice(0, 3).map(e => {
            const timeLabel = !e.IsAllDay && e.StartTime ? fmtLocalTime(e.StartTime) + ' ' : '';
            const tipDate = fmtLocalDateShort(e.StartDate) + (e.EndDate && e.EndDate !== e.StartDate ? ' ? ' + fmtLocalDateShort(e.EndDate) : '');
            const tipTime = !e.IsAllDay && e.StartTime ? (fmtLocalTime(e.StartTime) + (e.EndTime ? ' – ' + fmtLocalTime(e.EndTime) : '')) : L.allDay;
            const tipLoc  = e.Location || '';
            return `<div class="cal-event-dot" style="background:${e.Color}" onclick="event.stopPropagation();viewEvent(${e.Id})"
                data-tip-title="${e.Title.replace(/"/g,'&quot;')}" data-tip-date="${tipDate}" data-tip-time="${tipTime}" data-tip-loc="${tipLoc}">${timeLabel}${e.Title}</div>`;
        }).join('');
        const moreCount = dayEvents.length > 3 ? `<div style="font-size:10px;color:var(--text-muted);">+${dayEvents.length - 3}</div>` : '';
        html += `<div class="cal-day${isToday ? ' today' : ''}${isSel ? ' selected' : ''}" data-date="${dateStr}" onclick="selectDay('${dateStr}')">
            <div class="cal-day-num">${d}</div>${dots}${moreCount}
        </div>`;
    }

    // Next month filler
    const totalCells = startDow + totalDays;
    const remaining = (7 - totalCells % 7) % 7;
    for (let d = 1; d <= remaining; d++) {
        html += `<div class="cal-day outside" data-date="${fmtDate(calYear, calMonth + 1, d)}"><div class="cal-day-num">${d}</div></div>`;
    }

    document.getElementById('calGrid').innerHTML = html;

    // If a day is selected, show its events
    if (selectedDay) showDayPanel(selectedDay);
}

function fmtDate(y, m, d) {
    const dt = new Date(y, m, d);
    return `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
}

function getEventsForDate(dateStr) {
    return calEvents.filter(e => {
        const start = e.StartDate;
        const end   = e.EndDate || e.StartDate;
        return dateStr >= start && dateStr <= end;
    });
}

function selectDay(dateStr) {
    selectedDay = dateStr;
    renderCalendar();
}

function showDayPanel(dateStr) {
    const panel = document.getElementById('calDayPanel');
    const evts  = getEventsForDate(dateStr);
    const dt    = new Date(dateStr + 'T00:00:00');
    const opts  = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    document.getElementById('calDayTitle').textContent = dt.toLocaleDateString(document.documentElement.lang || 'nl', opts);

    if (!evts.length) {
        document.getElementById('calDayEvents').innerHTML = `<div class="cal-empty-day">${L.noEvents}</div>`;
    } else {
        document.getElementById('calDayEvents').innerHTML = evts.map(e => `
            <div class="cal-event-card" onclick="viewEvent(${e.Id})">
                <div class="cal-event-bar" style="background:${e.Color}"></div>
                <div class="cal-event-card-body">
                    <div class="cal-event-card-title">${e.Title}</div>
                    <div class="cal-event-card-meta">
                        ${!e.IsAllDay && e.StartTime ? '<svg class="icon icon-sm" style="vertical-align:-2px;margin-right:2px;"><use href="#icon-clock"/></svg>' + fmtLocalTime(e.StartTime) + (e.EndTime ? ' – ' + fmtLocalTime(e.EndTime) : '') + ' · ' : ''}
                        ${e.Location ? '<svg class="icon icon-sm" style="vertical-align:-2px;margin-right:2px;"><use href="#icon-location"/></svg>' + e.Location + ' · ' : ''}
                        ${fmtLocalDateShort(e.StartDate)}${e.EndDate && e.EndDate !== e.StartDate ? ' ? ' + fmtLocalDateShort(e.EndDate) : ''}
                    </div>
                </div>
            </div>`).join('');
    }
    panel.style.display = '';
}

// ?? Navigation ?????????????????????????
function changeMonth(delta) {
    calMonth += delta;
    if (calMonth > 11) { calMonth = 0; calYear++; }
    if (calMonth < 0) { calMonth = 11; calYear--; }
    selectedDay = null;
    document.getElementById('calDayPanel').style.display = 'none';
    loadEvents();
}
function goToday() {
    const now = new Date();
    calYear = now.getFullYear(); calMonth = now.getMonth();
    selectedDay = fmtDate(calYear, calMonth, now.getDate());
    loadEvents();
}

// ?? API calls ??????????????????????????
async function loadEvents() {
    try {
        const r = await fetch(`/api/agenda?year=${calYear}&month=${calMonth + 1}`, { headers: authHeaders() });
        calEvents = await r.json();
    } catch { calEvents = []; }
    renderCalendar();
}

// ?? Event form ?????????????????????????
function openEventForm(ev) {
    document.getElementById('ev_id').value = ev ? ev.Id : '0';
    document.getElementById('ev_title').value = ev ? ev.Title : '';
    document.getElementById('ev_desc').value = ev ? (ev.Description || '') : '';
    document.getElementById('ev_start').value = ev ? ev.StartDate : (selectedDay || fmtDate(calYear, calMonth, new Date().getDate()));
    document.getElementById('ev_end').value = ev ? (ev.EndDate || '') : '';
    document.getElementById('ev_location').value = ev ? (ev.Location || '') : '';
    const isAllDay = ev ? ev.IsAllDay : true;
    document.getElementById('ev_allday').value = isAllDay ? 'true' : 'false';
    document.getElementById('ev_start_time').value = ev && ev.StartTime ? ev.StartTime : '09:00';
    document.getElementById('ev_end_time').value = ev && ev.EndTime ? ev.EndTime : '10:00';
    applyAllDayState(isAllDay);
    const color = ev ? ev.Color : '#6366f1';
    const radio = document.querySelector(`input[name="evColor"][value="${color}"]`);
    if (radio) radio.checked = true;
    document.getElementById('ev_status').textContent = '';
    document.getElementById('eventFormTitle').textContent = ev ? L.editEvent : L.addEvent;
    showModal('eventFormModal');
}

function toggleAllDay() {
    const current = document.getElementById('ev_allday').value === 'true';
    const next = !current;
    document.getElementById('ev_allday').value = next ? 'true' : 'false';
    applyAllDayState(next);
}

function applyAllDayState(isAllDay) {
    const btn = document.getElementById('ev_allday_btn');
    const st = document.getElementById('ev_start_time');
    const et = document.getElementById('ev_end_time');
    btn.classList.toggle('active', isAllDay);
    st.disabled = isAllDay;
    et.disabled = isAllDay;
}

async function saveEvent() {
    const title = document.getElementById('ev_title').value.trim();
    if (!title) { alert(L.titleRequired); return; }

    const id = parseInt(document.getElementById('ev_id').value);
    const isAllDay = document.getElementById('ev_allday').value === 'true';
    const body = {
        title,
        description: document.getElementById('ev_desc').value.trim() || null,
        startDate: document.getElementById('ev_start').value,
        startTime: !isAllDay ? document.getElementById('ev_start_time').value : null,
        endDate: document.getElementById('ev_end').value || null,
        endTime: !isAllDay ? document.getElementById('ev_end_time').value : null,
        location: document.getElementById('ev_location').value.trim() || null,
        isAllDay: isAllDay,
        color: document.querySelector('input[name="evColor"]:checked')?.value || '#6366f1'
    };

    const statusEl = document.getElementById('ev_status');
    statusEl.textContent = L.saving;

    try {
        const url = id === 0 ? '/api/agenda' : `/api/agenda/${id}`;
        const method = id === 0 ? 'POST' : 'PUT';
        const r = await fetch(url, { method, headers: authHeaders(), body: JSON.stringify(body) });
        if (r.ok) {
            hideModal('eventFormModal');
            await loadEvents();
            if (selectedDay) showDayPanel(selectedDay);
        } else {
            const d = await r.json().catch(() => ({}));
            statusEl.textContent = d.error ?? L.failed;
        }
    } catch { statusEl.textContent = L.requestFailed; }
}

// ?? View event detail ??????????????????
function viewEvent(id) {
    const ev = calEvents.find(e => e.Id === id);
    if (!ev) return;

    document.getElementById('eventDetailTitle').textContent = ev.Title;
    document.getElementById('eventDetailBody').innerHTML = `
        <div style="text-align:center;padding-bottom:18px;border-bottom:1px solid var(--border);margin-bottom:18px;">
            <div style="width:48px;height:48px;border-radius:12px;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;background:${ev.Color}20;color:${ev.Color};"><svg class="icon" style="width:24px;height:24px;"><use href="#icon-calendar"/></svg></div>
            <div style="font-size:18px;font-weight:800;">${ev.Title}</div>
        </div>
        <div class="info-grid">
            <div class="info-block"><div class="info-label">${L.startDate}</div><div class="info-value">${fmtLocalDate(ev.StartDate)}${ev.StartTime ? ' · ' + fmtLocalTime(ev.StartTime) : ''}</div></div>
            <div class="info-block"><div class="info-label">${L.endDate}</div><div class="info-value">${ev.EndDate ? fmtLocalDate(ev.EndDate) + (ev.EndTime ? ' · ' + fmtLocalTime(ev.EndTime) : '') : '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.location}</div><div class="info-value">${ev.Location || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.createdBy}</div><div class="info-value">${ev.CreatedByUsername}</div></div>
        </div>
        ${ev.Description ? `<div style="margin-top:16px;padding:14px;background:var(--bg);border-radius:var(--radius-sm);font-size:13px;line-height:1.6;color:var(--text);">${ev.Description.replace(/\n/g, '<br>')}</div>` : ''}`;

    document.getElementById('eventDetailFooter').innerHTML = `
        <button class="btn btn-icon" onclick="hideModal('eventDetailModal')">${L.close}</button>
        ${canWrite ? `
        <button class="btn btn-accent" onclick="hideModal('eventDetailModal');openEventForm(calEvents.find(e=>e.Id===${ev.Id}))">${L.edit}</button>
        <button class="btn btn-danger" onclick="hideModal('eventDetailModal');promptDeleteEvent(${ev.Id})">${L.delete_}</button>
        ` : ''}`;

    showModal('eventDetailModal');
}

// ?? Delete event ???????????????????????
function promptDeleteEvent(id) {
    document.getElementById('deleteEventId').value = id;
    showModal('deleteEventModal');
}

async function confirmDeleteEvent() {
    const id = document.getElementById('deleteEventId').value;
    try {
        const r = await fetch(`/api/agenda/${id}`, { method: 'DELETE', headers: authHeaders() });
        if (r.ok) {
            hideModal('deleteEventModal');
            await loadEvents();
            if (selectedDay) showDayPanel(selectedDay);
        } else { alert(L.failed); }
    } catch { alert(L.requestFailed); }
}

// ?? Init ???????????????????????????????
document.addEventListener('DOMContentLoaded', () => {
    const now = new Date();
    calYear = now.getFullYear();
    calMonth = now.getMonth();
    loadEvents();

    // ?? Tooltip for calendar event ribbons ??
    const tip = document.createElement('div');
    tip.className = 'cal-tooltip';
    document.body.appendChild(tip);

    document.getElementById('calGrid').addEventListener('mouseover', e => {
        const dot = e.target.closest('.cal-event-dot');
        if (!dot || !dot.dataset.tipTitle) return;
        const t = dot.dataset.tipTitle;
        const d = dot.dataset.tipDate;
        const tm = dot.dataset.tipTime;
        const loc = dot.dataset.tipLoc;
        tip.innerHTML = `<div class="cal-tooltip-title">${t}</div>`
            + `<div class="cal-tooltip-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> ${d}</div>`
            + `<div class="cal-tooltip-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ${tm}</div>`
            + (loc ? `<div class="cal-tooltip-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> ${loc}</div>` : '');
        tip.classList.add('visible');
    });

    document.getElementById('calGrid').addEventListener('mousemove', e => {
        if (!tip.classList.contains('visible')) return;
        const x = Math.min(e.clientX + 12, window.innerWidth - tip.offsetWidth - 8);
        const y = Math.min(e.clientY + 12, window.innerHeight - tip.offsetHeight - 8);
        tip.style.left = x + 'px';
        tip.style.top = y + 'px';
    });

    document.getElementById('calGrid').addEventListener('mouseout', e => {
        const dot = e.target.closest('.cal-event-dot');
        if (dot) tip.classList.remove('visible');
    });

    // ?? 24h time input mask (HH:mm) ??
    document.querySelectorAll('.time-input-24h').forEach(el => {
        el.addEventListener('input', function () {
            let v = this.value.replace(/[^0-9]/g, '');
            if (v.length >= 3) v = v.slice(0, 2) + ':' + v.slice(2, 4);
            if (v.length > 5) v = v.slice(0, 5);
            this.value = v;
        });
        el.addEventListener('blur', function () {
            const m = this.value.match(/^(\d{1,2}):(\d{2})$/);
            if (m) {
                const h = Math.min(parseInt(m[1]), 23);
                const min = Math.min(parseInt(m[2]), 59);
                this.value = String(h).padStart(2, '0') + ':' + String(min).padStart(2, '0');
            } else {
                this.value = this.defaultValue || '09:00';
            }
        });
    });
});
</script>
}
