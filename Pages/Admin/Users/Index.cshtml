@page
@model AdminMembers.Pages.Admin.Users.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Management";
    ViewData["LayoutPage"] = "admin-users";
    ViewData["LayoutUser"] = Model.CurrentUser;
}

<div class="page-body-full">

    <div class="page-heading">
        <h1>User Management</h1>
        <p>Create, manage and control access for all admin users.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" style="margin-bottom:16px;padding:12px 16px;background:var(--accent-light,#e8f5e9);color:var(--accent,#2e7d32);border-radius:8px;border:1px solid var(--accent,#2e7d32);">
            &#10003; @Model.SuccessMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error" style="margin-bottom:16px;padding:12px 16px;background:#fdecea;color:#c62828;border-radius:8px;border:1px solid #c62828;">
            &#9888; @Model.ErrorMessage
        </div>
    }

    <div class="settings-grid">

        <!-- NAV -->
        <div class="settings-nav card">
            <a class="settings-nav-item active" href="#" onclick="showSection('users',this)">
                <svg class="icon icon-md nav-icon"><use href="#icon-user" /></svg> Active Users
                <span class="badge badge-gray" style="margin-left:auto;">@Model.Users.Count</span>
            </a>
            @if (Model.PendingUsers.Any())
            {
                <a class="settings-nav-item" href="#" onclick="showSection('pending',this)">
                    <svg class="icon icon-md nav-icon"><use href="#icon-warning" /></svg> Pending
                    <span class="badge badge-red" style="margin-left:auto;">@Model.PendingUsers.Count</span>
                </a>
            }
            <a class="settings-nav-item" href="#" onclick="showSection('create',this)">
                <svg class="icon icon-md nav-icon"><use href="#icon-plus" /></svg> Create User
            </a>
        </div>

        <!-- CONTENT -->
        <div class="settings-content">

            <!-- Active Users -->
            <div id="sec-users" class="settings-section active">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">
                            Active Users
                            <span class="badge badge-gray" style="margin-left:6px;">@Model.Users.Count</span>
                        </span>
                    </div>
                    <div class="card-body" style="padding:0;">
                        @if (Model.Users.Any())
                        {
                            @foreach (var u in Model.Users)
                            {
                                var initials = u.Username.Length > 0 ? u.Username[0].ToString().ToUpper() : "?";
                                var isSelf   = u.Id == Model.CurrentUser?.Id;
                                <div class="user-mgmt-row">
                                    <!-- Identity -->
                                    <div class="user-mgmt-identity">
                                        <div class="user-avatar" style="width:40px;height:40px;font-size:16px;flex-shrink:0;">@initials</div>
                                        <div>
                                            <div style="font-weight:600;font-size:14px;">
                                                @u.Username
                                                @if (isSelf) { <span class="badge badge-purple" style="margin-left:4px;">You</span> }
                                            </div>
                                            <div style="font-size:12px;color:var(--text-muted);">@u.Email</div>
                                            <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">
                                                Created @u.CreatedAt.ToString("d MMM yyyy")
                                                @if (u.LastLoginAt.HasValue)
                                                {
                                                    <span>&nbsp;&bull; Last login @u.LastLoginAt.Value.ToString("d MMM yyyy HH:mm")</span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Badges -->
                                    <div class="user-mgmt-badges">
                                        @foreach (var ur in u.UserRoles)
                                        {
                                            <span class="badge badge-purple">@ur.Role.Name</span>
                                        }
                                        @if (!u.IsActive) { <span class="badge badge-gray">Inactive</span> }
                                        @if (u.TotpEnabled)  { <span class="badge badge-green" title="2FA active">&#128274; 2FA</span> }
                                        @if (u.TotpRequired && !u.TotpEnabled) { <span class="badge badge-red" title="2FA required but not yet enrolled">&#9888; 2FA Pending</span> }
                                    </div>

                                    <!-- Actions -->
                                    <div class="user-mgmt-actions">

                                        <!-- Edit roles -->
                                        <button class="btn btn-sm btn-ghost" onclick="togglePanel('roles-@u.Id')">Edit Roles</button>

                                        <!-- Reset password -->
                                        <button class="btn btn-sm btn-ghost" onclick="togglePanel('pw-@u.Id')">Reset PW</button>

                                        @if (!isSelf)
                                        {
                                            <!-- Toggle active -->
                                            @if (u.IsActive)
                                            {
                                                <form method="post" asp-page-handler="ToggleActive" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId"   value="@u.Id" />
                                                    <input type="hidden" name="activate" value="false" />
                                                    <button type="submit" class="btn btn-sm btn-ghost"
                                                            onclick="return confirm('Deactivate @u.Username?')">Deactivate</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="ToggleActive" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId"   value="@u.Id" />
                                                    <input type="hidden" name="activate" value="true" />
                                                    <button type="submit" class="btn btn-sm btn-accent">Activate</button>
                                                </form>
                                            }

                                            <!-- Force 2FA -->
                                            @if (!u.TotpRequired)
                                            {
                                                <form method="post" asp-page-handler="Set2faRequired" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId"   value="@u.Id" />
                                                    <input type="hidden" name="required" value="true" />
                                                    <button type="submit" class="btn btn-sm btn-ghost"
                                                            style="border-color:#f59e0b;color:#f59e0b;"
                                                            title="Force this user to enrol in 2FA on next login"
                                                            onclick="return confirm('Force 2FA for @u.Username? Their existing TOTP will be reset and they must re-enrol.')">
                                                        &#128274; Force 2FA
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="Set2faRequired" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId"   value="@u.Id" />
                                                    <input type="hidden" name="required" value="false" />
                                                    <button type="submit" class="btn btn-sm btn-ghost"
                                                            title="Remove 2FA requirement">
                                                        &#128275; Clear 2FA
                                                    </button>
                                                </form>
                                            }

                                            <!-- Delete -->
                                            <form method="post" asp-page-handler="Delete" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@u.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Permanently delete @u.Username? This cannot be undone.')">
                                                    Delete
                                                </button>
                                            </form>
                                        }
                                    </div>

                                    <!-- Edit roles panel -->
                                    <div id="roles-@u.Id" class="inline-panel" style="display:none;">
                                        <form method="post" asp-page-handler="UpdateRoles">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@u.Id" />
                                            <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:10px;">
                                                @foreach (var r in Model.Roles)
                                                {
                                                    var isChecked = u.UserRoles.Any(ur => ur.RoleId == r.Id);
                                                    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
                                                        <input type="checkbox" name="roleIds" value="@r.Id" @(isChecked ? "checked" : "") />
                                                        <span>@r.Name</span>
                                                        <span class="badge badge-gray" style="font-size:10px;">@r.Permission</span>
                                                    </label>
                                                }
                                            </div>
                                            <div style="display:flex;gap:8px;">
                                                <button type="submit" class="btn btn-sm btn-accent">Save Roles</button>
                                                <button type="button" class="btn btn-sm btn-ghost" onclick="togglePanel('roles-@u.Id')">Cancel</button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Reset password panel -->
                                    <div id="pw-@u.Id" class="inline-panel" style="display:none;">
                                        <form method="post" asp-page-handler="ResetPassword">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@u.Id" />
                                            <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
                                                <div>
                                                    <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">New Password</label>
                                                    <input type="password" name="newPassword" class="form-control" style="min-width:220px;"
                                                           placeholder="Min. 6 characters" required minlength="6" />
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-accent"
                                                        onclick="return confirm('Reset password for @u.Username?')">Set Password</button>
                                                <button type="button" class="btn btn-sm btn-ghost" onclick="togglePanel('pw-@u.Id')">Cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state"><h3>No active users</h3><p>Create a user or approve a pending request.</p></div>
                        }
                    </div>
                </div>
            </div>

            <!-- Pending Approvals -->
            @if (Model.PendingUsers.Any())
            {
                <div id="sec-pending" class="settings-section">
                    <div class="card pending-card">
                        <div class="card-header">
                            <span class="card-title">
                                &#9888; Pending Approvals
                                <span class="badge badge-red" style="margin-left:6px;">@Model.PendingUsers.Count</span>
                            </span>
                        </div>
                        <div class="card-body" style="padding:0;">
                            @foreach (var p in Model.PendingUsers)
                            {
                                <div class="pending-row">
                                    <div class="pending-info">
                                        <div class="pending-name">@p.Username</div>
                                        <div class="pending-email">@p.Email</div>
                                        <div class="pending-date">Requested @p.CreatedAt.ToString("d MMM yyyy HH:mm")</div>
                                    </div>
                                    <div class="pending-actions">
                                        <form method="post" asp-page-handler="Approve" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@p.Id" />
                                            <select name="roleId" class="pending-role-select" required>
                                                <option value="">Assign role&hellip;</option>
                                                @foreach (var r in Model.Roles)
                                                {
                                                    <option value="@r.Id">@r.Name</option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-accent">&#10003; Approve</button>
                                        </form>
                                        <form method="post" asp-page-handler="Reject" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@p.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Reject and remove this registration request?')">
                                                &#10005; Reject
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Create User -->
            <div id="sec-create" class="settings-section">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Create New User</span>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="Create">
                            @Html.AntiForgeryToken()
                            <div style="display:grid;gap:16px;">
                                <div>
                                    <label class="form-label">Username</label>
                                    <input type="text" name="NewUsername" class="form-control" required maxlength="50" />
                                </div>
                                <div>
                                    <label class="form-label">Email</label>
                                    <input type="email" name="NewEmail" class="form-control" required maxlength="200" />
                                </div>
                                <div>
                                    <label class="form-label">Password</label>
                                    <input type="password" name="NewPassword" class="form-control" required minlength="6"
                                           placeholder="Min. 6 characters" />
                                </div>
                                <div>
                                    <label class="form-label">Roles</label>
                                    <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:6px;">
                                        @foreach (var r in Model.Roles)
                                        {
                                            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
                                                <input type="checkbox" name="NewRoleIds" value="@r.Id" />
                                                <span>@r.Name</span>
                                                <span class="badge badge-gray" style="font-size:10px;">@r.Permission</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <button type="submit" class="btn btn-accent">Create User</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Styles {
<style>
.user-mgmt-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
}
.user-mgmt-row:last-child { border-bottom: none; }

.user-mgmt-identity { display: flex; align-items: flex-start; gap: 12px; }
.user-mgmt-badges   { display: flex; flex-wrap: wrap; gap: 6px; }
.user-mgmt-actions  { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }

.inline-panel {
    background: var(--surface, #f9f9f9);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    margin-top: 4px;
}

.form-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--text);
}

.form-control {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 14px;
    background: var(--bg, #fff);
    color: var(--text);
    box-sizing: border-box;
}
.form-control:focus {
    outline: none;
    border-color: var(--accent, #6366f1);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent, #6366f1) 20%, transparent);
}
</style>
}

@section Scripts {
<script>
function showSection(id, el) {
    event.preventDefault();
    document.querySelectorAll('.settings-section').forEach(s => {
        s.style.opacity = '0';
        s.style.transform = 'translateY(6px)';
        setTimeout(() => s.classList.remove('active'), 150);
    });
    document.querySelectorAll('.settings-nav-item').forEach(a => a.classList.remove('active'));

    setTimeout(() => {
        const target = document.getElementById('sec-' + id);
        if (!target) return;
        target.classList.add('active');
        requestAnimationFrame(() => {
            target.style.opacity = '1';
            target.style.transform = 'translateY(0)';
        });
    }, 160);
    el.classList.add('active');
}

function togglePanel(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>
}
