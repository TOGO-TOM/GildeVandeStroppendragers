@page
@model AdminMembers.Pages.Admin.FeatureRequestsModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.SharedResources> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["FeatureRequests"];
    ViewData["LayoutPage"] = "feature-requests";
    ViewData["LayoutUser"] = Model.CurrentUser;
}

<div class="page-body-full settings-page">

    <div class="page-heading">
        <h1>@Localizer["FeatureRequests"]</h1>
        <p>@Localizer["FeatureRequestsDescription"]</p>
    </div>

    <div class="settings-grid">

        <!-- NAV -->
        <div class="settings-nav card">
            <a class="settings-nav-item active" href="#" onclick="showSection('submit',this)">
                <span class="nav-icon">&#128221;</span> @Localizer["SubmitRequest"]
            </a>
            <a class="settings-nav-item" href="#" onclick="showSection('list',this)">
                <span class="nav-icon">&#128203;</span> @Localizer["AllRequests"]
            </a>
        </div>

        <!-- CONTENT -->
        <div class="settings-content">

            <!-- Submit New Request -->
            <div id="sec-submit" class="settings-section active">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">@Localizer["NewFeatureRequest"]</span>
                    </div>
                    <div class="card-body">
                        <form id="requestForm" onsubmit="submitRequest(event)">
                            <div class="settings-row">
                                <div>
                                    <div class="settings-row-label">@Localizer["RequestTitle"]</div>
                                    <div class="settings-row-desc">@Localizer["RequestTitleDescription"]</div>
                                </div>
                                <input id="reqTitle" type="text" required placeholder="@Localizer["RequestTitlePlaceholder"]"
                                       style="width:100%;max-width:320px;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);font-size:13px;" />
                            </div>
                            <div class="settings-row" style="flex-direction:column;align-items:stretch;gap:8px;">
                                <div>
                                    <div class="settings-row-label">@Localizer["RequestDescription"]</div>
                                    <div class="settings-row-desc">@Localizer["RequestDescriptionHelp"]</div>
                                </div>
                                <textarea id="reqDescription" rows="6" required
                                          placeholder="@Localizer["RequestDescriptionPlaceholder"]"
                                          style="width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);font-size:13px;font-family:inherit;resize:vertical;"></textarea>
                            </div>
                            <div class="settings-row" style="border-bottom:none;padding-bottom:0;justify-content:flex-end;gap:12px;align-items:center;">
                                <span id="submitStatus" style="font-size:12px;color:var(--text-muted);"></span>
                                <button type="submit" class="btn btn-accent">&#9889; @Localizer["SubmitForAnalysis"]</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card" style="margin-top:16px;">
                    <div class="card-header">
                        <span class="card-title">@Localizer["HowItWorks"]</span>
                    </div>
                    <div class="card-body">
                        <div style="display:flex;gap:16px;flex-wrap:wrap;">
                            <div style="flex:1;min-width:180px;padding:16px;border:1px solid var(--border);border-radius:var(--radius-sm);text-align:center;">
                                <div style="font-size:28px;margin-bottom:8px;">&#128221;</div>
                                <div style="font-weight:700;font-size:13px;margin-bottom:4px;">1. @Localizer["StepSubmit"]</div>
                                <div style="font-size:12px;color:var(--text-muted);">@Localizer["StepSubmitDesc"]</div>
                            </div>
                            <div style="flex:1;min-width:180px;padding:16px;border:1px solid var(--border);border-radius:var(--radius-sm);text-align:center;">
                                <div style="font-size:28px;margin-bottom:8px;">&#129302;</div>
                                <div style="font-weight:700;font-size:13px;margin-bottom:4px;">2. @Localizer["StepAnalyze"]</div>
                                <div style="font-size:12px;color:var(--text-muted);">@Localizer["StepAnalyzeDesc"]</div>
                            </div>
                            <div style="flex:1;min-width:180px;padding:16px;border:1px solid var(--border);border-radius:var(--radius-sm);text-align:center;">
                                <div style="font-size:28px;margin-bottom:8px;">&#128736;&#65039;</div>
                                <div style="font-weight:700;font-size:13px;margin-bottom:4px;">3. @Localizer["StepArchitect"]</div>
                                <div style="font-size:12px;color:var(--text-muted);">@Localizer["StepArchitectDesc"]</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- All Requests -->
            <div id="sec-list" class="settings-section">
                <div id="requestsList"></div>
            </div>

        </div>
    </div>
</div>

<style>
.fr-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    gap: 12px;
    cursor: pointer;
    transition: background var(--transition);
}
.fr-row:last-child { border-bottom: none; }
.fr-row:hover { background: var(--bg); }
.fr-info { flex: 1; min-width: 0; }
.fr-info-title { font-weight: 600; font-size: 14px; margin-bottom: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.fr-info-meta { font-size: 12px; color: var(--text-muted); }
.fr-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; flex-wrap: wrap; justify-content: flex-end; }
@@media (max-width: 768px) {
    .fr-row { flex-wrap: wrap; padding: 12px 14px; }
    .fr-info { min-width: 100%; }
    .fr-actions { width: 100%; justify-content: flex-start; margin-top: 6px; }
}
</style>

<!-- Detail Modal -->
<div id="detailModal" class="modal" onclick="if(event.target===this)hideModal('detailModal')">
    <div class="modal-box" style="max-width:720px;">
        <div class="modal-head">
            <h3 id="detailTitle"></h3>
            <button class="modal-close-btn" onclick="hideModal('detailModal')">&times;</button>
        </div>
        <div class="modal-body" id="detailBody" style="max-height:70vh;overflow-y:auto;"></div>
        <div class="modal-footer">
            <button class="btn btn-icon" onclick="hideModal('detailModal')">@Localizer["Close"]</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
const pageToken = '@Model.AuthToken';
const L = {
    saving: '@Html.Raw(Localizer["Saving"].Value.Replace("'", "\\'"))',
    saved: '@Html.Raw(Localizer["Saved"].Value.Replace("'", "\\'"))',
    saveFailed: '@Html.Raw(Localizer["SaveFailed"].Value.Replace("'", "\\'"))',
    requestFailed: '@Html.Raw(Localizer["RequestFailed"].Value.Replace("'", "\\'"))',
    submitted: '@Html.Raw(Localizer["RequestSubmitted"].Value.Replace("'", "\\'"))',
    submitting: '@Html.Raw(Localizer["Submitting"].Value.Replace("'", "\\'"))',
    pending: '@Html.Raw(Localizer["Pending"].Value.Replace("'", "\\'"))',
    processing: '@Html.Raw(Localizer["Processing"].Value.Replace("'", "\\'"))',
    analyzed: '@Html.Raw(Localizer["Analyzed"].Value.Replace("'", "\\'"))',
    planned: '@Html.Raw(Localizer["Planned"].Value.Replace("'", "\\'"))',
    noRequests: '@Html.Raw(Localizer["NoFeatureRequests"].Value.Replace("'", "\\'"))',
    retrigger: '@Html.Raw(Localizer["Retrigger"]?.Value.Replace("'", "\\'") ?? "Retry AI")',
    retriggering: '@Html.Raw(Localizer["Retriggering"]?.Value.Replace("'", "\\'") ?? "Triggering...")',
    deleteConfirm: '@Html.Raw(Localizer["DeleteFeatureRequestConfirm"].Value.Replace("'", "\\'"))',
    analysis: '@Html.Raw(Localizer["Analysis"].Value.Replace("'", "\\'"))',
    feasibility: '@Html.Raw(Localizer["Feasibility"].Value.Replace("'", "\\'"))',
    architecturalPlan: '@Html.Raw(Localizer["ArchitecturalPlan"].Value.Replace("'", "\\'"))',
    category: '@Html.Raw(Localizer["Category"].Value.Replace("'", "\\'"))',
    priority: '@Html.Raw(Localizer["FRPriority"].Value.Replace("'", "\\'"))',
    awaitingAi: '@Html.Raw(Localizer["AwaitingAi"].Value.Replace("'", "\\'"))',
};

function showModal(id) { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; }
function hideModal(id) { document.getElementById(id).style.display = 'none'; document.body.style.overflow = ''; }

function showSection(id, el) {
    event.preventDefault();
    document.querySelectorAll('.settings-section').forEach(s => {
        s.style.opacity = '0';
        s.style.transform = 'translateY(6px)';
        setTimeout(() => s.classList.remove('active'), 150);
    });
    document.querySelectorAll('.settings-nav-item').forEach(a => a.classList.remove('active'));
    setTimeout(() => {
        const target = document.getElementById('sec-' + id);
        target.classList.add('active');
        requestAnimationFrame(() => { target.style.opacity = '1'; target.style.transform = 'translateY(0)'; });
        if (id === 'list') loadRequests();
    }, 160);
    el.classList.add('active');
}

async function submitRequest(e) {
    e.preventDefault();
    const statusEl = document.getElementById('submitStatus');
    statusEl.textContent = L.submitting;
    statusEl.style.color = '';

    const body = {
        title: document.getElementById('reqTitle').value.trim(),
        description: document.getElementById('reqDescription').value.trim()
    };

    try {
        const r = await fetch('/api/feature-requests', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify(body)
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok) {
            statusEl.style.color = 'green';
            statusEl.textContent = L.submitted;
            document.getElementById('reqTitle').value = '';
            document.getElementById('reqDescription').value = '';
            if (data.triggerError) {
                statusEl.style.color = 'orange';
                statusEl.textContent = L.submitted + ' ⚠️ ' + data.triggerError;
            }
            setTimeout(() => { statusEl.textContent = ''; statusEl.style.color = ''; }, 8000);
        } else {
            statusEl.style.color = 'red';
            statusEl.textContent = data.error ?? L.saveFailed;
        }
    } catch {
        statusEl.style.color = 'red';
        statusEl.textContent = L.requestFailed;
    }
}

function statusBadge(status) {
    const colors = { Pending: 'badge-gray', Processing: 'badge-purple', Analyzed: 'badge-purple', Planned: 'badge-green' };
    const labels = { Pending: L.pending, Processing: L.processing, Analyzed: L.analyzed, Planned: L.planned };
    return `<span class="badge ${colors[status] || 'badge-gray'}">${labels[status] || status}</span>`;
}

function priorityBadge(p) {
    if (!p) return '';
    const colors = { Low: 'badge-gray', Medium: 'badge-purple', High: 'badge-red', Critical: 'badge-red' };
    return `<span class="badge ${colors[p] || 'badge-gray'}">${p}</span>`;
}

async function loadRequests() {
    const container = document.getElementById('requestsList');
    container.innerHTML = '<div style="text-align:center;padding:32px;color:var(--text-muted);">Loading...</div>';

    try {
        const r = await fetch('/api/feature-requests', {
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) }
        });
        const data = await r.json();

        if (!data.length) {
            container.innerHTML = `<div class="card"><div class="card-body"><div class="empty-state"><h3>${L.noRequests}</h3></div></div></div>`;
            return;
        }

        let html = '<div class="card"><div class="card-header"><span class="card-title">@Localizer["AllRequests"] <span class="badge badge-gray" style="margin-left:6px;">' + data.length + '</span></span></div><div class="card-body" style="padding:0;">';

        for (const req of data) {
            const date = new Date(req.CreatedAt).toLocaleDateString(undefined, { day:'numeric', month:'short', year:'numeric' });
            html += `
                <div class="fr-row" onclick="showDetail(${req.Id})">
                    <div class="fr-info">
                        <div class="fr-info-title">${esc(req.Title)}</div>
                        <div class="fr-info-meta">${esc(req.SubmittedByUsername)} &middot; ${date}</div>
                    </div>
                    <div class="fr-actions">
                        ${req.Category ? `<span class="badge badge-gray">${esc(req.Category)}</span>` : ''}
                        ${priorityBadge(req.Priority)}
                        ${statusBadge(req.Status)}
                        ${req.Status === 'Pending' ? `<button class="btn btn-accent btn-sm" onclick="event.stopPropagation();retrigger(${req.Id})" title="${L.retrigger}">&#9889;</button>` : ''}
                        <button class="btn btn-danger btn-sm" onclick="event.stopPropagation();deleteRequest(${req.Id})">&#128465;</button>
                    </div>
                </div>`;
        }

        html += '</div></div>';
        container.innerHTML = html;
    } catch {
        container.innerHTML = `<div class="card"><div class="card-body" style="color:red;">${L.requestFailed}</div></div>`;
    }
}

async function showDetail(id) {
    try {
        const r = await fetch(`/api/feature-requests/${id}`, {
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) }
        });
        const req = await r.json();

        document.getElementById('detailTitle').textContent = req.Title;

        let html = `<div style="margin-bottom:16px;display:flex;gap:8px;flex-wrap:wrap;">
            ${statusBadge(req.Status)}
            ${req.Category ? `<span class="badge badge-gray">${esc(req.Category)}</span>` : ''}
            ${priorityBadge(req.Priority)}
        </div>`;

        html += `<div style="margin-bottom:20px;">
            <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:6px;">@Localizer["RequestDescription"]</div>
            <div style="font-size:13px;white-space:pre-wrap;background:var(--bg);padding:12px;border-radius:var(--radius-sm);border:1px solid var(--border);">${esc(req.Description)}</div>
        </div>`;

        if (req.AnalysisSummary) {
            html += `<div style="margin-bottom:20px;">
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:6px;">&#129302; ${L.analysis}</div>
                <div style="font-size:13px;background:var(--bg);padding:12px;border-radius:var(--radius-sm);border:1px solid var(--border);">${esc(req.AnalysisSummary)}</div>
            </div>`;
        }

        if (req.FeasibilityAssessment) {
            html += `<div style="margin-bottom:20px;">
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:6px;">&#9989; ${L.feasibility}</div>
                <div style="font-size:13px;background:var(--bg);padding:12px;border-radius:var(--radius-sm);border:1px solid var(--border);">${esc(req.FeasibilityAssessment)}</div>
            </div>`;
        }

        if (req.ArchitecturalPlan) {
            html += `<div style="margin-bottom:20px;">
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:6px;">&#128736;&#65039; ${L.architecturalPlan}</div>
                <div class="arch-plan" style="font-size:13px;background:var(--bg);padding:16px;border-radius:var(--radius-sm);border:1px solid var(--border);line-height:1.7;">${renderMarkdown(req.ArchitecturalPlan)}</div>
            </div>`;
        }

        if (req.Status === 'Pending' || req.Status === 'Processing') {
            html += `<div style="text-align:center;padding:16px;color:var(--text-muted);font-size:13px;">
                <div style="font-size:24px;margin-bottom:8px;">&#9203;</div>
                ${L.awaitingAi}
            </div>`;
        }

        document.getElementById('detailBody').innerHTML = html;
        showModal('detailModal');
    } catch { alert(L.requestFailed); }
}

async function deleteRequest(id) {
    if (!confirm(L.deleteConfirm)) return;
    try {
        await fetch(`/api/feature-requests/${id}`, {
            method: 'DELETE',
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) }
        });
        loadRequests();
    } catch { alert(L.requestFailed); }
}

function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

function renderMarkdown(md) {
    if (!md) return '';

    // Try parsing as JSON — the AI sometimes returns a JSON object instead of Markdown
    try {
        const obj = typeof md === 'object' ? md : JSON.parse(md);
        if (obj && typeof obj === 'object' && !Array.isArray(obj)) {
            return renderJsonPlan(obj);
        }
    } catch { /* not JSON, treat as markdown */ }

    return esc(md)
        .replace(/^## (.+)$/gm, '<h4 style="margin:16px 0 8px;color:var(--text);font-size:14px;">$1</h4>')
        .replace(/^### (.+)$/gm, '<h5 style="margin:12px 0 6px;color:var(--text);font-size:13px;">$1</h5>')
        .replace(/^\d+\.\s+(.+)$/gm, '<div style="padding-left:16px;margin:4px 0;"><span style="color:var(--accent);font-weight:700;">•</span> $1</div>')
        .replace(/^- (.+)$/gm, '<div style="padding-left:16px;margin:4px 0;"><span style="color:var(--text-muted);">–</span> $1</div>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/`(.+?)`/g, '<code style="background:var(--border);padding:1px 5px;border-radius:3px;font-size:12px;">$1</code>')
        .replace(/\n/g, '<br>');
}

function renderJsonPlan(obj) {
    let html = '';
    for (const [key, value] of Object.entries(obj)) {
        html += `<div style="margin-bottom:16px;">`;
        html += `<h4 style="margin:0 0 8px;color:var(--text);font-size:14px;font-weight:700;">## ${esc(key)}</h4>`;
        html += `<div style="font-size:13px;line-height:1.8;">`;

        const text = String(value);
        // Split numbered items (e.g. "1. First 2. Second") into separate lines
        const numbered = text.match(/\d+\.\s+[^]*?(?=\s*\d+\.\s|$)/g);
        if (numbered && numbered.length > 1) {
            for (const item of numbered) {
                const clean = item.replace(/^\d+\.\s+/, '').trim();
                html += `<div style="padding-left:16px;margin:4px 0;display:flex;gap:8px;">
                    <span style="color:var(--accent);font-weight:700;flex-shrink:0;">•</span>
                    <span>${esc(clean)}</span>
                </div>`;
            }
        } else {
            html += `<div style="padding:0;">${esc(text)}</div>`;
        }

        html += `</div></div>`;
    }
    return html;
}

async function retrigger(id) {
    try {
        const r = await fetch(`/api/feature-requests/${id}/retrigger`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            }
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok) { loadRequests(); }
        else { alert(d.error ?? L.requestFailed); }
    } catch { alert(L.requestFailed); }
}

window.addEventListener('keydown', e => { if (e.key === 'Escape') hideModal('detailModal'); });
</script>
}
