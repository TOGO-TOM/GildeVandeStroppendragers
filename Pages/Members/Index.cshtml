// ── Helpers ───────────────────────────────
function showModal(id) { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; }
function hideModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }

// ── Mobile FAB + form panel ───────────────
function toggleFormPanel() {
    document.getElementById('formPanel').classList.toggle('show');
}

// ── Custom field helpers ──────────────────
function buildCustomFieldBlocks(d) {
    let html = '';
    Object.keys(d).forEach(key => {
        if (key.startsWith('cf') && !key.startsWith('cflabel')) {
            const id    = key.slice(2); // strip 'cf'
            const label = d[`cflabel${id}`];
            const value = d[key];
            if (label) html += `<div class="info-block"><div class="info-label">${label}</div><div class="info-value">${value || '—'}</div></div>`;
        }
    });
    return html;
}

// ── Contact card ──────────────────────────
function openCard(el) {
    const d = el.dataset;
    _currentMemberId = d.id;
    // Reset to Info tab
    document.querySelectorAll('.modal-tab').forEach((t,i) => t.classList.toggle('active', i===0));
    document.querySelectorAll('.modal-tab-panel').forEach((p,i) => p.classList.toggle('active', i===0));
    const alive   = d.alive === 'true';
    const initials= ((d.first?.[0] ?? '?') + (d.last?.[0] ?? '?')).toUpperCase();
    const num     = d.number && d.number !== '' ? '#' + d.number : L.noNumber;
    const addr    = [d.street, d.housenumber].filter(Boolean).join(' ');
    const years   = d.seniority
        ? Math.floor((Date.now() - new Date(d.seniority)) / (365.25 * 864e5))
        : null;

    document.getElementById('cardTitle').textContent = d.last + ' ' + d.first;

    const roleBadgeClass = {'Stappend Lid':'badge-purple','Kandidaat':'badge-orange','Steunend Lid':'badge-blue'}[d.role] || 'badge-gray';

    document.getElementById('cardBody').innerHTML = `
        <div style="text-align:center;padding-bottom:18px;border-bottom:1px solid var(--border);margin-bottom:18px;">
            <div class="contact-avatar-lg">${initials}</div>
            <div class="contact-name">${d.last} ${d.first}</div>
            <div class="contact-sub" style="margin-top:8px;">
                <span class="badge ${roleBadgeClass}">${d.role || '—'}</span>
                <span class="badge ${alive ? 'badge-green' : 'badge-gray'}">${alive ? L.alive : L.deceased}</span>
                <span class="badge badge-gray">${num}</span>
            </div>
        </div>
        <div class="info-grid">
            <div class="info-block"><div class="info-label">${L.gender}</div><div class="info-value">${d.gender || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.birthDate}</div><div class="info-value">${d.birth || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.email}</div><div class="info-value">${d.email || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.phone}</div><div class="info-value">${d.phone || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.address}</div><div class="info-value">${addr || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.city}</div><div class="info-value">${[d.postal, d.city].filter(Boolean).join(' ') || '—'}</div></div>
            <div class="info-block"><div class="info-label">${L.country}</div><div class="info-value">${d.country || '—'}</div></div>
            ${buildCustomFieldBlocks(d)}
        </div>
        ${years !== null ? `<div class="seniority-box"><div class="years">${years} ${years !== 1 ? L.years : L.year}</div><div class="label">${L.memberSince} ${d.seniority}</div></div>` : ''}`;


    document.getElementById('cardFooter').innerHTML = `
        <button class="btn btn-icon" onclick="closeCard()">Close</button>
        ${canWrite ? `
        <button class="btn btn-accent" onclick="loadEdit(document.querySelector('[data-id=\\'${d.id}\\']'));closeCard()">Edit</button>
        <button class="btn btn-danger" onclick="confirmDelete('${d.id}','${d.last} ${d.first}')">Delete</button>
        ` : ''}`;

    showModal('contactModal');
}

function closeCard() { hideModal('contactModal'); }

// ── Populate edit form ────────────────────
function loadEdit(el) {
    const d = el.dataset;
    document.getElementById('formTitle').textContent = L.editMember;
    document.getElementById('submitBtn').textContent  = L.updateMember;
    sv('Form_Id', d.id); sv('Form_FirstName', d.first); sv('Form_LastName', d.last);
    sv('Form_Gender', d.gender); sv('Form_IsAlive', d.alive); sv('Form_Role', d.role);
    sv('Form_MemberNumber', d.number); sv('Form_Email', d.email); sv('Form_PhoneNumber', d.phone);
    sv('Form_BirthDate', d.birth); sv('Form_SeniorityDate', d.seniority);
    sv('Form_Street', d.street); sv('Form_HouseNumber', d.housenumber);
    sv('Form_City', d.city); sv('Form_PostalCode', d.postal); sv('Form_Country', d.country);
    // Populate custom field inputs
    Object.keys(d).forEach(key => {
        if (key.startsWith('cf') && !key.startsWith('cflabel')) {
            const id = key.slice(2);
            const input = document.getElementById(`cf_${id}`);
            if (input) input.value = d[key] ?? '';
        }
    });
    // Show form panel on mobile
    document.getElementById('formPanel').classList.add('show');
    document.getElementById('formPanel').scrollIntoView({ behavior: 'smooth' });
}

function sv(id, val) {
    const el = document.getElementById(id);
    if (el && val !== undefined && val !== null) el.value = val;
}

function resetForm() {
    document.getElementById('memberForm').reset();
    document.getElementById('formTitle').textContent = L.addMember;
    document.getElementById('submitBtn').textContent  = L.addMember;
    const id = document.getElementById('Form_Id');
    if (id) id.value = '0';
    const c = document.getElementById('Form_Country');
    if (c && !c.value) c.value = 'Belgium';
    document.getElementById('formPanel').classList.remove('show');
}

// ── Delete ────────────────────────────────
function confirmDelete(id, name) {
    closeCard();
    document.getElementById('deleteId').value = id;
    document.getElementById('deleteName').textContent = name;
    showModal('deleteModal');
}
function closeDelete() { hideModal('deleteModal'); }

// ── Export ────────────────────────────────
function toggleAllFields(checked) {
    document.querySelectorAll('#exportModal input[name="ef"]').forEach(cb => cb.checked = checked);
}

async function runExport() {
    const format = document.querySelector('input[name="exportFormat"]:checked')?.value ?? 'pdf';
    const fields  = [...document.querySelectorAll('#exportModal input[name="ef"]:checked')].map(cb => cb.value);
    const roles   = [...document.querySelectorAll('#exportModal input[name="er"]:checked')].map(cb => cb.value);

    if (fields.length === 0) {
        showToast('error', 'Select at least one field to export.');
        return;
    }

    const statusEl = document.getElementById('exportStatus');
    statusEl.textContent = 'Generating…';

    const endpointMap = { pdf: 'export/pdf', excel: 'export/excel', csv: 'export/csv-custom' };
    const mimeMap     = { pdf: 'application/pdf', excel: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet', csv: 'text/csv' };
    const extMap      = { pdf: 'pdf', excel: 'xlsx', csv: 'csv' };

    try {
        const r = await fetch(`/api/members/${endpointMap[format]}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify({ selectedFields: fields, filterRoles: roles.length > 0 ? roles : null })
        });

        if (!r.ok) {
            const err = await r.json().catch(() => ({}));
            throw new Error(err.error ?? `Server error ${r.status}`);
        }

        const blob = await r.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = url;
        a.download = `members_export_${new Date().toISOString().slice(0,10)}.${extMap[format]}`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);

        statusEl.textContent = '';
        hideModal('exportModal');
        showToast('success', 'Export downloaded successfully.');
    } catch (e) {
        statusEl.textContent = '';
        showToast('error', e.message ?? 'Export failed.');
    }
}

// ── Import CSV ────────────────────────────
async function importCsv() {
    const file = document.getElementById('csvFile').files[0];
    if (!file) { alert('Please select a CSV file.'); return; }
    const fd = new FormData(); fd.append('file', file);
    try {
        const r = await fetch('/api/members/import/csv', { method: 'POST', body: fd });
        const data = await r.json().catch(() => ({}));
        if (r.ok) {
            hideModal('importModal');
            showToast('success', `Imported ${data.imported ?? ''} members.`);
            setTimeout(() => location.reload(), 1500);
        } else { showToast('error', data.error ?? 'Import failed.'); }
    } catch { showToast('error', 'Import request failed.'); }
}

// ── Toast helper ──────────────────────────
function showToast(type, msg) {
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<span class="toast-icon">${type === 'success' ? '&#10003;' : '&#33;'}</span>${msg}`;
    document.getElementById('toastWrap').appendChild(t);
    setTimeout(() => t.remove(), 4000);
}

// ── Bulk update ──────────────────────────
function openBulkModal() {
    // Populate member list from current DOM
    const items = document.querySelectorAll('.member-list-item');
    const list  = document.getElementById('bulkMemberList');
    list.innerHTML = '';
    items.forEach(el => {
        const d    = el.dataset;
        const name = `${d.first} ${d.last}`;
        const num  = d.number ? `#${d.number}` : '';
        const row  = document.createElement('label');
        row.style.cssText = 'display:flex;align-items:center;gap:10px;padding:6px 8px;cursor:pointer;border-radius:4px;font-size:13px;';
        row.innerHTML = `<input type="checkbox" class="bulk-cb" value="${d.id}" style="width:15px;height:15px;flex-shrink:0;">
            <span style="flex:1;">${name}</span>
            <span style="color:var(--text-muted);font-size:12px;">${num} &middot; ${d.role || ''}</span>`;
        row.querySelector('input').addEventListener('change', updateBulkCount);
        list.appendChild(row);
    });
    updateBulkCount();
    document.getElementById('bulkRole').value   = '';
    document.getElementById('bulkAlive').value  = '';
    document.getElementById('bulkGender').value = '';
    document.getElementById('bulkStatus').textContent = '';
}

function updateBulkCount() {
    const n = document.querySelectorAll('.bulk-cb:checked').length;
    document.getElementById('bulkSelectedCount').textContent = `(${n} ${L.selected})`;
}

function bulkSelectAll(checked) {
    document.querySelectorAll('.bulk-cb').forEach(cb => { cb.checked = checked; });
    updateBulkCount();
}

async function applyBulkUpdate() {
    const ids    = [...document.querySelectorAll('.bulk-cb:checked')].map(cb => parseInt(cb.value));
    const role   = document.getElementById('bulkRole').value   || null;
    const alive  = document.getElementById('bulkAlive').value;
    const gender = document.getElementById('bulkGender').value || null;

    if (ids.length === 0) { showToast('error', 'Select at least one member.'); return; }
    if (!role && alive === '' && !gender) { showToast('error', 'Choose at least one field to update.'); return; }

    const body = {
        memberIds: ids,
        ...(role   ? { role }   : {}),
        ...(gender ? { gender } : {}),
        ...(alive !== '' ? { isAlive: alive === 'true' } : {})
    };

    const statusEl = document.getElementById('bulkStatus');
    statusEl.textContent = 'Updating…';

    try {
        const r = await fetch('/api/members/bulk-update', {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify(body)
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok) {
            statusEl.textContent = '';
            hideModal('bulkModal');
            showToast('success', `Updated ${data.updatedCount} member(s).`);
            setTimeout(() => location.reload(), 1500);
        } else {
            statusEl.textContent = '';
            showToast('error', data.error ?? data.message ?? `Bulk update failed (HTTP ${r.status}).`);
        }
    } catch {
        statusEl.textContent = '';
        showToast('error', 'Request failed.');
    }
}

// ── Documents ─────────────────────────────
let _currentMemberId = null;

function switchTab(tab, btn) {
    document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.modal-tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(tab === 'info' ? 'tabInfo' : 'tabDocs').classList.add('active');
    if (tab === 'docs' && _currentMemberId) loadDocs(_currentMemberId);
}

async function loadDocs(memberId) {
    const list = document.getElementById('docList');
    list.innerHTML = `<div style="color:var(--text-muted);font-size:13px;text-align:center;padding:12px;">${L.loading}</div>`;
    try {
        const r = await fetch(`/api/members/${memberId}/documents`, {
            headers: pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}
        });
        const docs = await r.json();
        if (!docs.length) {
            list.innerHTML = `<div style="color:var(--text-muted);font-size:13px;text-align:center;padding:12px;">${L.noDocumentsYet}</div>`;
            return;
        }
        list.innerHTML = docs.map(d => {
            const ext = d.FileName.split('.').pop().toLowerCase();
            const canPreview = ['pdf','png','jpg','jpeg','gif','webp','txt'].includes(ext);
            return `
            <div class="doc-item" id="doc-${d.Id}">
                <svg class="icon icon-md doc-item-icon"><use href="#icon-paperclip" /></svg>
                <span class="doc-item-name" title="${d.FileName}">${d.FileName}</span>
                <span class="doc-item-meta">${formatBytes(d.FileSizeBytes)}</span>
                <div class="doc-item-actions">
                    ${canPreview ? `<button class="btn btn-xs btn-icon" onclick="viewDoc(${memberId},${d.Id},'${d.FileName}','${d.ContentType}')">
                        <svg class="icon icon-sm"><use href="#icon-eye" /></svg> ${L.view}
                    </button>` : ''}
                    <button class="btn btn-xs btn-icon" onclick="downloadDoc(${memberId},${d.Id},'${d.FileName}')">
                        <svg class="icon icon-sm"><use href="#icon-download" /></svg> ${L.download}
                    </button>
                    ${canWrite ? `<button class="btn btn-xs btn-danger" onclick="deleteDoc(${memberId},${d.Id})">
                        <svg class="icon icon-sm"><use href="#icon-trash" /></svg> ${L.delete}
                    </button>` : ''}
                </div>
            </div>`;
        }).join('');
    } catch {
        list.innerHTML = '<div style="color:var(--danger);font-size:13px;text-align:center;padding:12px;">Failed to load documents.</div>';
    }
}

async function uploadDocs(fileList) {
    if (!fileList || !fileList.length || !_currentMemberId) return;
    const files = Array.from(fileList);
    const status = document.getElementById('docUploadStatus');
    status.style.display = 'block';
    let succeeded = 0, failed = 0;
    for (let i = 0; i < files.length; i++) {
        const file = files[i];
        status.style.color = 'var(--text-muted)';
        status.textContent = `Uploading ${i + 1}/${files.length}: ${file.name}…`;
        const fd = new FormData();
        fd.append('file', file);
        try {
            const r = await fetch(`/api/members/${_currentMemberId}/documents`, {
                method: 'POST',
                headers: pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {},
                body: fd
            });
            const data = await r.json().catch(() => ({}));
            if (r.ok) { succeeded++; }
            else { failed++; }
        } catch { failed++; }
    }
    await loadDocs(_currentMemberId);
    if (failed === 0) {
        status.style.color = 'var(--success)';
        status.textContent = files.length === 1 ? `${files[0].name} uploaded.` : `${succeeded} files uploaded.`;
    } else {
        status.style.color = 'var(--danger)';
        status.textContent = `${succeeded} uploaded, ${failed} failed.`;
    }
    document.getElementById('docFileInput').value = '';
    setTimeout(() => { status.style.display = 'none'; }, 4000);
}

async function viewDoc(memberId, docId, fileName, contentType) {
    // Open the viewer immediately with loading state
    document.getElementById('viewerTitle').textContent = fileName;
    document.getElementById('docViewerBody').innerHTML = '<div class="doc-viewer-loading">Loading preview…</div>';
    document.getElementById('viewerDownloadBtn').onclick = () => downloadDoc(memberId, docId, fileName);
    showModal('docViewerModal');

    try {
        const r = await fetch(`/api/members/${memberId}/documents/${docId}/download`, {
            headers: pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}
        });
        if (!r.ok) { document.getElementById('docViewerBody').innerHTML = '<div class="doc-viewer-error">Failed to load document.</div>'; return; }

        const blob    = await r.blob();
        const objUrl  = URL.createObjectURL(blob);
        const ext     = fileName.split('.').pop().toLowerCase();
        const body    = document.getElementById('docViewerBody');

        if (['png','jpg','jpeg','gif','webp'].includes(ext)) {
            body.innerHTML = `<div class="doc-viewer-img-wrap"><img src="${objUrl}" alt="${fileName}" class="doc-viewer-img" /></div>`;
        } else if (ext === 'pdf') {
            body.innerHTML = `<iframe src="${objUrl}" class="doc-viewer-iframe" title="${fileName}"></iframe>`;
        } else if (ext === 'txt') {
            const text = await blob.text();
            body.innerHTML = `<pre class="doc-viewer-text">${escapeHtml(text)}</pre>`;
            URL.revokeObjectURL(objUrl);
        } else {
            body.innerHTML = `<div class="doc-viewer-unsupported">
                <svg class="icon icon-2xl" style="color:var(--text-muted);margin-bottom:12px;"><use href="#icon-download" /></svg>
                <div style="font-weight:600;margin-bottom:6px;">${L.previewNotAvailable}</div>
                <div style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">${fileName}</div>
                <button class="btn btn-accent" onclick="downloadDoc(${memberId},${docId},'${fileName}')">
                    <svg class="icon icon-sm"><use href="#icon-download" /></svg> ${L.downloadFile}
                </button>
            </div>`;
            URL.revokeObjectURL(objUrl);
        }
    } catch {
        document.getElementById('docViewerBody').innerHTML = '<div class="doc-viewer-error">Could not load preview.</div>';
    }
}

function closeViewer() {
    hideModal('docViewerModal');
    // Revoke any blob URL inside the viewer to free memory
    const iframe = document.querySelector('#docViewerBody iframe');
    const img    = document.querySelector('#docViewerBody img');
    if (iframe) URL.revokeObjectURL(iframe.src);
    if (img)    URL.revokeObjectURL(img.src);
    document.getElementById('docViewerBody').innerHTML = '';
}

function escapeHtml(t) {
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

async function downloadDoc(memberId, docId, fileName) {
    try {
        const r = await fetch(`/api/members/${memberId}/documents/${docId}/download`, {
            headers: pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}
        });
        if (!r.ok) { showToast('error', 'Download failed.'); return; }
        const blob = await r.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url; a.download = fileName;
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
    } catch { showToast('error', 'Download request failed.'); }
}

async function deleteDoc(memberId, docId) {
    if (!confirm(L.deleteDocConfirm)) return;
    try {
        const r = await fetch(`/api/members/${memberId}/documents/${docId}`, {
            method: 'DELETE',
            headers: pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}
        });
        if (r.ok) {
            document.getElementById(`doc-${docId}`)?.remove();
            const list = document.getElementById('docList');
            if (!list.querySelector('.doc-item'))
                list.innerHTML = `<div style="color:var(--text-muted);font-size:13px;text-align:center;padding:12px;">${L.noDocumentsYet}</div>`;
        } else {
            showToast('error', 'Delete failed.');
        }
    } catch { showToast('error', 'Request failed.'); }
}

function handleDocDrop(e) {
    e.preventDefault();
    document.getElementById('docDropZone').classList.remove('drag-over');
    const files = e.dataTransfer?.files;
    if (files && files.length) uploadDocs(files);
}

function formatBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
    return (b/1048576).toFixed(1) + ' MB';
}

// ── Init ──────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.toast').forEach(t => setTimeout(() => t.remove(), 4000));
    const action = new URLSearchParams(location.search).get('action');
    if (action === 'import') showModal('importModal');
    // Wire bulk modal to populate on open
    document.getElementById('bulkModal').addEventListener('show', openBulkModal);
    const bulkBtn = document.querySelector('[onclick="showModal(\'bulkModal\')"]');
    if (bulkBtn) bulkBtn.addEventListener('click', openBulkModal);
});
</script>
}
