@page
@model AdminMembers.Pages.Members.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Members";
    ViewData["LayoutPage"] = "members";
    ViewData["LayoutUser"] = Model.CurrentUser;
    var search      = (string?)ViewContext.HttpContext.Request.Query["search"];
    var sortBy      = (string?)ViewContext.HttpContext.Request.Query["sortBy"];
    var filterRole  = (string?)ViewContext.HttpContext.Request.Query["filterRole"];
    var filterAlive = (string?)ViewContext.HttpContext.Request.Query["filterAlive"];
    // Collect active custom field filters from query string
    var cfFilters = ViewContext.HttpContext.Request.Query.Keys
        .Where(k => k.StartsWith("filterCf_"))
        .ToDictionary(k => k, k => (string?)ViewContext.HttpContext.Request.Query[k]);
    // Build a base query string fragment that preserves all active filters (except the one being changed)
    string CfFilterQs(int? excludeId = null) => string.Join("",
        cfFilters.Where(kv => excludeId == null || kv.Key != $"filterCf_{excludeId}")
                 .Select(kv => $"&{kv.Key}={Uri.EscapeDataString(kv.Value ?? "")}")
    );

    var roles = new[] { "Steunend Lid", "Kandidaat", "Stappend Lid" };
}

<!-- TOASTS -->
<div class="toast-wrap" id="toastWrap">
    @if (Model.SuccessMessage != null)
    {
        <div class="toast success"><span class="toast-icon">&#10003;</span> @Model.SuccessMessage</div>
    }
    @if (Model.ErrorMessage != null)
    {
        <div class="toast error"><span class="toast-icon">&#33;</span> @Model.ErrorMessage</div>
    }
</div>

<div class="page-body">

    <!-- ── SIDEBAR ── -->
    <div class="sidebar form-panel" id="formPanel">
        @if (Model.CanWrite)
        {
        <div class="card">
            <div class="card-header">
                <span class="card-title" id="formTitle">Add Member</span>
                <button type="button" class="btn btn-xs btn-icon" onclick="resetForm()">Reset</button>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save"
                      asp-route-search="@search" asp-route-sortBy="@sortBy"
                      asp-route-filterRole="@filterRole" asp-route-filterAlive="@filterAlive"
                      id="memberForm">

                    <input type="hidden" asp-for="Form.Id" />
                    <input type="hidden" asp-for="Form.AddressId" />

                    <div class="form-section-title" style="margin-top:0;border-top:none;padding-top:0;">Personal</div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>First Name *</label>
                            <input asp-for="Form.FirstName" placeholder="First name" required />
                        </div>
                        <div class="form-group">
                            <label>Last Name *</label>
                            <input asp-for="Form.LastName" placeholder="Last name" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Gender</label>
                            <select asp-for="Form.Gender">
                                <option value="Man">Man</option>
                                <option value="Vrouw">Vrouw</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <select asp-for="Form.IsAlive">
                                <option value="true">Alive</option>
                                <option value="false">Deceased</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Role</label>
                            <select asp-for="Form.Role">
                                <option value="Steunend Lid">Steunend Lid</option>
                                <option value="Kandidaat">Kandidaat</option>
                                <option value="Stappend Lid">Stappend Lid</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Member #</label>
                            <input asp-for="Form.MemberNumber" type="number" placeholder="Optional" min="1" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Birth Date</label>
                            <input asp-for="Form.BirthDate" type="date" />
                        </div>
                        <div class="form-group">
                            <label>Seniority Date</label>
                            <input asp-for="Form.SeniorityDate" type="date" />
                        </div>
                    </div>

                    <div class="form-section-title">Contact</div>

                    <div class="form-group">
                        <label>Email</label>
                        <input asp-for="Form.Email" type="email" placeholder="email@example.com" />
                    </div>
                    <div class="form-group">
                        <label>Phone</label>
                        <input asp-for="Form.PhoneNumber" placeholder="+32 ..." />
                    </div>

                    <div class="form-section-title">Address</div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Street</label>
                            <input asp-for="Form.Street" placeholder="Street" />
                        </div>
                        <div class="form-group">
                            <label>House Nr.</label>
                            <input asp-for="Form.HouseNumber" placeholder="Nr." />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>City</label>
                            <input asp-for="Form.City" placeholder="City" />
                        </div>
                        <div class="form-group">
                            <label>Postal Code</label>
                            <input asp-for="Form.PostalCode" placeholder="0000" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Country</label>
                        <input asp-for="Form.Country" id="Form_Country" placeholder="Belgium" />
                    </div>

                    @if (Model.CustomFields.Any())
                    {
                        <div class="form-section-title">Custom Fields</div>
                        @foreach (var cf in Model.CustomFields)
                        {
                            <div class="form-group">
                                <label>@cf.FieldLabel@(cf.IsRequired ? " *" : "")</label>
                                @if (cf.FieldType == "Boolean")
                                {
                                    <select id="cf_@cf.Id" name="cf_@cf.Id">
                                        <option value="">— select —</option>
                                        <option value="Yes">Yes</option>
                                        <option value="No">No</option>
                                    </select>
                                }
                                else if (cf.FieldType == "Date")
                                {
                                    <input type="date" id="cf_@cf.Id" name="cf_@cf.Id" />
                                }
                                else if (cf.FieldType == "Number")
                                {
                                    <input type="number" id="cf_@cf.Id" name="cf_@cf.Id" />
                                }
                                else
                                {
                                    <input type="text" id="cf_@cf.Id" name="cf_@cf.Id" />
                                }
                            </div>
                        }
                    }

                    <button type="submit" class="btn btn-primary" id="submitBtn" style="margin-top:16px;">
                        Add Member
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="resetForm()">Reset</button>
                </form>
            </div>
        </div>

        <!-- Data management -->
        <div class="card" style="margin-top:16px;">
            <div class="card-header"><span class="card-title">Data</span></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
                <button class="btn btn-icon" onclick="showModal('importModal')">&#128228; Import CSV</button>
                <button class="btn btn-icon" onclick="showModal('exportModal')">&#128229; Export</button>
                <button class="btn btn-icon" onclick="showModal('bulkModal')">&#9998; Bulk Update</button>
            </div>
        </div>
        }
        else
        {
        <!-- Viewer: read-only notice + export only -->
        <div class="card">
            <div class="card-header"><span class="card-title">Members</span></div>
            <div class="card-body">
                <div class="viewer-notice">
                    <span class="viewer-notice-icon">&#128274;</span>
                    <div>
                        <div style="font-weight:600;font-size:13px;">Read-only access</div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">
                            You can view and export members but cannot add, edit or delete.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card" style="margin-top:16px;">
            <div class="card-header"><span class="card-title">Data</span></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
                <button class="btn btn-icon" onclick="showModal('exportModal')">&#128229; Export</button>
            </div>
        </div>
        }
    </div>

    <!-- ── MAIN CONTENT ── -->
    <div class="main-col">

        <!-- Stats (also act as alive/deceased filter) -->
        <div class="stat-strip">
            <a class="stat-item @(string.IsNullOrEmpty(filterAlive) ? "active" : "")"
               href="?search=@search&sortBy=@sortBy&filterRole=@filterRole@CfFilterQs()"
               style="text-decoration:none;">
                <div class="stat-value">@Model.TotalMembers</div>
                <div class="stat-label">@(string.IsNullOrEmpty(filterRole) ? "Total" : filterRole)</div>
            </a>
            <a class="stat-item @(filterAlive == "alive" ? "active" : "")"
               href="?search=@search&sortBy=@sortBy&filterRole=@filterRole&filterAlive=alive@CfFilterQs()"
               style="text-decoration:none;">
                <div class="stat-value green">@Model.ActiveMembers</div>
                <div class="stat-label">Alive</div>
            </a>
            <a class="stat-item @(filterAlive == "deceased" ? "active" : "")"
               href="?search=@search&sortBy=@sortBy&filterRole=@filterRole&filterAlive=deceased@CfFilterQs()"
               style="text-decoration:none;">
                <div class="stat-value">@Model.DeceasedMembers</div>
                <div class="stat-label">Deceased</div>
            </a>
        </div>

        <!-- Toolbar -->
        <div class="toolbar">
            <form method="get" class="toolbar-search">
                <input name="search"     value="@search"     placeholder="Search name, email, member #..." />
                <input type="hidden" name="sortBy"      value="@sortBy" />
                <input type="hidden" name="filterRole"  value="@filterRole" />
                <input type="hidden" name="filterAlive" value="@filterAlive" />
                @foreach (var kv in cfFilters) { <input type="hidden" name="@kv.Key" value="@kv.Value" /> }
                <button class="btn btn-accent btn-sm" type="submit">Search</button>
            </form>
            <div class="toolbar-divider"></div>
            <a class="btn btn-icon btn-sm" href="?search=@search&sortBy=lastName-asc&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs()">A&ndash;Z</a>
            <a class="btn btn-icon btn-sm" href="?search=@search&sortBy=lastName-desc&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs()">Z&ndash;A</a>
            <a class="btn btn-icon btn-sm" href="?search=@search&sortBy=memberNumber-asc&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs()">By&nbsp;#</a>
            @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(filterRole) || !string.IsNullOrEmpty(filterAlive) || cfFilters.Any())
            {
                <a class="btn btn-icon btn-sm" href="/Members">Clear</a>
            }
        </div>

        <!-- Role filter button group -->
        <div class="role-filter-bar">
            <span class="role-filter-label">Rol</span>
            <div class="role-btn-group">
                <a class="role-btn @(string.IsNullOrEmpty(filterRole) ? "active" : "")"
                   href="?search=@search&sortBy=@sortBy&filterAlive=@filterAlive@CfFilterQs()">
                    Alle
                    <span class="role-btn-count">@Model.AllMembersCount</span>
                </a>
                @foreach (var role in roles)
                {
                    var count = Model.RoleCounts.GetValueOrDefault(role, 0);
                    <a class="role-btn @(filterRole == role ? "active" : "")"
                       href="?search=@search&sortBy=@sortBy&filterRole=@Uri.EscapeDataString(role)&filterAlive=@filterAlive@CfFilterQs()">
                        @role
                        <span class="role-btn-count">@count</span>
                    </a>
                }
            </div>
        </div>

        <!-- Custom field filters (only shown if any filterable fields exist) -->
        @if (Model.FilterableCustomFields.Any())
        {
            <div class="role-filter-bar" style="flex-wrap:wrap;gap:8px;">
                <span class="role-filter-label">Filters</span>
                <form method="get" style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
                    <input type="hidden" name="search"      value="@search" />
                    <input type="hidden" name="sortBy"      value="@sortBy" />
                    <input type="hidden" name="filterRole"  value="@filterRole" />
                    <input type="hidden" name="filterAlive" value="@filterAlive" />
                    @foreach (var cf in Model.FilterableCustomFields)
                    {
                        var currentCfVal = cfFilters.GetValueOrDefault($"filterCf_{cf.Id}", "");
                        <div style="display:flex;align-items:center;gap:4px;">
                            <label style="font-size:12px;color:var(--text-muted);white-space:nowrap;">@cf.FieldLabel</label>
                            @if (cf.FieldType == "Boolean")
                            {
                                <select name="filterCf_@cf.Id" style="font-size:12px;padding:4px 8px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);">
                                    <option value="">Alle</option>
                                    @if (currentCfVal == "Yes") { <option value="Yes" selected>Yes</option> } else { <option value="Yes">Yes</option> }
                                    @if (currentCfVal == "No")  { <option value="No"  selected>No</option>  } else { <option value="No">No</option>   }
                                </select>
                            }
                            else
                            {
                                <input type="text" name="filterCf_@cf.Id" value="@currentCfVal"
                                       placeholder="Filter..."
                                       style="font-size:12px;padding:4px 8px;width:120px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);" />
                            }
                        </div>
                    }
                    <button type="submit" class="btn btn-accent btn-sm">Apply</button>
                    @if (cfFilters.Any())
                    {
                        <a class="btn btn-icon btn-sm" href="?search=@search&sortBy=@sortBy&filterRole=@filterRole&filterAlive=@filterAlive">Clear filters</a>
                    }
                </form>
            </div>
        }

        <!-- Member list -->
        @if (Model.Members.Any())
        {
            <div class="member-list">
                @foreach (var m in Model.Members)
                {
                    var av  = ((m.FirstName?.Length > 0 ? m.FirstName[0].ToString() : "?") +
                               (m.LastName?.Length  > 0 ? m.LastName[0].ToString()  : "?")).ToUpper();
                    var det = new List<string>();
                    if (!string.IsNullOrEmpty(m.Email))        det.Add(m.Email);
                    if (!string.IsNullOrEmpty(m.PhoneNumber))  det.Add(m.PhoneNumber);
                    if (m.Address?.City?.Length > 0)           det.Add(m.Address.City);

                    <div class="member-list-item @(m.IsAlive ? "" : "deceased")"
                         onclick="openCard(this)"
                         data-id="@m.Id"
                         data-first="@m.FirstName"     data-last="@m.LastName"
                         data-number="@m.MemberNumber" data-gender="@m.Gender"
                         data-role="@m.Role"           data-email="@m.Email"
                         data-phone="@m.PhoneNumber"   data-alive="@m.IsAlive.ToString().ToLower()"
                         data-street="@m.Address?.Street"      data-housenumber="@m.Address?.HouseNumber"
                         data-city="@m.Address?.City"          data-postal="@m.Address?.PostalCode"
                         data-country="@m.Address?.Country"
                         data-birth="@m.BirthDate?.ToString("yyyy-MM-dd")"
                         data-seniority="@m.SeniorityDate?.ToString("yyyy-MM-dd")"
                         @foreach (var cf in Model.CustomFields)
                         {
                             var cfVal = m.CustomFieldValues?.FirstOrDefault(v => v.CustomFieldId == cf.Id)?.Value ?? "";
                             @:data-cf-@cf.Id="@cfVal" data-cflabel-@cf.Id="@cf.FieldLabel"
                         }>
                        <div class="member-avatar">@av</div>
                        <div class="member-info">
                            <div class="member-name">@m.FirstName @m.LastName</div>
                            <div class="member-details">@string.Join(" · ", det)</div>
                        </div>
                        <div class="member-meta">
                            <div class="member-number">@(m.MemberNumber.HasValue ? $"#{m.MemberNumber}" : "No #")</div>
                            <span class="badge @(m.IsAlive ? "badge-green" : "badge-gray")">
                                @(m.IsAlive ? "Alive" : "Deceased")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-members">
                <h3>No members found</h3>
                <p>@(string.IsNullOrEmpty(search) ? "Use the form to add your first member." : "No results — try a different search.")</p>
            </div>
        }
    </div>
</div>

<!-- FAB for mobile -->
<button class="fab-add" onclick="toggleFormPanel()" title="Add member">&#43;</button>

<!-- ══ CONTACT CARD MODAL ══ -->
<div id="contactModal" class="modal" onclick="if(event.target===this)closeCard()">
    <div class="modal-box">
        <div class="modal-head">
            <h3 id="cardTitle">Member</h3>
            <button class="modal-close-btn" onclick="closeCard()">&times;</button>
        </div>
        <div class="modal-body" id="cardBody"></div>
        <div class="modal-footer" id="cardFooter"></div>
    </div>
</div>

<!-- ══ DELETE MODAL ══ -->
<div id="deleteModal" class="modal" onclick="if(event.target===this)closeDelete()">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>Delete Member</h3>
            <button class="modal-close-btn" onclick="closeDelete()">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:14px;">Delete <strong id="deleteName"></strong>? This cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <form method="post" asp-page-handler="Delete"
                  asp-route-search="@search" asp-route-sortBy="@sortBy"
                  asp-route-filterRole="@filterRole" asp-route-filterAlive="@filterAlive">
                <input type="hidden" name="id" id="deleteId" />
                <button type="button" class="btn btn-icon" onclick="closeDelete()">Cancel</button>
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

<!-- ══ IMPORT MODAL ══ -->
<div id="importModal" class="modal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>Import CSV</h3>
            <button class="modal-close-btn" onclick="this.closest('.modal').style.display='none'">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px;">
                Supported: comma or semicolon separator. First row = headers.<br/>
                Required: <strong>FirstName</strong>, <strong>LastName</strong>
            </p>
            <div class="form-group">
                <label>CSV File</label>
                <input type="file" id="csvFile" accept=".csv"
                       style="width:100%;padding:8px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-icon" onclick="this.closest('.modal').style.display='none'">Cancel</button>
            <button class="btn btn-accent" onclick="importCsv()">Import</button>
        </div>
    </div>
</div>

<!-- ══ EXPORT MODAL ══ -->
<div id="exportModal" class="modal" onclick="if(event.target===this)hideModal('exportModal')">
    <div class="modal-box">
        <div class="modal-head">
            <h3>&#128229; Export Members</h3>
            <button class="modal-close-btn" onclick="hideModal('exportModal')">&times;</button>
        </div>
        <div class="modal-body">

            <!-- Format -->
            <div style="margin-bottom:20px;">
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">Format</div>
                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                    <label class="export-format-pill">
                        <input type="radio" name="exportFormat" value="pdf" checked /> PDF
                    </label>
                    <label class="export-format-pill">
                        <input type="radio" name="exportFormat" value="excel" /> Excel (.xlsx)
                    </label>
                    <label class="export-format-pill">
                        <input type="radio" name="exportFormat" value="csv" /> CSV
                    </label>
                </div>
            </div>

            <!-- Field selection -->
            <div style="margin-bottom:20px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                    <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);">Fields to include</div>
                    <div style="display:flex;gap:8px;">
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(true)">All</button>
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(false)">None</button>
                    </div>
                </div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="ef" value="MemberNumber" checked /> Member #</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="FirstName"    checked /> First Name</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="LastName"     checked /> Last Name</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Gender"       checked /> Gender</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Role"         checked /> Role</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="IsAlive"      checked /> Status</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="BirthDate"           /> Birth Date</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="SeniorityDate"       /> Seniority Date</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Email"               /> Email</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PhoneNumber"         /> Phone</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Street"              /> Street</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="HouseNumber"         /> House #</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="City"                /> City</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PostalCode"          /> Postal Code</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Country"             /> Country</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="CreatedAt"           /> Created Date</label>
                </div>
            </div>

            <!-- Role filter -->
            <div>
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">Filter by role <span style="font-weight:400;text-transform:none;">(leave all unchecked = export everyone)</span></div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="er" value="Steunend Lid"  /> Steunend Lid</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Kandidaat"    /> Kandidaat</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Stappend Lid" /> Stappend Lid</label>
                </div>
            </div>

        </div>
        <div class="modal-footer">
            <span id="exportStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('exportModal')">Cancel</button>
            <button class="btn btn-accent" onclick="runExport()">&#128229; Download</button>
        </div>
    </div>
</div>

<!-- ══ BULK UPDATE MODAL ══ -->
<div id="bulkModal" class="modal" onclick="if(event.target===this)hideModal('bulkModal')">
    <div class="modal-box">
        <div class="modal-head">
            <h3>&#9998; Bulk Update Members</h3>
            <button class="modal-close-btn" onclick="hideModal('bulkModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                Select members below, choose what to update, then click Apply.
                Only filled fields will be updated.
            </p>

            <!-- Field selectors -->
            <div class="form-row" style="margin-bottom:16px;">
                <div class="form-group">
                    <label>Role</label>
                    <select id="bulkRole">
                        <option value="">— no change —</option>
                        <option value="Steunend Lid">Steunend Lid</option>
                        <option value="Kandidaat">Kandidaat</option>
                        <option value="Stappend Lid">Stappend Lid</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <select id="bulkAlive">
                        <option value="">— no change —</option>
                        <option value="true">Alive</option>
                        <option value="false">Deceased</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Gender</label>
                    <select id="bulkGender">
                        <option value="">— no change —</option>
                        <option value="Man">Man</option>
                        <option value="Vrouw">Vrouw</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <!-- Member selection -->
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);">Members <span id="bulkSelectedCount">(0 selected)</span></span>
                <div style="display:flex;gap:8px;">
                    <button type="button" class="btn btn-xs btn-icon" onclick="bulkSelectAll(true)">All</button>
                    <button type="button" class="btn btn-xs btn-icon" onclick="bulkSelectAll(false)">None</button>
                </div>
            </div>
            <div id="bulkMemberList" style="max-height:280px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius-sm);padding:4px;"></div>
        </div>
        <div class="modal-footer">
            <span id="bulkStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('bulkModal')">Cancel</button>
            <button class="btn btn-accent" onclick="applyBulkUpdate()">&#9998; Apply</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
const canWrite = @(Model.CanWrite ? "true" : "false");
const pageToken = '@Model.AuthToken';

// ── Helpers ───────────────────────────────
function showModal(id) { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; }
function hideModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }

// ── Mobile FAB + form panel ───────────────
function toggleFormPanel() {
    document.getElementById('formPanel').classList.toggle('show');
}

// ── Custom field helpers ──────────────────
function buildCustomFieldBlocks(d) {
    let html = '';
    Object.keys(d).forEach(key => {
        if (key.startsWith('cf') && !key.startsWith('cflabel')) {
            const id    = key.slice(2); // strip 'cf'
            const label = d[`cflabel${id}`];
            const value = d[key];
            if (label) html += `<div class="info-block"><div class="info-label">${label}</div><div class="info-value">${value || '—'}</div></div>`;
        }
    });
    return html;
}

// ── Contact card ──────────────────────────
function openCard(el) {
    const d = el.dataset;
    const alive   = d.alive === 'true';
    const initials= ((d.first?.[0] ?? '?') + (d.last?.[0] ?? '?')).toUpperCase();
    const num     = d.number && d.number !== '' ? '#' + d.number : 'No #';
    const addr    = [d.street, d.housenumber].filter(Boolean).join(' ');
    const years   = d.seniority
        ? Math.floor((Date.now() - new Date(d.seniority)) / (365.25 * 864e5))
        : null;

    document.getElementById('cardTitle').textContent = d.first + ' ' + d.last;

    document.getElementById('cardBody').innerHTML = `
        <div style="text-align:center;padding-bottom:18px;border-bottom:1px solid var(--border);margin-bottom:18px;">
            <div class="contact-avatar-lg">${initials}</div>
            <div class="contact-name">${d.first} ${d.last}</div>
            <div class="contact-sub" style="margin-top:8px;">
                <span class="badge badge-purple">${d.role || '—'}</span>
                <span class="badge ${alive ? 'badge-green' : 'badge-gray'}">${alive ? 'Alive' : 'Deceased'}</span>
                <span class="badge badge-gray">${num}</span>
            </div>
        </div>
        <div class="info-grid">
            <div class="info-block"><div class="info-label">Gender</div><div class="info-value">${d.gender || '—'}</div></div>
            <div class="info-block"><div class="info-label">Birth Date</div><div class="info-value">${d.birth || '—'}</div></div>
            <div class="info-block"><div class="info-label">Email</div><div class="info-value">${d.email || '—'}</div></div>
            <div class="info-block"><div class="info-label">Phone</div><div class="info-value">${d.phone || '—'}</div></div>
            <div class="info-block"><div class="info-label">Address</div><div class="info-value">${addr || '—'}</div></div>
            <div class="info-block"><div class="info-label">City</div><div class="info-value">${[d.postal, d.city].filter(Boolean).join(' ') || '—'}</div></div>
            <div class="info-block"><div class="info-label">Country</div><div class="info-value">${d.country || '—'}</div></div>
            ${buildCustomFieldBlocks(d)}
        </div>
        ${years !== null ? `<div class="seniority-box"><div class="years">${years} year${years !== 1 ? 's' : ''}</div><div class="label">Member since ${d.seniority}</div></div>` : ''}`;


    document.getElementById('cardFooter').innerHTML = `
        <button class="btn btn-icon" onclick="closeCard()">Close</button>
        ${canWrite ? `
        <button class="btn btn-accent" onclick="loadEdit(document.querySelector('[data-id=\\'${d.id}\\']'));closeCard()">Edit</button>
        <button class="btn btn-danger" onclick="confirmDelete('${d.id}','${d.first} ${d.last}')">Delete</button>
        ` : ''}`;

    showModal('contactModal');
}

function closeCard() { hideModal('contactModal'); }

// ── Populate edit form ────────────────────
function loadEdit(el) {
    const d = el.dataset;
    document.getElementById('formTitle').textContent = 'Edit Member';
    document.getElementById('submitBtn').textContent  = 'Update Member';
    sv('Form_Id', d.id); sv('Form_FirstName', d.first); sv('Form_LastName', d.last);
    sv('Form_Gender', d.gender); sv('Form_IsAlive', d.alive); sv('Form_Role', d.role);
    sv('Form_MemberNumber', d.number); sv('Form_Email', d.email); sv('Form_PhoneNumber', d.phone);
    sv('Form_BirthDate', d.birth); sv('Form_SeniorityDate', d.seniority);
    sv('Form_Street', d.street); sv('Form_HouseNumber', d.housenumber);
    sv('Form_City', d.city); sv('Form_PostalCode', d.postal); sv('Form_Country', d.country);
    // Populate custom field inputs
    Object.keys(d).forEach(key => {
        if (key.startsWith('cf') && !key.startsWith('cflabel')) {
            const id = key.slice(2);
            const input = document.getElementById(`cf_${id}`);
            if (input) input.value = d[key] ?? '';
        }
    });
    // Show form panel on mobile
    document.getElementById('formPanel').classList.add('show');
    document.getElementById('formPanel').scrollIntoView({ behavior: 'smooth' });
}

function sv(id, val) {
    const el = document.getElementById(id);
    if (el && val !== undefined && val !== null) el.value = val;
}

function resetForm() {
    document.getElementById('memberForm').reset();
    document.getElementById('formTitle').textContent = 'Add Member';
    document.getElementById('submitBtn').textContent  = 'Add Member';
    const id = document.getElementById('Form_Id');
    if (id) id.value = '0';
    const c = document.getElementById('Form_Country');
    if (c && !c.value) c.value = 'Belgium';
    document.getElementById('formPanel').classList.remove('show');
}

// ── Delete ────────────────────────────────
function confirmDelete(id, name) {
    closeCard();
    document.getElementById('deleteId').value = id;
    document.getElementById('deleteName').textContent = name;
    showModal('deleteModal');
}
function closeDelete() { hideModal('deleteModal'); }

// ── Export ────────────────────────────────
function toggleAllFields(checked) {
    document.querySelectorAll('#exportModal input[name="ef"]').forEach(cb => cb.checked = checked);
}

async function runExport() {
    const format = document.querySelector('input[name="exportFormat"]:checked')?.value ?? 'pdf';
    const fields  = [...document.querySelectorAll('#exportModal input[name="ef"]:checked')].map(cb => cb.value);
    const roles   = [...document.querySelectorAll('#exportModal input[name="er"]:checked')].map(cb => cb.value);

    if (fields.length === 0) {
        showToast('error', 'Select at least one field to export.');
        return;
    }

    const statusEl = document.getElementById('exportStatus');
    statusEl.textContent = 'Generating…';

    const endpointMap = { pdf: 'export/pdf', excel: 'export/excel', csv: 'export/csv-custom' };
    const mimeMap     = { pdf: 'application/pdf', excel: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet', csv: 'text/csv' };
    const extMap      = { pdf: 'pdf', excel: 'xlsx', csv: 'csv' };

    try {
        const r = await fetch(`/api/members/${endpointMap[format]}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify({ selectedFields: fields, filterRoles: roles.length > 0 ? roles : null })
        });

        if (!r.ok) {
            const err = await r.json().catch(() => ({}));
            throw new Error(err.error ?? `Server error ${r.status}`);
        }

        const blob = await r.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = url;
        a.download = `members_export_${new Date().toISOString().slice(0,10)}.${extMap[format]}`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);

        statusEl.textContent = '';
        hideModal('exportModal');
        showToast('success', 'Export downloaded successfully.');
    } catch (e) {
        statusEl.textContent = '';
        showToast('error', e.message ?? 'Export failed.');
    }
}

// ── Import CSV ────────────────────────────
async function importCsv() {
    const file = document.getElementById('csvFile').files[0];
    if (!file) { alert('Please select a CSV file.'); return; }
    const fd = new FormData(); fd.append('file', file);
    try {
        const r = await fetch('/api/members/import/csv', { method: 'POST', body: fd });
        const data = await r.json().catch(() => ({}));
        if (r.ok) {
            hideModal('importModal');
            showToast('success', `Imported ${data.imported ?? ''} members.`);
            setTimeout(() => location.reload(), 1500);
        } else { showToast('error', data.error ?? 'Import failed.'); }
    } catch { showToast('error', 'Import request failed.'); }
}

// ── Toast helper ──────────────────────────
function showToast(type, msg) {
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<span class="toast-icon">${type === 'success' ? '&#10003;' : '&#33;'}</span>${msg}`;
    document.getElementById('toastWrap').appendChild(t);
    setTimeout(() => t.remove(), 4000);
}

// ── Bulk update ──────────────────────────
function openBulkModal() {
    // Populate member list from current DOM
    const items = document.querySelectorAll('.member-list-item');
    const list  = document.getElementById('bulkMemberList');
    list.innerHTML = '';
    items.forEach(el => {
        const d    = el.dataset;
        const name = `${d.first} ${d.last}`;
        const num  = d.number ? `#${d.number}` : '';
        const row  = document.createElement('label');
        row.style.cssText = 'display:flex;align-items:center;gap:10px;padding:6px 8px;cursor:pointer;border-radius:4px;font-size:13px;';
        row.innerHTML = `<input type="checkbox" class="bulk-cb" value="${d.id}" style="width:15px;height:15px;flex-shrink:0;">
            <span style="flex:1;">${name}</span>
            <span style="color:var(--text-muted);font-size:12px;">${num} &middot; ${d.role || ''}</span>`;
        row.querySelector('input').addEventListener('change', updateBulkCount);
        list.appendChild(row);
    });
    updateBulkCount();
    document.getElementById('bulkRole').value   = '';
    document.getElementById('bulkAlive').value  = '';
    document.getElementById('bulkGender').value = '';
    document.getElementById('bulkStatus').textContent = '';
}

function updateBulkCount() {
    const n = document.querySelectorAll('.bulk-cb:checked').length;
    document.getElementById('bulkSelectedCount').textContent = `(${n} selected)`;
}

function bulkSelectAll(checked) {
    document.querySelectorAll('.bulk-cb').forEach(cb => { cb.checked = checked; });
    updateBulkCount();
}

async function applyBulkUpdate() {
    const ids    = [...document.querySelectorAll('.bulk-cb:checked')].map(cb => parseInt(cb.value));
    const role   = document.getElementById('bulkRole').value   || null;
    const alive  = document.getElementById('bulkAlive').value;
    const gender = document.getElementById('bulkGender').value || null;

    if (ids.length === 0) { showToast('error', 'Select at least one member.'); return; }
    if (!role && alive === '' && !gender) { showToast('error', 'Choose at least one field to update.'); return; }

    const body = {
        memberIds: ids,
        ...(role   ? { role }   : {}),
        ...(gender ? { gender } : {}),
        ...(alive !== '' ? { isAlive: alive === 'true' } : {})
    };

    const statusEl = document.getElementById('bulkStatus');
    statusEl.textContent = 'Updating…';

    try {
        const r = await fetch('/api/members/bulk-update', {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify(body)
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok) {
            statusEl.textContent = '';
            hideModal('bulkModal');
            showToast('success', `Updated ${data.updatedCount} member(s).`);
            setTimeout(() => location.reload(), 1500);
        } else {
            statusEl.textContent = '';
            showToast('error', data.error ?? data.message ?? `Bulk update failed (HTTP ${r.status}).`);
        }
    } catch {
        statusEl.textContent = '';
        showToast('error', 'Request failed.');
    }
}

// ── Init ──────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.toast').forEach(t => setTimeout(() => t.remove(), 4000));
    const action = new URLSearchParams(location.search).get('action');
    if (action === 'import') showModal('importModal');
    // Wire bulk modal to populate on open
    document.getElementById('bulkModal').addEventListener('show', openBulkModal);
    const bulkBtn = document.querySelector('[onclick="showModal(\'bulkModal\')"]');
    if (bulkBtn) bulkBtn.addEventListener('click', openBulkModal);
});
</script>
}
