@page
@model AdminMembers.Pages.Members.IndexModel
@{
    ViewData["Title"] = "Members";
    var search  = (string?)ViewContext.HttpContext.Request.Query["search"];
    var sortBy  = (string?)ViewContext.HttpContext.Request.Query["sortBy"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Member Administration</title>
    <link rel="stylesheet" href="~/styles.css">
</head>
<body>

<!-- ???????????? HEADER ???????????? -->
<div class="header">
    <div class="header-content">
        <div class="header-title">
            <a href="/Home" class="home-link">Home</a>
            <h1>Member Administration</h1>
        </div>
        <div class="header-actions">
            <a href="/Settings" class="btn-icon btn">Settings</a>
            <form method="post" asp-page-handler="Logout" asp-page="/Home" style="margin:0;">
                <button class="btn-icon btn">
                    @Model.CurrentUser?.Username &nbsp;&#x2715;
                </button>
            </form>
        </div>
    </div>
</div>

<!-- ???????????? TOAST MESSAGES ???????????? -->
@if (Model.SuccessMessage != null)
{
    <div class="message-box">
        <div class="message success">@Model.SuccessMessage</div>
    </div>
}
@if (Model.ErrorMessage != null)
{
    <div class="message-box">
        <div class="message error">@Model.ErrorMessage</div>
    </div>
}

<!-- ???????????? MAIN LAYOUT ???????????? -->
<div class="container">

    <!-- ?? SIDEBAR FORM ?? -->
    <div class="sidebar">
        <div class="form-section">
            <h2 id="formTitle">Add New Member</h2>

            <form method="post" asp-page-handler="Save" asp-route-search="@search" asp-route-sortBy="@sortBy" id="memberForm">

                <input type="hidden" asp-for="Form.Id" id="formId" />
                <input type="hidden" asp-for="Form.AddressId" id="formAddressId" />

                <div class="form-group">
                    <label>Member Number</label>
                    <input asp-for="Form.MemberNumber" type="number" placeholder="Optional (e.g. 1, 2, 3...)" min="1" />
                    <small>Leave empty if member has no number</small>
                </div>

                <div class="form-group">
                    <label>Status *</label>
                    <select asp-for="Form.IsAlive">
                        <option value="true">Alive</option>
                        <option value="false">Deceased</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>First Name *</label>
                    <input asp-for="Form.FirstName" placeholder="First name" required />
                </div>

                <div class="form-group">
                    <label>Last Name *</label>
                    <input asp-for="Form.LastName" placeholder="Last name" required />
                </div>

                <div class="form-group">
                    <label>Gender *</label>
                    <select asp-for="Form.Gender">
                        <option value="Man">Man</option>
                        <option value="Vrouw">Vrouw</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Role *</label>
                    <select asp-for="Form.Role">
                        <option value="Kandidaat">Kandidaat</option>
                        <option value="Lid">Lid</option>
                        <option value="Deken">Deken</option>
                        <option value="Erevoorzitter">Erevoorzitter</option>
                        <option value="Erelid">Erelid</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Form.Email" type="email" placeholder="email@example.com" />
                </div>

                <div class="form-group">
                    <label>Phone Number</label>
                    <input asp-for="Form.PhoneNumber" placeholder="+32 ..." />
                </div>

                <div class="form-group">
                    <label>Birth Date</label>
                    <input asp-for="Form.BirthDate" type="date" />
                </div>

                <div class="form-group">
                    <label>Seniority Date</label>
                    <input asp-for="Form.SeniorityDate" type="date" />
                </div>

                <div class="section-divider">
                    <div class="section-title">Address</div>
                </div>

                <div class="form-group">
                    <label>Street</label>
                    <input asp-for="Form.Street" placeholder="Street name" />
                </div>

                <div class="form-group">
                    <label>House Number</label>
                    <input asp-for="Form.HouseNumber" placeholder="Nr." />
                </div>

                <div class="form-group">
                    <label>City</label>
                    <input asp-for="Form.City" placeholder="City" />
                </div>

                <div class="form-group">
                    <label>Postal Code</label>
                    <input asp-for="Form.PostalCode" placeholder="Postal code" />
                </div>

                <div class="form-group">
                    <label>Country</label>
                    <input asp-for="Form.Country" placeholder="Country" value="@(string.IsNullOrWhiteSpace(Model.Form.Country) ? "Belgium" : Model.Form.Country)" />
                </div>

                <button type="submit" class="btn btn-primary" id="submitBtn">Add Member</button>
                <button type="button" class="btn btn-secondary" onclick="resetForm()">Clear Form</button>
            </form>
        </div>
    </div>

    <!-- ?? MAIN CONTENT ?? -->
    <div class="main-content">

        <!-- List header with search & sort -->
        <div class="list-header">
            <h2>Members (@Model.TotalMembers)</h2>
            <form method="get" class="search-box" style="display:flex;gap:8px;">
                <input class="search-box input" name="search" value="@search" placeholder="Search..." style="flex:1;" />
                <input type="hidden" name="sortBy" value="@sortBy" />
                <button class="btn-icon btn" type="submit">Search</button>
            </form>
            <div style="display:flex;gap:8px;margin-left:12px;">
                <a class="btn-icon btn" href="?search=@search&sortBy=lastName-asc">A-Z</a>
                <a class="btn-icon btn" href="?search=@search&sortBy=lastName-desc">Z-A</a>
                <a class="btn-icon btn" href="?search=@search&sortBy=memberNumber-asc">By #</a>
                @if (!string.IsNullOrEmpty(search))
                {
                    <a class="btn-icon btn" href="/Members">Clear</a>
                }
            </div>
        </div>

        <!-- Stats strip -->
        <div style="display:flex;gap:12px;margin-bottom:16px;">
            <div style="background:#fff;padding:12px 20px;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1);flex:1;text-align:center;">
                <div style="font-size:22px;font-weight:700;">@Model.TotalMembers</div>
                <div style="font-size:12px;color:#666;">Total</div>
            </div>
            <div style="background:#fff;padding:12px 20px;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1);flex:1;text-align:center;">
                <div style="font-size:22px;font-weight:700;color:#2e7d32;">@Model.ActiveMembers</div>
                <div style="font-size:12px;color:#666;">Alive</div>
            </div>
            <div style="background:#fff;padding:12px 20px;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1);flex:1;text-align:center;">
                <div style="font-size:22px;font-weight:700;">@Model.DeceasedMembers</div>
                <div style="font-size:12px;color:#666;">Deceased</div>
            </div>
        </div>

        <!-- Member list -->
        @if (Model.Members.Any())
        {
            <div class="member-list">
                @foreach (var m in Model.Members)
                {
                    var initials = ((m.FirstName?.Length > 0 ? m.FirstName[0].ToString() : "?") +
                                   (m.LastName?.Length  > 0 ? m.LastName[0].ToString()  : "?")).ToUpper();
                    var details = new List<string>();
                    if (!string.IsNullOrEmpty(m.Email))                         details.Add(m.Email);
                    if (!string.IsNullOrEmpty(m.PhoneNumber))                   details.Add(m.PhoneNumber);
                    if (m.Address != null && !string.IsNullOrEmpty(m.Address.City)) details.Add(m.Address.City);

                    <div class="member-list-item @(m.IsAlive ? "" : "deceased")"
                         onclick="openCard(this)" style="cursor:pointer;"
                         data-id="@m.Id"
                         data-first="@m.FirstName"
                         data-last="@m.LastName"
                         data-number="@m.MemberNumber"
                         data-gender="@m.Gender"
                         data-role="@m.Role"
                         data-email="@m.Email"
                         data-phone="@m.PhoneNumber"
                         data-alive="@m.IsAlive.ToString().ToLower()"
                         data-street="@m.Address?.Street"
                         data-housenumber="@m.Address?.HouseNumber"
                         data-city="@m.Address?.City"
                         data-postal="@m.Address?.PostalCode"
                         data-country="@m.Address?.Country"
                         data-birth="@m.BirthDate?.ToString("yyyy-MM-dd")"
                         data-seniority="@m.SeniorityDate?.ToString("yyyy-MM-dd")">
                        <div class="member-avatar">@initials</div>
                        <div class="member-list-info">
                            <div class="member-list-name">@m.FirstName @m.LastName</div>
                            <div class="member-list-details">@string.Join(" | ", details)</div>
                        </div>
                        <div class="member-list-meta">
                            <div class="member-list-number">@(m.MemberNumber.HasValue ? $"#{m.MemberNumber}" : "No #")</div>
                            <div class="member-list-status @(m.IsAlive ? "alive" : "deceased")">
                                @(m.IsAlive ? "Alive" : "Deceased")
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-members">
                <h3>No members found</h3>
                <p>@(string.IsNullOrEmpty(search) ? "Add your first member using the form." : "Try a different search.")</p>
            </div>
        }
    </div>
</div>

<!-- ???????????? CONTACT CARD MODAL ???????????? -->
<div id="contactModal" class="modal" onclick="if(event.target===this) closeCard()">
    <div class="modal-content modal-large">
        <span class="modal-close" onclick="closeCard()">&times;</span>
        <div id="cardBody"></div>
        <div class="contact-card-actions" id="cardActions"></div>
    </div>
</div>

<!-- ???????????? DELETE CONFIRM MODAL ???????????? -->
<div id="deleteModal" class="modal" onclick="if(event.target===this) closeDelete()">
    <div class="modal-content">
        <span class="modal-close" onclick="closeDelete()">&times;</span>
        <div class="modal-header">Delete Member</div>
        <p>Are you sure you want to delete <strong id="deleteName"></strong>? This cannot be undone.</p>
        <form method="post" asp-page-handler="Delete" asp-route-search="@search" asp-route-sortBy="@sortBy" id="deleteForm" style="margin-top:20px;">
            <input type="hidden" name="id" id="deleteId" />
            <button type="submit" class="btn btn-primary" style="background:#d32f2f;">Delete</button>
            <button type="button" class="btn btn-secondary" onclick="closeDelete()">Cancel</button>
        </form>
    </div>
</div>

<script>
    // ??? Contact card modal ???????????????????????????????
    function openCard(el) {
        const d = el.dataset;
        const alive = d.alive === 'true';
        const initials = ((d.first?.[0] ?? '?') + (d.last?.[0] ?? '?')).toUpperCase();
        const num = d.number && d.number !== '' ? '#' + d.number : 'No Member #';
        const addr = [d.street, d.housenumber].filter(Boolean).join(' ');

        const years = d.seniority
            ? Math.floor((Date.now() - new Date(d.seniority)) / (1000 * 60 * 60 * 24 * 365.25))
            : null;

        document.getElementById('cardBody').innerHTML = `
            <div class="contact-card">
                <div class="contact-card-header">
                    <div class="contact-card-avatar">${initials}</div>
                    <div class="contact-card-name">${d.first} ${d.last}</div>
                    <div class="contact-card-number">${num}</div>
                    <div class="contact-card-status ${alive ? 'alive' : 'deceased'}">${alive ? 'Alive' : 'Deceased'}</div>
                </div>
                <div class="contact-card-body">
                    <div class="contact-info-section">
                        <h3>Personal Information</h3>
                        <div class="contact-info-grid">
                            <div class="contact-info-item"><div class="contact-info-label">Gender</div><div class="contact-info-value">${d.gender || 'Ś'}</div></div>
                            <div class="contact-info-item"><div class="contact-info-label">Role</div><div class="contact-info-value">${d.role || 'Ś'}</div></div>
                            <div class="contact-info-item"><div class="contact-info-label">Birth Date</div><div class="contact-info-value">${d.birth || 'Ś'}</div></div>
                        </div>
                    </div>
                    <div class="contact-info-section">
                        <h3>Contact Information</h3>
                        <div class="contact-info-grid">
                            <div class="contact-info-item"><div class="contact-info-label">Email</div><div class="contact-info-value">${d.email || 'Ś'}</div></div>
                            <div class="contact-info-item"><div class="contact-info-label">Phone</div><div class="contact-info-value">${d.phone || 'Ś'}</div></div>
                        </div>
                    </div>
                    <div class="contact-info-section">
                        <h3>Address</h3>
                        <div class="contact-info-grid">
                            <div class="contact-info-item"><div class="contact-info-label">Street</div><div class="contact-info-value">${addr || 'Ś'}</div></div>
                            <div class="contact-info-item"><div class="contact-info-label">City</div><div class="contact-info-value">${d.city || 'Ś'}</div></div>
                            <div class="contact-info-item"><div class="contact-info-label">Postal Code</div><div class="contact-info-value">${d.postal || 'Ś'}</div></div>
                            <div class="contact-info-item"><div class="contact-info-label">Country</div><div class="contact-info-value">${d.country || 'Ś'}</div></div>
                        </div>
                    </div>
                    ${years !== null ? `
                    <div class="contact-info-section">
                        <div class="seniority-highlight">
                            <div class="seniority-years">${years} year${years !== 1 ? 's' : ''}</div>
                            <div class="seniority-label">Member since ${d.seniority}</div>
                        </div>
                    </div>` : ''}
                </div>
            </div>`;

        document.getElementById('cardActions').innerHTML = `
            <button class="btn btn-primary btn-small" style="width:auto;" onclick="loadEditForm(document.querySelector('[data-id=\\'${d.id}\\']'))">Edit</button>
            <button class="btn btn-secondary btn-small" style="width:auto;color:#d32f2f;border-color:#d32f2f;" onclick="confirmDelete('${d.id}','${d.first} ${d.last}')">Delete</button>`;

        document.getElementById('contactModal').style.display = 'block';
        document.body.style.overflow = 'hidden';
    }

    function closeCard() {
        document.getElementById('contactModal').style.display = 'none';
        document.body.style.overflow = '';
    }

    // ??? Edit: populate sidebar form ?????????????????????
    function loadEditForm(el) {
        closeCard();
        const d = el.dataset;
        document.getElementById('formTitle').textContent = 'Edit Member';
        document.getElementById('submitBtn').textContent = 'Update Member';

        setVal('Form_Id', d.id);
        setVal('Form_MemberNumber', d.number);
        setVal('Form_FirstName', d.first);
        setVal('Form_LastName', d.last);
        setVal('Form_Gender', d.gender, true);
        setVal('Form_Role', d.role, true);
        setVal('Form_IsAlive', d.alive, true);
        setVal('Form_Email', d.email);
        setVal('Form_PhoneNumber', d.phone);
        setVal('Form_BirthDate', d.birth);
        setVal('Form_SeniorityDate', d.seniority);
        setVal('Form_Street', d.street);
        setVal('Form_HouseNumber', d.housenumber);
        setVal('Form_City', d.city);
        setVal('Form_PostalCode', d.postal);
        setVal('Form_Country', d.country);

        document.querySelector('.sidebar').scrollIntoView({ behavior: 'smooth' });
    }

    function setVal(id, val, isSelect = false) {
        const el = document.getElementById(id);
        if (!el || val === undefined || val === null) return;
        if (isSelect) el.value = val;
        else el.value = val;
    }

    function resetForm() {
        document.getElementById('formTitle').textContent = 'Add New Member';
        document.getElementById('submitBtn').textContent = 'Add Member';
        document.getElementById('memberForm').reset();
        document.getElementById('Form_Id').value = '0';
        document.getElementById('Form_Country').value = 'Belgium';
    }

    // ??? Delete confirm ???????????????????????????????????
    function confirmDelete(id, name) {
        closeCard();
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteName').textContent = name;
        document.getElementById('deleteModal').style.display = 'block';
        document.body.style.overflow = 'hidden';
    }

    function closeDelete() {
        document.getElementById('deleteModal').style.display = 'none';
        document.body.style.overflow = '';
    }

    // ??? Auto-dismiss toast messages ?????????????????????
    document.addEventListener('DOMContentLoaded', () => {
        const boxes = document.querySelectorAll('.message-box');
        boxes.forEach(b => setTimeout(() => b.remove(), 4000));
    });
</script>
</body>
</html>
