@page
@model AdminMembers.Pages.Members.IndexModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.SharedResources> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Members"];
    ViewData["LayoutPage"] = "members";
    ViewData["LayoutUser"] = Model.CurrentUser;
    var search      = (string?)ViewContext.HttpContext.Request.Query["search"];
    var sortBy      = (string?)ViewContext.HttpContext.Request.Query["sortBy"];
    var filterRole  = (string?)ViewContext.HttpContext.Request.Query["filterRole"];
    var filterAlive = (string?)ViewContext.HttpContext.Request.Query["filterAlive"];
    var filterAliveNorm   = (filterAlive ?? string.Empty).Trim().ToLowerInvariant();
    var filterRoleEncoded = Uri.EscapeDataString(filterRole ?? string.Empty);
    var searchEncoded     = Uri.EscapeDataString(search ?? string.Empty);
    var sortByEncoded     = Uri.EscapeDataString(sortBy ?? string.Empty);
    // Collect active custom field filters from query string
    var cfFilters = ViewContext.HttpContext.Request.Query.Keys
        .Where(k => k.StartsWith("filterCf_"))
        .ToDictionary(k => k, k => (string?)ViewContext.HttpContext.Request.Query[k]);
    // Build a base query string fragment that preserves all active filters (except the one being changed)
    string CfFilterQs(int? excludeId = null) => string.Join("",
        cfFilters.Where(kv => excludeId == null || kv.Key != $"filterCf_{excludeId}")
                 .Select(kv => $"&{kv.Key}={Uri.EscapeDataString(kv.Value ?? "")}")
    );
    // Pre-built tile URLs — avoids any quote conflicts inside HTML href attributes
    var tileBase     = $"?search={searchEncoded}&sortBy={sortByEncoded}&filterRole={filterRoleEncoded}{CfFilterQs()}";
    var urlAlive     = tileBase + "&filterAlive=alive";
    var urlDeceased  = tileBase + "&filterAlive=deceased";
    var urlAll       = tileBase + "&filterAlive=all";

    var roles = new[] { "Steunend Lid", "Kandidaat", "Stappend Lid" };
}

<!-- TOASTS -->
<div class="toast-wrap" id="toastWrap">
    @if (Model.SuccessMessage != null)
    {
        <div class="toast success"><span class="toast-icon">&#10003;</span> @Model.SuccessMessage</div>
    }
    @if (Model.ErrorMessage != null)
    {
        <div class="toast error"><span class="toast-icon">&#33;</span> @Model.ErrorMessage</div>
    }
</div>

<div class="page-body">

    <!-- ── SIDEBAR ── -->
    <div class="sidebar form-panel" id="formPanel">
        @if (Model.CanWrite)
        {
        <div class="card">
            <div class="card-header">
                <span class="card-title" id="formTitle">@Localizer["AddMember"]</span>
                <button type="button" class="btn btn-xs btn-icon" onclick="resetForm()">@Localizer["Reset"]</button>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save"
                      asp-route-search="@search" asp-route-sortBy="@sortBy"
                      asp-route-filterRole="@filterRole" asp-route-filterAlive="@filterAlive"
                      id="memberForm">

                    <input type="hidden" asp-for="Form.Id" />
                    <input type="hidden" asp-for="Form.AddressId" />

                    <div class="form-section-title" style="margin-top:0;border-top:none;padding-top:0;">@Localizer["Personal"]</div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>@Localizer["FirstNameRequired"]</label>
                            <input asp-for="Form.FirstName" placeholder="@Localizer["FirstName"]" required />
                        </div>
                        <div class="form-group">
                            <label>@Localizer["LastNameRequired"]</label>
                            <input asp-for="Form.LastName" placeholder="@Localizer["LastName"]" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>@Localizer["Gender"]</label>
                            <select asp-for="Form.Gender">
                                <option value="Man">@Localizer["Man"]</option>
                                <option value="Vrouw">@Localizer["Woman"]</option>
                                <option value="Other">@Localizer["Other"]</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>@Localizer["Status"]</label>
                            <select asp-for="Form.IsAlive">
                                <option value="true">@Localizer["Alive"]</option>
                                <option value="false">@Localizer["Deceased"]</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>@Localizer["Role"]</label>
                            <select asp-for="Form.Role">
                                <option value="Steunend Lid">@Localizer["SteunendLid"]</option>
                                <option value="Kandidaat">@Localizer["Kandidaat"]</option>
                                <option value="Stappend Lid">@Localizer["StappendLid"]</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>@Localizer["MemberHash"]</label>
                            <input asp-for="Form.MemberNumber" type="number" placeholder="@Localizer["Optional"]" min="1" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>@Localizer["BirthDate"]</label>
                            <input asp-for="Form.BirthDate" type="date" />
                        </div>
                        <div class="form-group">
                            <label>@Localizer["SeniorityDate"]</label>
                            <input asp-for="Form.SeniorityDate" type="date" />
                        </div>
                    </div>

                    <div class="form-section-title">@Localizer["Contact"]</div>

                    <div class="form-group">
                        <label>@Localizer["Email"]</label>
                        <input asp-for="Form.Email" type="email" placeholder="email@example.com" />
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Phone"]</label>
                        <input asp-for="Form.PhoneNumber" placeholder="+32 ..." />
                    </div>

                    <div class="form-section-title">@Localizer["Address"]</div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>@Localizer["Street"]</label>
                            <input asp-for="Form.Street" placeholder="@Localizer["Street"]" />
                        </div>
                        <div class="form-group">
                            <label>@Localizer["HouseNr"]</label>
                            <input asp-for="Form.HouseNumber" placeholder="Nr." />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>@Localizer["City"]</label>
                            <input asp-for="Form.City" placeholder="@Localizer["City"]" />
                        </div>
                        <div class="form-group">
                            <label>@Localizer["PostalCode"]</label>
                            <input asp-for="Form.PostalCode" placeholder="0000" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Country"]</label>
                        <input asp-for="Form.Country" id="Form_Country" placeholder="Belgium" />
                    </div>

                    @if (Model.CustomFields.Any())
                    {
                        <div class="form-section-title">@Localizer["CustomFields"]</div>
                        @foreach (var cf in Model.CustomFields)
                        {
                            <div class="form-group">
                                <label>@cf.FieldLabel@(cf.IsRequired ? " *" : "")</label>
                                @if (cf.FieldType == "Boolean")
                                {
                                    <select id="cf_@cf.Id" name="cf_@cf.Id">
                                        <option value="">@Localizer["SelectAValue"]</option>
                                        <option value="Yes">@Localizer["Ja"]</option>
                                        <option value="No">@Localizer["Nee"]</option>
                                    </select>
                                }
                                else if (cf.FieldType == "Date")
                                {
                                    <input type="date" id="cf_@cf.Id" name="cf_@cf.Id" />
                                }
                                else if (cf.FieldType == "Number")
                                {
                                    <input type="number" id="cf_@cf.Id" name="cf_@cf.Id" />
                                }
                                else
                                {
                                    <input type="text" id="cf_@cf.Id" name="cf_@cf.Id" />
                                }
                            </div>
                        }
                    }

                    <button type="submit" class="btn btn-primary" id="submitBtn" style="margin-top:16px;">
                        @Localizer["AddMember"]
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="resetForm()">@Localizer["Reset"]</button>
                </form>
            </div>
        </div>

        <!-- Data management -->
        <div class="card" style="margin-top:16px;">
            <div class="card-header"><span class="card-title">@Localizer["Data"]</span></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
                <button class="btn btn-icon" onclick="showModal('importModal')">
                    <svg class="icon icon-md"><use href="#icon-upload" /></svg> @Localizer["ImportCSV"]
                </button>
                <button class="btn btn-icon" onclick="showModal('exportModal')">
                    <svg class="icon icon-md"><use href="#icon-download" /></svg> @Localizer["Export"]
                </button>
                <button class="btn btn-icon" onclick="showModal('bulkModal')">
                    <svg class="icon icon-md"><use href="#icon-edit" /></svg> @Localizer["BulkUpdate"]
                </button>
            </div>
        </div>
        }
        else
        {
        <!-- Viewer: read-only notice + export only -->
        <div class="card">
            <div class="card-header"><span class="card-title">@Localizer["Members"]</span></div>
            <div class="card-body">
                <div class="viewer-notice">
                    <svg class="icon icon-xl" style="color:var(--text-muted);"><use href="#icon-lock" /></svg>
                    <div>
                        <div style="font-weight:600;font-size:13px;">@Localizer["ReadOnlyAccess"]</div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">
                            @Localizer["MembersReadOnlyDescription"]
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card" style="margin-top:16px;">
            <div class="card-header"><span class="card-title">@Localizer["Data"]</span></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
                <button class="btn btn-icon" onclick="showModal('exportModal')">
                    <svg class="icon icon-md"><use href="#icon-download" /></svg> @Localizer["Export"]
                </button>
            </div>
        </div>
        }
    </div>

    <!-- ── MAIN CONTENT ── -->
    <div class="main-col">

        <!-- Stats (also act as alive/deceased filter) -->
        <div class="stat-strip">
            <a class="stat-item @(filterAliveNorm == "alive" ? "active" : "")"
               href="@urlAlive" style="text-decoration:none;">
                <div class="stat-value green">@Model.ActiveMembers</div>
                <div class="stat-label">@Localizer["Alive"]</div>
            </a>
            <a class="stat-item @(filterAliveNorm == "deceased" ? "active" : "")"
               href="@urlDeceased" style="text-decoration:none;">
                <div class="stat-value">@Model.DeceasedMembers</div>
                <div class="stat-label">@Localizer["Deceased"]</div>
            </a>
            <a class="stat-item @(filterAliveNorm != "alive" && filterAliveNorm != "deceased" ? "active" : "")"
               href="@urlAll" style="text-decoration:none;">
                <div class="stat-value">@Model.TotalMembers</div>
                <div class="stat-label">@(string.IsNullOrEmpty(filterRole) ? Localizer["Total"].Value : filterRole)</div>
            </a>
        </div>

        <!-- Toolbar -->
        <div class="toolbar">
            <form method="get" class="toolbar-search">
                <input name="search"     value="@search"     placeholder="@Localizer["SearchPlaceholder"]" />
                <input type="hidden" name="sortBy"      value="@sortBy" />
                <input type="hidden" name="filterRole"  value="@filterRole" />
                <input type="hidden" name="filterAlive" value="@filterAlive" />
                @foreach (var kv in cfFilters) { <input type="hidden" name="@kv.Key" value="@kv.Value" /> }
                <button class="btn btn-accent btn-sm" type="submit">@Localizer["Search"]</button>
            </form>
            <div class="toolbar-divider"></div>
            <a class="btn btn-icon btn-sm" href="?search=@search&sortBy=lastName-asc&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs()">@Localizer["AZ"]</a>
            <a class="btn btn-icon btn-sm" href="?search=@search&sortBy=lastName-desc&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs()">@Localizer["ZA"]</a>
            <a class="btn btn-icon btn-sm" href="?search=@search&sortBy=memberNumber-asc&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs()">@Localizer["ByNumber"]</a>
            @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(filterRole) || (filterAlive != null && filterAlive != "alive") || cfFilters.Any())
            {
                <a class="btn btn-icon btn-sm" href="?filterAlive=alive">@Localizer["Clear"]</a>
            }
        </div>

        <!-- Role filter button group -->
        <div class="role-filter-bar">
            <span class="role-filter-label">@Localizer["Rol"]</span>
            <div class="role-btn-group">
                <a class="role-btn @(string.IsNullOrEmpty(filterRole) ? "active" : "")"
                   href="?search=@search&sortBy=@sortBy&filterAlive=@filterAlive@CfFilterQs()">
                    @Localizer["Alle"]
                    <span class="role-btn-count">@Model.AllMembersCount</span>
                </a>
                @foreach (var role in roles)
                {
                    var count = Model.RoleCounts.GetValueOrDefault(role, 0);
                    <a class="role-btn @(filterRole == role ? "active" : "")"
                       href="?search=@search&sortBy=@sortBy&filterRole=@Uri.EscapeDataString(role)&filterAlive=@filterAlive@CfFilterQs()">
                        @role
                        <span class="role-btn-count">@count</span>
                    </a>
                }
            </div>
        </div>

        <!-- Custom field filters (one row per filterable field) -->
        @foreach (var cf in Model.FilterableCustomFields)
        {
            var currentCfVal = cfFilters.GetValueOrDefault($"filterCf_{cf.Id}", "");
            <div class="role-filter-bar">
                <span class="role-filter-label">@cf.FieldLabel</span>
                @if (cf.FieldType == "Boolean")
                {
                    <div class="role-btn-group">
                        <a class="role-btn @(string.IsNullOrEmpty(currentCfVal) ? "active" : "")"
                           href="?search=@search&sortBy=@sortBy&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs(cf.Id)">
                            @Localizer["Alle"]
                        </a>
                        <a class="role-btn @(currentCfVal == "Yes" ? "active" : "")"
                           href="?search=@search&sortBy=@sortBy&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs(cf.Id)&filterCf_@(cf.Id)=Yes">
                            @Localizer["Ja"]
                        </a>
                        <a class="role-btn @(currentCfVal == "No" ? "active" : "")"
                           href="?search=@search&sortBy=@sortBy&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs(cf.Id)&filterCf_@(cf.Id)=No">
                            @Localizer["Nee"]
                        </a>
                    </div>
                }
                else
                {
                    <form method="get" style="display:flex;align-items:center;gap:6px;">
                        <input type="hidden" name="search"      value="@search" />
                        <input type="hidden" name="sortBy"      value="@sortBy" />
                        <input type="hidden" name="filterRole"  value="@filterRole" />
                        <input type="hidden" name="filterAlive" value="@filterAlive" />
                        @foreach (var kv in cfFilters.Where(kv => kv.Key != $"filterCf_{cf.Id}"))
                        {
                            <input type="hidden" name="@kv.Key" value="@kv.Value" />
                        }
                        <input type="text" name="filterCf_@cf.Id" value="@currentCfVal"
                               placeholder="@Localizer["FilterPlaceholder"]"
                               class="role-filter-input" />
                        <button type="submit" class="role-btn active" style="border:none;cursor:pointer;">@Localizer["Zoek"]</button>
                        @if (!string.IsNullOrEmpty(currentCfVal))
                        {
                            <a class="role-btn" href="?search=@search&sortBy=@sortBy&filterRole=@filterRole&filterAlive=@filterAlive@CfFilterQs(cf.Id)">&#x2715;</a>
                        }
                    </form>
                }
            </div>
        }

        <!-- Member list -->
        @if (Model.Members.Any())
        {
            <div class="member-list">
                @foreach (var m in Model.Members)
                {
                    var av  = ((m.FirstName?.Length > 0 ? m.FirstName[0].ToString() : "?") +
                               (m.LastName?.Length  > 0 ? m.LastName[0].ToString()  : "?")).ToUpper();
                    var det = new List<string>();
                    if (!string.IsNullOrEmpty(m.Email))        det.Add(m.Email);
                    if (!string.IsNullOrEmpty(m.PhoneNumber))  det.Add(m.PhoneNumber);
                    if (m.Address?.City?.Length > 0)           det.Add(m.Address.City);

                    <div class="member-list-item @(m.IsAlive ? "" : "deceased")"
                         onclick="openCard(this)"
                         data-id="@m.Id"
                         data-first="@m.FirstName"     data-last="@m.LastName"
                         data-number="@m.MemberNumber" data-gender="@m.Gender"
                         data-role="@m.Role"           data-email="@m.Email"
                         data-phone="@m.PhoneNumber"   data-alive="@m.IsAlive.ToString().ToLower()"
                         data-street="@m.Address?.Street"      data-housenumber="@m.Address?.HouseNumber"
                         data-city="@m.Address?.City"          data-postal="@m.Address?.PostalCode"
                         data-country="@m.Address?.Country"
                         data-birth="@m.BirthDate?.ToString("yyyy-MM-dd")"
                         data-seniority="@m.SeniorityDate?.ToString("yyyy-MM-dd")"
                         @foreach (var cf in Model.CustomFields)
                         {
                             var cfVal = m.CustomFieldValues?.FirstOrDefault(v => v.CustomFieldId == cf.Id)?.Value ?? "";
                             @:data-cf-@cf.Id="@cfVal" data-cflabel-@cf.Id="@cf.FieldLabel"
                         }>
                        <div class="member-avatar">@av</div>
                        <div class="member-info">
                            <div class="member-name">@m.LastName @m.FirstName</div>
                            <div class="member-details">@string.Join(" · ", det)</div>
                        </div>
                        <div class="member-meta">
                            <div class="member-number">@(m.MemberNumber.HasValue ? $"#{m.MemberNumber}" : Localizer["NoNumber"].Value)</div>
                            <span class="badge @(m.IsAlive ? "badge-green" : "badge-gray")">
                                @(m.IsAlive ? Localizer["Alive"].Value : Localizer["Deceased"].Value)
                            </span>
                            @{
                                var roleBadgeClass = m.Role switch {
                                    "Stappend Lid"  => "badge-purple",
                                    "Kandidaat"     => "badge-orange",
                                    "Steunend Lid"  => "badge-blue",
                                    _               => "badge-gray"
                                };
                            }
                            <span class="badge @roleBadgeClass">@m.Role</span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-members">
                <h3>@Localizer["NoMembersFound"]</h3>
                <p>@(string.IsNullOrEmpty(search) ? Localizer["UseFormToAddFirst"].Value : Localizer["NoResultsTryDifferent"].Value)</p>
            </div>
        }
    </div>
</div>

<!-- FAB for mobile -->
<button class="fab-add" onclick="toggleFormPanel()" title="@Localizer["AddMember"]">&#43;</button>

<!-- ══ CONTACT CARD MODAL ══ -->
<div id="contactModal" class="modal" onclick="if(event.target===this)closeCard()">
    <div class="modal-box">
        <div class="modal-head">
            <h3 id="cardTitle">@Localizer["Members"]</h3>
            <button class="modal-close-btn" onclick="closeCard()">&times;</button>
        </div>
        <div class="modal-tabs">
            <button class="modal-tab active" onclick="switchTab('info',this)">@Localizer["Info"]</button>
            <button class="modal-tab" onclick="switchTab('docs',this)">
                <svg class="icon icon-sm" style="margin-right:4px;"><use href="#icon-paperclip" /></svg>@Localizer["Documents"]
            </button>
        </div>
        <div class="modal-body">
            <div id="tabInfo" class="modal-tab-panel active">
                <div id="cardBody"></div>
            </div>
            <div id="tabDocs" class="modal-tab-panel">
                <div id="docList" class="doc-list">
                    <div style="color:var(--text-muted);font-size:13px;text-align:center;padding:12px;">Loading...</div>
                </div>
                @if (Model.CanWrite)
                {
                <div class="doc-upload-area" id="docDropZone"
                     onclick="document.getElementById('docFileInput').click()"
                     ondragover="event.preventDefault();this.classList.add('drag-over')"
                     ondragleave="this.classList.remove('drag-over')"
                     ondrop="handleDocDrop(event)">
                    <svg class="icon icon-xl" style="margin-bottom:8px;color:var(--accent);"><use href="#icon-upload" /></svg>
                    <div style="font-weight:600;">@Localizer["ClickOrDragUpload"]</div>
                    <div style="font-size:12px;margin-top:4px;">@Localizer["UploadFileTypes"]</div>
                    <input type="file" id="docFileInput" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.webp,.txt,.msg"
                           multiple onchange="uploadDocs(this.files)" />
                </div>
                <div id="docUploadStatus" style="font-size:12px;margin-top:8px;display:none;"></div>
                }
            </div>
        </div>
        <div class="modal-footer" id="cardFooter"></div>
    </div>
</div>

<!-- ══ DOCUMENT VIEWER MODAL ══ -->
<div id="docViewerModal" class="modal" onclick="if(event.target===this)closeViewer()">
    <div class="modal-box doc-viewer-box">
        <div class="modal-head">
            <h3 id="viewerTitle" style="font-size:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:calc(100% - 80px);">@Localizer["Documents"]</h3>
            <div style="display:flex;gap:8px;flex-shrink:0;">
                <button class="btn btn-xs btn-icon" id="viewerDownloadBtn">
                    <svg class="icon icon-sm"><use href="#icon-download" /></svg> @Localizer["Download"]
                </button>
                <button class="modal-close-btn" onclick="closeViewer()">&times;</button>
            </div>
        </div>
        <div class="doc-viewer-body" id="docViewerBody">
            <div class="doc-viewer-loading">Loading preview…</div>
        </div>
    </div>
</div>

<!-- ══ DELETE MODAL ══ -->
<div id="deleteModal" class="modal" onclick="if(event.target===this)closeDelete()">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>@Localizer["DeleteMember"]</h3>
            <button class="modal-close-btn" onclick="closeDelete()">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:14px;">@Localizer["DeleteMemberConfirm"] <strong id="deleteName"></strong>? @Localizer["CannotBeUndone"]</p>
        </div>
        <div class="modal-footer">
            <form method="post" asp-page-handler="Delete"
                  asp-route-search="@search" asp-route-sortBy="@sortBy"
                  asp-route-filterRole="@filterRole" asp-route-filterAlive="@filterAlive">
                <input type="hidden" name="id" id="deleteId" />
                <button type="button" class="btn btn-icon" onclick="closeDelete()">@Localizer["Cancel"]</button>
                <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
            </form>
        </div>
    </div>
</div>

<!-- ══ IMPORT MODAL ══ -->
<div id="importModal" class="modal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>@Localizer["ImportCSV"]</h3>
            <button class="modal-close-btn" onclick="this.closest('.modal').style.display='none'">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px;">
                @Localizer["ImportCSVDescription"]<br/>
                @Localizer["ImportCSVRequired"] <strong>FirstName</strong>, <strong>LastName</strong>
            </p>
            <div class="form-group">
                <label>@Localizer["CSVFile"]</label>
                <input type="file" id="csvFile" accept=".csv"
                       style="width:100%;padding:8px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-icon" onclick="this.closest('.modal').style.display='none'">@Localizer["Cancel"]</button>
            <button class="btn btn-accent" onclick="importCsv()">@Localizer["Import"]</button>
        </div>
    </div>
</div>

<!-- ══ EXPORT MODAL ══ -->
