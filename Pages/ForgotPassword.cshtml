@page
@model AdminMembers.Pages.ForgotPasswordModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.SharedResources> Localizer
@{
    Layout = null;
    ViewData["Title"] = Localizer["ForgotPasswordTitle"];
    var culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var currentPath = ViewContext.HttpContext.Request.Path + ViewContext.HttpContext.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Localizer["ForgotPasswordTitle"] - @Localizer["AppTitle"]</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-wrap">
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none"><symbol id="icon-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol><symbol id="icon-arrow-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></symbol></svg>
    <div style="position:absolute;top:20px;right:20px;z-index:10;">
        <form method="post" action="/set-language" style="margin:0;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentPath" />
            <div style="display:flex;align-items:center;gap:4px;padding:4px;border:1px solid rgba(255,255,255,.2);border-radius:999px;background:rgba(15,23,42,.75);backdrop-filter:blur(8px);box-shadow:0 8px 24px rgba(0,0,0,.18);">
                <button type="submit" name="culture" value="nl" style="border:none;border-radius:999px;padding:8px 14px;font-size:12px;font-weight:700;letter-spacing:.03em;cursor:pointer;transition:.2s;background:@(culture == "nl" ? "linear-gradient(135deg,#6366f1,#4f46e5)" : "transparent");color:@(culture == "nl" ? "#fff" : "#cbd5e1");">NL</button>
                <button type="submit" name="culture" value="en" style="border:none;border-radius:999px;padding:8px 14px;font-size:12px;font-weight:700;letter-spacing:.03em;cursor:pointer;transition:.2s;background:@(culture == "en" ? "linear-gradient(135deg,#6366f1,#4f46e5)" : "transparent");color:@(culture == "en" ? "#fff" : "#cbd5e1");">EN</button>
            </div>
        </form>
    </div>
    <div class="login-card">
        <div class="login-head">
            <svg class="icon icon-2xl" style="color:#6366f1;margin-bottom:12px;"><use href="#icon-shield" /></svg>
            <h1>@Localizer["ForgotPasswordTitle"]</h1>
            <p>@Localizer["ForgotPasswordIntro"]</p>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div style="padding:12px 16px;background:#e8f5e9;color:#2e7d32;border-radius:8px;border:1px solid #2e7d32;margin-bottom:16px;">
                    &#10003; @Model.SuccessMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-error">@Model.ErrorMessage</div>
            }
            @if (string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="login-input-group">
                        <label>@Localizer["EmailAddress"]</label>
                        <input asp-for="Email" type="email" placeholder="your@email.com" autofocus required />
                    </div>
                    <button type="submit" class="btn-login" style="margin-top:12px;">@Localizer["SendResetLink"]</button>
                </form>
            }
            <div style="text-align:center;margin-top:20px;font-size:13px;color:var(--text-muted);">
                <a href="/Login" style="color:var(--accent);font-weight:600;">&#8592; @Localizer["BackToSignIn"]</a>
            </div>
        </div>
    </div>
</body>
</html>
