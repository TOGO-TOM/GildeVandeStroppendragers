@page
@model AdminMembers.Pages.ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Gilde Van De Stroppendragers</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-wrap">
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none"><symbol id="icon-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol><symbol id="icon-arrow-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></symbol></svg>
    <div class="login-card">
        <div class="login-head">
            <svg class="icon icon-2xl" style="color:#6366f1;margin-bottom:12px;"><use href="#icon-shield" /></svg>
            <h1>Forgot Password</h1>
            <p>Enter your email address and we'll send you a reset link.</p>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div style="padding:12px 16px;background:#e8f5e9;color:#2e7d32;border-radius:8px;border:1px solid #2e7d32;margin-bottom:16px;">
                    &#10003; @Model.SuccessMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-error">@Model.ErrorMessage</div>
            }
            @if (string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="login-input-group">
                        <label>Email address</label>
                        <input asp-for="Email" type="email" placeholder="your@email.com" autofocus required />
                    </div>
                    <button type="submit" class="btn-login" style="margin-top:12px;">Send Reset Link</button>
                </form>
            }
            <div style="text-align:center;margin-top:20px;font-size:13px;color:var(--text-muted);">
                <a href="/Login" style="color:var(--accent);font-weight:600;">&#8592; Back to Sign In</a>
            </div>
        </div>
    </div>
</body>
</html>
