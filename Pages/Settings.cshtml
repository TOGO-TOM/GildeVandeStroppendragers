@page
@model AdminMembers.Pages.SettingsModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AdminMembers.SharedResources> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Settings"];
    ViewData["LayoutPage"] = "settings";
    ViewData["LayoutUser"] = Model.CurrentUser;
}

<div class="page-body-full settings-page">

    <div class="page-heading">
        <h1>@Localizer["Settings"]</h1>
        <p>@Localizer["SettingsPageDescription"]</p>
    </div>

    <div class="settings-grid">

        <!-- NAV -->
        <div class="settings-nav card">
            <a class="settings-nav-item active" href="#" onclick="showSection('general',this)">
                <span class="nav-icon">&#9881;&#65039;</span> @Localizer["General"]
            </a>
            <a class="settings-nav-item" href="#" onclick="showSection('fields',this)">
                <span class="nav-icon">&#9776;</span> @Localizer["CustomFields"]
            </a>
            @if (Model.HasPermission("ReadWrite"))
            {
                <a class="settings-nav-item" href="#" onclick="showSection('users',this)">
                    <span class="nav-icon">&#128100;</span> @Localizer["Users"]
                </a>
            }
            @if (Model.IsSuperAdmin)
            {
                <a class="settings-nav-item" href="#" onclick="showSection('api',this)">
                    <span class="nav-icon">&#128273;</span> API
                </a>
            }
        </div>

        <!-- CONTENT -->
        <div class="settings-content">

            <!-- General -->
            <div id="sec-general" class="settings-section active">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">@Localizer["GeneralSettings"]</span>
                    </div>
                    <div class="card-body">
                        <form id="generalForm" onsubmit="saveGeneralSettings(event)" enctype="multipart/form-data">

                            <div class="settings-row">
                                <div>
                                    <div class="settings-row-label">@Localizer["CompanyName"]</div>
                                    <div class="settings-row-desc">@Localizer["CompanyNameDescription"]</div>
                                </div>
                                <input id="companyName" name="companyName" type="text"
                                       value="@(Model.GeneralSettings?.CompanyName ?? "")"
                                       placeholder="@Localizer["EnterCompanyName"]"
                                       style="width:260px;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);font-size:13px;" />
                            </div>

                            <div class="settings-row">
                                <div>
                                    <div class="settings-row-label">@Localizer["Logo"]</div>
                                    <div class="settings-row-desc">@Localizer["LogoDescription"]</div>
                                </div>
                                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                                    @if (Model.HasLogo)
                                    {
                                        <img id="logoPreview" src="/api/settings/logo" alt="@Localizer["Logo"]"
                                             style="height:40px;border-radius:6px;border:1px solid var(--border);" />
                                    }
                                    else
                                    {
                                        <img id="logoPreview" src="" alt="" style="height:40px;border-radius:6px;border:1px solid var(--border);display:none;" />
                                    }
                                    <label class="btn btn-icon btn-sm" style="cursor:pointer;margin:0;">
                                        &#128247; @Localizer["ChooseFile"]
                                        <input type="file" id="logoFile" name="logo" accept="image/png,image/jpeg,image/gif"
                                               style="display:none;" onchange="previewLogo(this)" />
                                    </label>
                                    @if (Model.HasLogo)
                                    {
                                        <button type="button" class="btn btn-danger btn-sm" onclick="deleteLogo()">&#128465; @Localizer["Remove"]</button>
                                    }
                                </div>
                            </div>

                            <div class="settings-row" style="border-bottom:none;padding-bottom:0;justify-content:flex-end;gap:12px;align-items:center;">
                                <span id="generalStatus" style="font-size:12px;color:var(--text-muted);"></span>
                                <button type="submit" class="btn btn-accent">&#10003; @Localizer["SaveSettings"]</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card" style="margin-top:16px;">
                    <div class="card-header"><span class="card-title">@Localizer["ExportMembers"]</span></div>
                    <div class="card-body">
                        <div class="settings-row" style="border-bottom:none;padding-bottom:0;">
                            <div>
                                <div class="settings-row-label">@Localizer["DownloadMemberData"]</div>
                                <div class="settings-row-desc">@Localizer["DownloadMemberDataDescription"]</div>
                            </div>
                            <button class="btn btn-accent btn-sm" onclick="showModal('exportModal')">&#128229; @Localizer["Export"]</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Fields -->
            <div id="sec-fields" class="settings-section">
                <div class="card">
                    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
                        <span class="card-title">
                            @Localizer["CustomFields"]
                            <span class="badge badge-gray" style="margin-left:6px;" id="fieldCount">@Model.CustomFields.Count</span>
                        </span>
                        <button class="btn btn-accent btn-sm" onclick="openFieldModal()">&#43; @Localizer["AddField"]</button>
                    </div>
                    <div class="card-body" id="customFieldsList">
                        @if (Model.CustomFields.Any())
                        {
                            foreach (var f in Model.CustomFields)
                            {
                                <div class="settings-row" id="field-row-@f.Id">
                                    <div class="field-tag">
                                        <span style="font-weight:700;">@f.FieldLabel</span>
                                        <span class="badge badge-gray">@f.FieldType</span>
                                        @if (f.IsRequired) { <span class="badge badge-red">@Localizer["Required"]</span> }
                                        @if (f.IsFilterable) { <span class="badge badge-purple">@Localizer["Filterable"]</span> }
                                        @if (!f.IsActive) { <span class="badge badge-gray">@Localizer["Inactive"]</span> }
                                    </div>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <span style="font-size:12px;color:var(--text-muted);">@Localizer["Order"]: @f.DisplayOrder</span>
                                        <button class="btn btn-icon btn-sm" onclick="openFieldModal(@f.Id,'@f.FieldName','@f.FieldLabel','@f.FieldType',@(f.IsRequired ? "true" : "false"),@(f.IsActive ? "true" : "false"),@f.DisplayOrder,@(f.IsFilterable ? "true" : "false"))">&#9998;</button>
                                        <button class="btn btn-danger btn-sm" onclick="deleteField(@f.Id)">&#128465;</button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state" id="fieldsEmptyState">
                                <h3>@Localizer["NoCustomFields"]</h3>
                                <p>@Localizer["NoCustomFieldsDescription"]</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Users -->
            @if (Model.HasPermission("ReadWrite"))
            {
                <div id="sec-users" class="settings-section">

                    @* ?? Pending approvals ?? *@
                    @if (Model.PendingUsers.Any())
                    {
                        <div class="card pending-card" style="margin-bottom:16px;">
                            <div class="card-header">
                                <span class="card-title">
                                    &#9888; @Localizer["PendingApprovals"]
                                    <span class="badge badge-red" style="margin-left:6px;">@Model.PendingUsers.Count</span>
                                </span>
                            </div>
                            <div class="card-body" style="padding:0;">
                                @foreach (var p in Model.PendingUsers)
                                {
                                    <div class="pending-row">
                                        <div class="pending-info">
                                            <div class="pending-name">@p.Username</div>
                                            <div class="pending-email">@p.Email</div>
                                            <div class="pending-date">@Localizer["Requested"] @p.CreatedAt.ToString("d MMM yyyy HH:mm")</div>
                                        </div>
                                        <div class="pending-actions">
                                            <form method="post" asp-page-handler="Approve" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@p.Id" />
                                                <select name="roleId" class="pending-role-select" required>
                                                    <option value="">@Localizer["AssignRole"]</option>
                                                    @foreach (var r in Model.Roles)
                                                    {
                                                        <option value="@r.Id">@r.Name</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-accent">&#10003; @Localizer["Approve"]</button>
                                            </form>
                                            <form method="post" asp-page-handler="Reject" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@p.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('@Localizer["RejectRegistrationConfirm"]')">
                                                    &#10005; @Localizer["Reject"]
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* ?? Active users ?? *@
                    <div class="card">
                        <div class="card-header">
                            <span class="card-title">
                                @Localizer["ActiveUsers"]
                                <span class="badge badge-gray" style="margin-left:6px;">@Model.Users.Count</span>
                            </span>
                        </div>
                        <div class="card-body">
                            @if (Model.Users.Any())
                            {
                                foreach (var u in Model.Users)
                                {
                                    var uInitials = u.Username?.Substring(0, 1).ToUpper() ?? "?";
                                    <div class="settings-row">
                                        <div style="display:flex;align-items:center;gap:12px;">
                                            <div class="user-avatar" style="width:36px;height:36px;font-size:14px;flex-shrink:0;">@uInitials</div>
                                            <div>
                                                <div style="font-weight:600;font-size:14px;">@u.Username</div>
                                                <div style="font-size:12px;color:var(--text-muted);">@u.Email</div>
                                            </div>
                                        </div>
                                        <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;">
                                            @foreach (var ur in u.UserRoles)
                                            {
                                                <span class="badge badge-purple">@ur.Role.Name</span>
                                            }
                                            @if (!u.IsActive) { <span class="badge badge-gray">@Localizer["Inactive"]</span> }
                                            @if (u.LastLoginAt.HasValue)
                                            {
                                                <span style="font-size:11px;color:var(--text-muted);">@Localizer["LastLogin"]: @u.LastLoginAt.Value.ToString("d MMM yyyy")</span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="empty-state"><h3>@Localizer["NoActiveUsers"]</h3><p>@Localizer["NoActiveUsersDescription"]</p></div>
                            }
                        </div>
                    </div>
                </div>
            }

                    @if (Model.IsSuperAdmin)
                    {
                        <div id="sec-api" class="settings-section">

                            <!-- API Keys Management -->
                            <div class="card">
                                <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
                                    <span class="card-title">&#128273; API Keys</span>
                                    <button class="btn btn-accent btn-sm" onclick="showApiCreateModal()">&#43; Nieuwe API Key</button>
                                </div>
                                <div class="card-body" style="padding:0;">
                                    <div id="apiKeysList" style="min-height:60px;">
                                        <div style="padding:30px;text-align:center;color:var(--text-muted);">Laden...</div>
                                    </div>
                                </div>
                            </div>

                            <!-- API Usage Help -->
                            <div class="card" style="margin-top:16px;">
                                <div class="card-header">
                                    <span class="card-title">&#10067; Hoe gebruik je de API?</span>
                                </div>
                                <div class="card-body" style="line-height:1.7;">

                                    <div class="settings-row">
                                        <div>
                                            <div class="settings-row-label">&#128274; Authenticatie</div>
                                            <div class="settings-row-desc">Elke API-aanvraag moet een geldige API-sleutel bevatten.</div>
                                        </div>
                                    </div>
                                    <div style="padding:0 16px 16px;">
                                        <ul style="margin:0 0 0 16px;font-size:13px;line-height:2;">
                                            <li><strong>Header (aanbevolen):</strong> <code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">X-Api-Key: jouw-api-sleutel</code></li>
                                            <li><strong>Query parameter:</strong> <code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">?apikey=jouw-api-sleutel</code></li>
                                        </ul>
                                    </div>

                                    <div class="settings-row">
                                        <div>
                                            <div class="settings-row-label">&#128225; Endpoints</div>
                                            <div class="settings-row-desc">Beschikbare API endpoints voor externe toegang.</div>
                                        </div>
                                    </div>
                                    <div style="padding:0 16px 16px;">
                                        <table style="width:100%;border-collapse:collapse;font-size:13px;">
                                            <thead>
                                                <tr style="text-align:left;border-bottom:2px solid var(--border);">
                                                    <th style="padding:8px;">Endpoint</th>
                                                    <th style="padding:8px;">Beschrijving</th>
                                                    <th style="padding:8px;">Permissie</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr style="border-bottom:1px solid var(--border);">
                                                    <td style="padding:8px;"><code>GET /api/public/members</code></td>
                                                    <td style="padding:8px;">Lijst van alle leden (gepagineerd)</td>
                                                    <td style="padding:8px;"><span class="badge badge-green">Read</span></td>
                                                </tr>
                                                <tr style="border-bottom:1px solid var(--border);">
                                                    <td style="padding:8px;"><code>GET /api/public/members/{id}</code></td>
                                                    <td style="padding:8px;">Details van een specifiek lid</td>
                                                    <td style="padding:8px;"><span class="badge badge-green">Read</span></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="settings-row">
                                        <div>
                                            <div class="settings-row-label">&#128196; Output formaten</div>
                                            <div class="settings-row-desc">Gebruik de <code>Accept</code> header om het formaat te kiezen.</div>
                                        </div>
                                    </div>
                                    <div style="padding:0 16px 16px;">
                                        <ul style="margin:0 0 0 16px;font-size:13px;line-height:2;">
                                            <li><code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">Accept: application/json</code> &mdash; JSON (standaard)</li>
                                            <li><code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">Accept: application/xml</code> &mdash; XML</li>
                                        </ul>
                                    </div>

                                    <div class="settings-row">
                                        <div>
                                            <div class="settings-row-label">&#128202; Excel / Power Query</div>
                                            <div class="settings-row-desc">Stappen om de API in Excel te gebruiken via Power Query.</div>
                                        </div>
                                    </div>
                                    <div style="padding:0 16px 16px;">
                                        <ol style="margin:0 0 0 16px;font-size:13px;line-height:2.2;">
                                            <li>Open Excel &rarr; <strong>Gegevens</strong> &rarr; <strong>Gegevens ophalen</strong> &rarr; <strong>Van web</strong></li>
                                            <li>Kies <strong>Geavanceerd</strong></li>
                                            <li>Voer de URL in: <code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">https://jouw-domein/api/public/members</code></li>
                                            <li>Voeg een HTTP-header toe: <code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">X-Api-Key</code> met je API-sleutel</li>
                                            <li>Klik op <strong>OK</strong> en transformeer de data naar een tabel</li>
                                        </ol>
                                    </div>

                                    <div class="settings-row">
                                        <div>
                                            <div class="settings-row-label">&#128214; Paginering &amp; filters</div>
                                            <div class="settings-row-desc">Optionele query parameters voor de ledenlijst.</div>
                                        </div>
                                    </div>
                                    <div style="padding:0 16px 16px;">
                                        <ul style="margin:0 0 0 16px;font-size:13px;line-height:2;">
                                            <li><code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">?page=1&amp;pageSize=50</code> &mdash; pagina 1 met 50 resultaten</li>
                                            <li><code style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">?role=Lid</code> &mdash; filter op rol</li>
                                        </ul>
                                    </div>

                                    <div class="settings-row" style="border-bottom:none;">
                                        <div>
                                            <div class="settings-row-label">&#9888;&#65039; Rechten</div>
                                            <div class="settings-row-desc"><strong>Read</strong> = alleen gegevens ophalen (GET) &bull; <strong>ReadWrite</strong> = ophalen en wijzigen</div>
                                        </div>
                                    </div>

                                </div>
                            </div>

                        </div>
                    }

                </div>
            </div>
        </div>

        <!-- CUSTOM FIELD MODAL -->
<div id="fieldModal" class="modal" onclick="if(event.target===this)hideModal('fieldModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3 id="fieldModalTitle">@Localizer["AddCustomField"]</h3>
            <button class="modal-close-btn" onclick="hideModal('fieldModal')">&times;</button>
        </div>
        <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
            <input type="hidden" id="fieldId" value="0" />
            <div class="form-group">
                <label>@Localizer["FieldName"] <span style="font-size:11px;color:var(--text-muted);">(@Localizer["InternalNoSpaces"])</span></label>
                <input type="text" id="fieldName" placeholder="@Localizer["E.gMembershipType"]" style="width:100%;" />
            </div>
            <div class="form-group">
                <label>@Localizer["Label"] <span style="font-size:11px;color:var(--text-muted);">(@Localizer["ShownToUsers"])</span></label>
                <input type="text" id="fieldLabel" placeholder="@Localizer["E.gMembershipType"]" style="width:100%;" />
            </div>
            <div class="form-group">
                <label>@Localizer["Type"]</label>
                <select id="fieldType" style="width:100%;">
                    <option value="Text">@Localizer["Text"]</option>
                    <option value="Number">@Localizer["Number"]</option>
                    <option value="Date">@Localizer["Date"]</option>
                    <option value="Boolean">@Localizer["YesNo"]</option>
                </select>
            </div>
            <div class="form-row" style="gap:24px;">
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" id="fieldRequired" /> @Localizer["Required"]
                </label>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" id="fieldActive" checked /> @Localizer["Active"]
                </label>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" id="fieldFilterable" /> @Localizer["Filterable"]
                </label>
            </div>
            <div class="form-group">
                <label>@Localizer["DisplayOrder"]</label>
                <input type="number" id="fieldOrder" value="0" min="0" style="width:100px;" />
            </div>
        </div>
        <div class="modal-footer">
            <span id="fieldStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('fieldModal')">@Localizer["Cancel"]</button>
            <button class="btn btn-accent" onclick="saveField()">&#10003; @Localizer["Save"]</button>
        </div>
    </div>
</div>

<!-- EXPORT MODAL -->
<div id="exportModal" class="modal" onclick="if(event.target===this)hideModal('exportModal')">
    <div class="modal-box">
        <div class="modal-head">
            <h3>&#128229; @Localizer["ExportMembers"]</h3>
            <button class="modal-close-btn" onclick="hideModal('exportModal')">&times;</button>
        </div>
        <div class="modal-body">

            <!-- Format -->
            <div style="margin-bottom:20px;">
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">@Localizer["Format"]</div>
                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="pdf" checked /> PDF</label>
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="excel" /> Excel (.xlsx)</label>
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="csv" /> CSV</label>
                </div>
            </div>

            <!-- Field selection -->
            <div style="margin-bottom:20px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                    <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);">@Localizer["FieldsToInclude"]</div>
                    <div style="display:flex;gap:8px;">
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(true)">@Localizer["All"]</button>
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(false)">@Localizer["None"]</button>
                    </div>
                </div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="ef" value="MemberNumber" checked /> @Localizer["MemberNumber"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="FirstName"    checked /> @Localizer["FirstName"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="LastName"     checked /> @Localizer["LastName"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Gender"       checked /> @Localizer["Gender"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Role"         checked /> @Localizer["Role"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="IsAlive"      checked /> @Localizer["Status"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="BirthDate"           /> @Localizer["BirthDate"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="SeniorityDate"       /> @Localizer["SeniorityDate"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Email"               /> @Localizer["Email"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PhoneNumber"         /> @Localizer["Phone"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Street"              /> @Localizer["Street"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="HouseNumber"         /> @Localizer["HouseNumber"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="City"                /> @Localizer["City"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PostalCode"          /> @Localizer["PostalCode"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Country"             /> @Localizer["Country"]</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="CreatedAt"           /> @Localizer["CreatedDate"]</label>
                </div>
            </div>

            <!-- Role filter -->
            <div>
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">@Localizer["FilterByRole"] <span style="font-weight:400;text-transform:none;">(@Localizer["LeaveAllUnchecked"])</span></div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="er" value="Steunend Lid"  /> @Localizer["SteunendLid"]</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Kandidaat"    /> @Localizer["Kandidaat"]</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Stappend Lid" /> @Localizer["StappendLid"]</label>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <span id="exportStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('exportModal')">@Localizer["Cancel"]</button>
            <button class="btn btn-accent" onclick="runExport()">&#128229; @Localizer["Download"]</button>
        </div>
    </div>
</div>

<!-- API KEY CREATE MODAL -->
@if (Model.IsSuperAdmin)
{
<div id="apiCreateModal" class="modal" onclick="if(event.target===this)hideModal('apiCreateModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>&#128273; Nieuwe API Key</h3>
            <button class="modal-close-btn" onclick="hideModal('apiCreateModal')">&times;</button>
        </div>
        <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
            <div class="form-group">
                <label>Naam *</label>
                <input type="text" id="akName" placeholder="Bijv. Excel koppeling" style="width:100%;" />
            </div>
            <div class="form-group">
                <label>Permissie</label>
                <select id="akPermission" style="width:100%;">
                    <option value="Read">Read (alleen lezen)</option>
                    <option value="ReadWrite">ReadWrite (lezen + schrijven)</option>
                </select>
            </div>
            <div class="form-group">
                <label>Vervaldatum (optioneel)</label>
                <input type="date" id="akExpires" style="width:100%;" />
            </div>
        </div>
        <div class="modal-footer">
            <span id="akStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('apiCreateModal')">Annuleren</button>
            <button class="btn btn-accent" onclick="createApiKey()">&#10003; Aanmaken</button>
        </div>
    </div>
</div>

<div id="apiRawKeyModal" class="modal" onclick="if(event.target===this)hideModal('apiRawKeyModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3>&#9989; API Key aangemaakt</h3>
            <button class="modal-close-btn" onclick="hideModal('apiRawKeyModal')">&times;</button>
        </div>
        <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
            <div style="color:var(--danger);font-weight:600;">&#9888;&#65039; Kopieer deze sleutel nu! Hij wordt maar &eacute;&eacute;n keer getoond.</div>
            <div style="display:flex;gap:8px;align-items:center;">
                <input id="rawKeyDisplay" readonly style="flex:1;font-family:monospace;font-size:13px;padding:8px 12px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);" />
                <button class="btn btn-accent btn-sm" onclick="copyApiRawKey()">&#128203; Kopieer</button>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-icon" onclick="hideModal('apiRawKeyModal')">Sluiten</button>
        </div>
    </div>
</div>
}
<script>
const pageToken = '@Model.AuthToken';
const L = {
    saving: '@Html.Raw(Localizer["Saving"].Value.Replace("'", "\\'"))',
    saved: '@Html.Raw(Localizer["Saved"].Value.Replace("'", "\\'"))',
    saveFailed: '@Html.Raw(Localizer["SaveFailed"].Value.Replace("'", "\\'"))',
    requestFailed: '@Html.Raw(Localizer["RequestFailed"].Value.Replace("'", "\\'"))',
};

function showModal(id) { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; }
function hideModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }

window.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
        hideModal('fieldModal');
        hideModal('exportModal');
        hideModal('apiCreateModal');
        hideModal('apiRawKeyModal');
    }
});

// ?? Section nav ???????????????????????????
function showSection(id, el) {
    event.preventDefault();
    document.querySelectorAll('.settings-section').forEach(s => {
        s.style.opacity = '0';
        s.style.transform = 'translateY(6px)';
        setTimeout(() => s.classList.remove('active'), 150);
    });
    document.querySelectorAll('.settings-nav-item').forEach(a => a.classList.remove('active'));
    setTimeout(() => {
        const target = document.getElementById('sec-' + id);
        target.classList.add('active');
        requestAnimationFrame(() => { target.style.opacity = '1'; target.style.transform = 'translateY(0)'; });
    }, 160);
    el.classList.add('active');
    if (id === 'api' && !window._apiKeysLoaded) {
        window._apiKeysLoaded = true;
        setTimeout(loadApiKeys, 200);
    }
}

// ?? Logo preview ??????????????????????????
function previewLogo(input) {
    if (!input.files || !input.files[0]) return;
    const img = document.getElementById('logoPreview');
    img.src = URL.createObjectURL(input.files[0]);
    img.style.display = 'block';
}

// ?? Save general settings ?????????????????
async function saveGeneralSettings(e) {
    e.preventDefault();
    const statusEl = document.getElementById('generalStatus');
    statusEl.textContent = L.saving;
    statusEl.style.color = '';

    const fd = new FormData();
    fd.append('companyName', document.getElementById('companyName').value);
    const logoFile = document.getElementById('logoFile').files[0];
    if (logoFile) fd.append('logo', logoFile);

    try {
        const r = await fetch('/api/settings', {
            method: 'POST',
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) },
            body: fd
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok) {
            statusEl.style.color = 'green';
            statusEl.textContent = L.saved;
            setTimeout(() => { statusEl.textContent = ''; statusEl.style.color = ''; }, 3000);
        } else {
            statusEl.style.color = 'red';
            statusEl.textContent = data.error ?? L.saveFailed;
        }
    } catch {
        statusEl.style.color = 'red';
        statusEl.textContent = L.requestFailed;
    }
}

// ?? Delete logo ???????????????????????????
async function deleteLogo() {
    if (!confirm('@Localizer["RemoveLogoConfirm"]')) return;
    try {
        const r = await fetch('/api/settings/logo', {
            method: 'DELETE',
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) }
        });
        if (r.ok) {
            const img = document.getElementById('logoPreview');
            img.src = ''; img.style.display = 'none';
            document.querySelector('[onclick="deleteLogo()"]')?.remove();
        }
    } catch { alert('@Localizer["FailedToRemoveLogo"]'); }
}

// ?? Custom fields ?????????????????????????
function openFieldModal(id = 0, name = '', label = '', type = 'Text', required = false, active = true, order = 0, filterable = false) {
    document.getElementById('fieldModalTitle').textContent = id === 0 ? '@Localizer["AddCustomField"]' : '@Localizer["EditCustomField"]';
    document.getElementById('fieldId').value    = id;
    document.getElementById('fieldName').value  = name;
    document.getElementById('fieldLabel').value = label;
    document.getElementById('fieldType').value  = type;
    document.getElementById('fieldRequired').checked   = required;
    document.getElementById('fieldActive').checked     = active;
    document.getElementById('fieldFilterable').checked = filterable;
    document.getElementById('fieldOrder').value = order;
    document.getElementById('fieldName').readOnly = id !== 0;
    document.getElementById('fieldStatus').textContent = '';
    showModal('fieldModal');
}

async function saveField() {
    const id       = parseInt(document.getElementById('fieldId').value);
    const name     = document.getElementById('fieldName').value.trim();
    const label    = document.getElementById('fieldLabel').value.trim();
    const type     = document.getElementById('fieldType').value;
    const required   = document.getElementById('fieldRequired').checked;
    const active     = document.getElementById('fieldActive').checked;
    const filterable = document.getElementById('fieldFilterable').checked;
    const order      = parseInt(document.getElementById('fieldOrder').value) || 0;
    const statusEl   = document.getElementById('fieldStatus');

    if (!name || !label) { statusEl.textContent = '@Localizer["NameLabelRequired"]'; return; }

    const isNew  = id === 0;
    const url    = isNew ? '/api/settings/custom-fields' : `/api/settings/custom-fields/${id}`;
    const method = isNew ? 'POST' : 'PUT';
    const body   = { id, fieldName: name, fieldLabel: label, fieldType: type, isRequired: required, isActive: active, isFilterable: filterable, displayOrder: order };

    statusEl.textContent = L.saving;
    try {
        const r = await fetch(url, {
            method,
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify(body)
        });
        if (r.ok) { hideModal('fieldModal'); location.reload(); }
        else {
            const d = await r.json().catch(() => ({}));
            statusEl.textContent = d.error ?? '@Localizer["SaveFailed"]';
        }
    } catch { statusEl.textContent = '@Localizer["RequestFailed"]'; }
}

async function deleteField(id) {
    if (!confirm('@Localizer["DeleteCustomFieldConfirm"]')) return;
    try {
        const r = await fetch(`/api/settings/custom-fields/${id}`, {
            method: 'DELETE',
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) }
        });
        if (r.ok) {
            document.getElementById(`field-row-${id}`)?.remove();
            const remaining = document.querySelectorAll('[id^="field-row-"]').length;
            document.getElementById('fieldCount').textContent = remaining;
            if (remaining === 0)
                document.getElementById('customFieldsList').innerHTML =
                    '<div class="empty-state"><h3>@Localizer["NoCustomFields"]</h3><p>@Localizer["NoCustomFieldsDescription"]</p></div>';
        } else { alert('@Localizer["FailedToDeleteField"]'); }
    } catch { alert(L.requestFailed); }
}

// ?? Export ????????????????????????????????
function toggleAllFields(checked) {
    document.querySelectorAll('#exportModal input[name="ef"]').forEach(cb => cb.checked = checked);
}

async function runExport() {
    const format  = document.querySelector('input[name="exportFormat"]:checked')?.value ?? 'pdf';
    const fields  = [...document.querySelectorAll('#exportModal input[name="ef"]:checked')].map(cb => cb.value);
    const roles   = [...document.querySelectorAll('#exportModal input[name="er"]:checked')].map(cb => cb.value);

    if (fields.length === 0) { alert('@Localizer["SelectAtLeastOneField"]'); return; }

    const statusEl = document.getElementById('exportStatus');
    statusEl.textContent = '@Localizer["Generating"]�';

    const endpointMap = { pdf: 'export/pdf', excel: 'export/excel', csv: 'export/csv-custom' };
    const extMap      = { pdf: 'pdf', excel: 'xlsx', csv: 'csv' };

    try {
        const r = await fetch(`/api/members/${endpointMap[format]}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify({ selectedFields: fields, filterRoles: roles.length > 0 ? roles : null })
        });
        if (!r.ok) { const err = await r.json().catch(() => ({})); throw new Error(err.error ?? `Server error ${r.status}`); }
        const blob = await r.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url;
        a.download = `members_export_${new Date().toISOString().slice(0,10)}.${extMap[format]}`;
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
        statusEl.textContent = '';
        hideModal('exportModal');
    } catch (e) {
        statusEl.textContent = '';
        alert(e.message ?? '@Localizer["ExportFailed"]');
    }
}

// ── API Keys ─────────────────────────────
function showApiCreateModal() {
    document.getElementById('akName').value = '';
    document.getElementById('akPermission').value = 'Read';
    document.getElementById('akExpires').value = '';
    document.getElementById('akStatus').textContent = '';
    showModal('apiCreateModal');
}

function loadApiKeys() {
    const el = document.getElementById('apiKeysList');
    if (!el) return;
    fetch('/api/admin/apikeys', {
        headers: { 'Authorization': 'Bearer ' + pageToken }
    })
    .then(r => { if (!r.ok) throw new Error(); return r.json(); })
    .then(keys => renderApiKeys(keys))
    .catch(() => { el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--danger);">Fout bij laden van API keys.</div>'; });
}

function renderApiKeys(keys) {
    const el = document.getElementById('apiKeysList');
    if (!keys.length) {
        el.innerHTML = '<div style="padding:30px;text-align:center;color:var(--text-muted);">Nog geen API keys aangemaakt.</div>';
        return;
    }
    let html = '<table style="width:100%;border-collapse:collapse;font-size:13px;">';
    html += '<thead><tr style="text-align:left;border-bottom:2px solid var(--border);">';
    html += '<th style="padding:10px 14px;">Naam</th><th style="padding:10px 14px;">Prefix</th><th style="padding:10px 14px;">Permissie</th><th style="padding:10px 14px;">Status</th><th style="padding:10px 14px;">Vervalt</th><th style="padding:10px 14px;"></th>';
    html += '</tr></thead><tbody>';
    keys.forEach(k => {
        const badge = k.IsActive
            ? '<span class="badge badge-green">Actief</span>'
            : '<span class="badge badge-red">Ingetrokken</span>';
        const expires = k.ExpiresAt ? new Date(k.ExpiresAt).toLocaleDateString('nl-BE') : '\u2014';
        html += '<tr style="border-bottom:1px solid var(--border);">';
        html += '<td style="padding:10px 14px;font-weight:600;">' + escApi(k.Name) + '</td>';
        html += '<td style="padding:10px 14px;font-family:monospace;">' + escApi(k.KeyPrefix) + '...</td>';
        html += '<td style="padding:10px 14px;">' + escApi(k.Permission) + '</td>';
        html += '<td style="padding:10px 14px;">' + badge + '</td>';
        html += '<td style="padding:10px 14px;">' + expires + '</td>';
        html += '<td style="padding:10px 14px;text-align:right;display:flex;gap:6px;justify-content:flex-end;">';
        if (k.IsActive) html += '<button class="btn btn-danger btn-sm" onclick="revokeApiKey(' + k.Id + ')">Intrekken</button>';
        html += '<button class="btn btn-danger btn-sm" style="opacity:0.7;" onclick="deleteApiKey(' + k.Id + ')">&#128465; Verwijderen</button>';
        html += '</td></tr>';
    });
    html += '</tbody></table>';
    el.innerHTML = html;
}

function escApi(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

async function createApiKey() {
    const name = document.getElementById('akName').value.trim();
    const statusEl = document.getElementById('akStatus');
    if (!name) { statusEl.textContent = 'Naam is verplicht.'; return; }
    const body = {
        name,
        permission: document.getElementById('akPermission').value,
        expiresAt: document.getElementById('akExpires').value || null
    };
    statusEl.textContent = L.saving;
    try {
        const r = await fetch('/api/admin/apikeys', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + pageToken, 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (!r.ok) { const err = await r.json().catch(() => ({})); statusEl.textContent = err.error || L.saveFailed; return; }
        const result = await r.json();
        hideModal('apiCreateModal');
        document.getElementById('rawKeyDisplay').value = result.Key;
        showModal('apiRawKeyModal');
        loadApiKeys();
    } catch { statusEl.textContent = L.requestFailed; }
}

function copyApiRawKey() {
    const input = document.getElementById('rawKeyDisplay');
    input.select();
    navigator.clipboard.writeText(input.value);
}

async function revokeApiKey(id) {
    if (!confirm('Weet je zeker dat je deze key wilt intrekken?')) return;
    try {
        const r = await fetch('/api/admin/apikeys/' + id, {
            method: 'DELETE',
            headers: { 'Authorization': 'Bearer ' + pageToken }
        });
        if (r.ok) loadApiKeys();
        else alert(L.requestFailed);
    } catch { alert(L.requestFailed); }
}

async function deleteApiKey(id) {
    if (!confirm('Weet je zeker dat je deze key permanent wilt verwijderen?')) return;
    try {
        const r = await fetch('/api/admin/apikeys/' + id + '/permanent', {
            method: 'DELETE',
            headers: { 'Authorization': 'Bearer ' + pageToken }
        });
        if (r.ok) loadApiKeys();
        else alert(L.requestFailed);
    } catch { alert(L.requestFailed); }
}

// Load API keys when section becomes visible
window._apiKeysLoaded = false;
</script>
}
