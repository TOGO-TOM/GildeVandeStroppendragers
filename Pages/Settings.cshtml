@page
@model AdminMembers.Pages.SettingsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Settings";
    ViewData["LayoutPage"] = "settings";
    ViewData["LayoutUser"] = Model.CurrentUser;
}

<div class="page-body-full settings-page">

    <div class="page-heading">
        <h1>Settings</h1>
        <p>Manage application configuration, custom fields and users.</p>
    </div>

    <div class="settings-grid">

        <!-- NAV -->
        <div class="settings-nav card">
            <a class="settings-nav-item active" href="#" onclick="showSection('general',this)">
                <span class="nav-icon">&#9881;&#65039;</span> General
            </a>
            <a class="settings-nav-item" href="#" onclick="showSection('fields',this)">
                <span class="nav-icon">&#9776;</span> Custom Fields
            </a>
            @if (Model.HasPermission("ReadWrite"))
            {
                <a class="settings-nav-item" href="#" onclick="showSection('users',this)">
                    <span class="nav-icon">&#128100;</span> Users
                </a>
            }
        </div>

        <!-- CONTENT -->
        <div class="settings-content">

            <!-- General -->
            <div id="sec-general" class="settings-section active">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">General Settings</span>
                    </div>
                    <div class="card-body">
                        <div class="settings-row">
                            <div>
                                <div class="settings-row-label">Company Name</div>
                                <div class="settings-row-desc">Displayed in the application header and exports.</div>
                            </div>
                            <span class="settings-row-value">@(Model.GeneralSettings?.CompanyName ?? "Not configured")</span>
                        </div>
                        <div class="settings-row">
                            <div>
                                <div class="settings-row-label">Logo</div>
                                <div class="settings-row-desc">Company logo used in PDF exports.</div>
                            </div>
                            @if (Model.HasLogo)
                            {
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <img src="/api/settings/logo" alt="Logo" style="height:36px;border-radius:6px;border:1px solid var(--border);" />
                                    <span class="badge badge-green">Uploaded</span>
                                </div>
                            }
                            else
                            {
                                <span class="badge badge-gray">Not set</span>
                            }
                        </div>
                        <div class="settings-row" style="border-bottom:none;padding-bottom:0;">
                            <div>
                                <div class="settings-row-label">API Endpoints</div>
                                <div class="settings-row-desc">Use these to update settings programmatically.</div>
                            </div>
                            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                <span class="badge badge-purple">POST /api/settings</span>
                                <span class="badge badge-purple">POST /api/settings/logo</span>
                            </div>
                        </div>
                        <div class="settings-row" style="border-top:1px solid var(--border);margin-top:8px;padding-top:16px;border-bottom:none;padding-bottom:0;">
                            <div>
                                <div class="settings-row-label">Export Members</div>
                                <div class="settings-row-desc">Download all member data in your preferred format.</div>
                            </div>
                            <button class="btn btn-accent btn-sm" onclick="showModal('exportModal')">&#128229; Export</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Fields -->
            <div id="sec-fields" class="settings-section">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">
                            Custom Fields
                            <span class="badge badge-gray" style="margin-left:6px;">@Model.CustomFields.Count</span>
                        </span>
                    </div>
                    <div class="card-body">
                        @if (Model.CustomFields.Any())
                        {
                            @foreach (var f in Model.CustomFields)
                            {
                                <div class="settings-row">
                                    <div class="field-tag">
                                        <span style="font-weight:700;">@f.FieldLabel</span>
                                        <span class="badge badge-gray">@f.FieldType</span>
                                        @if (f.IsRequired) { <span class="badge badge-red">Required</span> }
                                        @if (!f.IsActive)  { <span class="badge badge-gray">Inactive</span> }
                                    </div>
                                    <span style="font-size:12px;color:var(--text-muted);">Order: @f.DisplayOrder</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <h3>No custom fields</h3>
                                <p>Use the API to add custom fields to member profiles.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Users -->
            @if (Model.HasPermission("ReadWrite"))
            {
                <div id="sec-users" class="settings-section">

                    @* ?? Pending approvals ?? *@
                    @if (Model.PendingUsers.Any())
                    {
                        <div class="card pending-card" style="margin-bottom:16px;">
                            <div class="card-header">
                                <span class="card-title">
                                    &#9888; Pending Approvals
                                    <span class="badge badge-red" style="margin-left:6px;">@Model.PendingUsers.Count</span>
                                </span>
                            </div>
                            <div class="card-body" style="padding:0;">
                                @foreach (var p in Model.PendingUsers)
                                {
                                    <div class="pending-row">
                                        <div class="pending-info">
                                            <div class="pending-name">@p.Username</div>
                                            <div class="pending-email">@p.Email</div>
                                            <div class="pending-date">Requested @p.CreatedAt.ToString("d MMM yyyy HH:mm")</div>
                                        </div>
                                        <div class="pending-actions">
                                            <form method="post" asp-page-handler="Approve" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@p.Id" />
                                                <select name="roleId" class="pending-role-select" required>
                                                    <option value="">Assign role…</option>
                                                    @foreach (var r in Model.Roles)
                                                    {
                                                        <option value="@r.Id">@r.Name</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-accent">&#10003; Approve</button>
                                            </form>
                                            <form method="post" asp-page-handler="Reject" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@p.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Reject and delete this registration request?')">
                                                    &#10005; Reject
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* ?? Active users ?? *@
                    <div class="card">
                        <div class="card-header">
                            <span class="card-title">
                                Active Users
                                <span class="badge badge-gray" style="margin-left:6px;">@Model.Users.Count</span>
                            </span>
                        </div>
                        <div class="card-body">
                            @if (Model.Users.Any())
                            {
                                @foreach (var u in Model.Users)
                                {
                                    var uInitials = u.Username?.Substring(0, 1).ToUpper() ?? "?";
                                    <div class="settings-row">
                                        <div style="display:flex;align-items:center;gap:12px;">
                                            <div class="user-avatar" style="width:36px;height:36px;font-size:14px;flex-shrink:0;">@uInitials</div>
                                            <div>
                                                <div style="font-weight:600;font-size:14px;">@u.Username</div>
                                                <div style="font-size:12px;color:var(--text-muted);">@u.Email</div>
                                            </div>
                                        </div>
                                        <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;">
                                            @foreach (var ur in u.UserRoles)
                                            {
                                                <span class="badge badge-purple">@ur.Role.Name</span>
                                            }
                                            @if (!u.IsActive) { <span class="badge badge-gray">Inactive</span> }
                                            @if (u.LastLoginAt.HasValue)
                                            {
                                                <span style="font-size:11px;color:var(--text-muted);">Last login: @u.LastLoginAt.Value.ToString("d MMM yyyy")</span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="empty-state"><h3>No active users</h3><p>Approve pending requests to add users.</p></div>
                            }
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<!-- ?? EXPORT MODAL ?? -->
<div id="exportModal" class="modal" onclick="if(event.target===this)hideModal('exportModal')">
    <div class="modal-box">
        <div class="modal-head">
            <h3>&#128229; Export Members</h3>
            <button class="modal-close-btn" onclick="hideModal('exportModal')">&times;</button>
        </div>
        <div class="modal-body">

            <!-- Format -->
            <div style="margin-bottom:20px;">
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">Format</div>
                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="pdf" checked /> PDF</label>
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="excel" /> Excel (.xlsx)</label>
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="csv" /> CSV</label>
                </div>
            </div>

            <!-- Field selection -->
            <div style="margin-bottom:20px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                    <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);">Fields to include</div>
                    <div style="display:flex;gap:8px;">
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(true)">All</button>
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(false)">None</button>
                    </div>
                </div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="ef" value="MemberNumber" checked /> Member #</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="FirstName"    checked /> First Name</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="LastName"     checked /> Last Name</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Gender"       checked /> Gender</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Role"         checked /> Role</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="IsAlive"      checked /> Status</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="BirthDate"           /> Birth Date</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="SeniorityDate"       /> Seniority Date</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Email"               /> Email</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PhoneNumber"         /> Phone</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Street"              /> Street</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="HouseNumber"         /> House #</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="City"                /> City</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PostalCode"          /> Postal Code</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Country"             /> Country</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="CreatedAt"           /> Created Date</label>
                </div>
            </div>

            <!-- Role filter -->
            <div>
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">Filter by role <span style="font-weight:400;text-transform:none;">(leave all unchecked = export everyone)</span></div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="er" value="Steunend Lid"  /> Steunend Lid</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Kandidaat"    /> Kandidaat</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Stappend Lid" /> Stappend Lid</label>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <span id="exportStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('exportModal')">Cancel</button>
            <button class="btn btn-accent" onclick="runExport()">&#128229; Download</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
const pageToken = '@Model.AuthToken';

function showModal(id)
function hideModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }

function toggleAllFields(checked) {
    document.querySelectorAll('#exportModal input[name="ef"]').forEach(cb => cb.checked = checked);
}

async function runExport() {
    const format = document.querySelector('input[name="exportFormat"]:checked')?.value ?? 'pdf';
    const fields  = [...document.querySelectorAll('#exportModal input[name="ef"]:checked')].map(cb => cb.value);
    const roles   = [...document.querySelectorAll('#exportModal input[name="er"]:checked')].map(cb => cb.value);

    if (fields.length === 0) { alert('Select at least one field to export.'); return; }

    const statusEl = document.getElementById('exportStatus');
    statusEl.textContent = 'Generating…';

    const endpointMap = { pdf: 'export/pdf', excel: 'export/excel', csv: 'export/csv-custom' };
    const extMap      = { pdf: 'pdf', excel: 'xlsx', csv: 'csv' };

    try {
        const r = await fetch(`/api/members/${endpointMap[format]}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify({ selectedFields: fields, filterRoles: roles.length > 0 ? roles : null })
        });

        if (!r.ok) {
            const err = await r.json().catch(() => ({}));
            throw new Error(err.error ?? `Server error ${r.status}`);
        }

        const blob = await r.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = url;
        a.download = `members_export_${new Date().toISOString().slice(0,10)}.${extMap[format]}`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);

        statusEl.textContent = '';
        hideModal('exportModal');
    } catch (e) {
        statusEl.textContent = '';
        alert(e.message ?? 'Export failed.');
    }
}

function showSection(id, el) {
    event.preventDefault();
    const sections = document.querySelectorAll('.settings-section');
    const navItems = document.querySelectorAll('.settings-nav-item');

    sections.forEach(s => {
        s.style.opacity = '0';
        s.style.transform = 'translateY(6px)';
        setTimeout(() => { s.classList.remove('active'); }, 150);
    });
    navItems.forEach(a => a.classList.remove('active'));

    setTimeout(() => {
        const target = document.getElementById('sec-' + id);
        target.classList.add('active');
        requestAnimationFrame(() => {
            target.style.opacity = '1';
            target.style.transform = 'translateY(0)';
        });
    }, 160);

    el.classList.add('active');
}
</script>
}
