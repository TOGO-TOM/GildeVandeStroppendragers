@page
@model AdminMembers.Pages.SettingsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Settings";
    ViewData["LayoutPage"] = "settings";
    ViewData["LayoutUser"] = Model.CurrentUser;
}

<div class="page-body-full settings-page">

    <div class="page-heading">
        <h1>Settings</h1>
        <p>Manage application configuration, custom fields and users.</p>
    </div>

    <div class="settings-grid">

        <!-- NAV -->
        <div class="settings-nav card">
            <a class="settings-nav-item active" href="#" onclick="showSection('general',this)">
                <span class="nav-icon">&#9881;&#65039;</span> General
            </a>
            <a class="settings-nav-item" href="#" onclick="showSection('fields',this)">
                <span class="nav-icon">&#9776;</span> Custom Fields
            </a>
            @if (Model.HasPermission("ReadWrite"))
            {
                <a class="settings-nav-item" href="#" onclick="showSection('users',this)">
                    <span class="nav-icon">&#128100;</span> Users
                </a>
            }
        </div>

        <!-- CONTENT -->
        <div class="settings-content">

            <!-- General -->
            <div id="sec-general" class="settings-section active">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">General Settings</span>
                    </div>
                    <div class="card-body">
                        <form id="generalForm" onsubmit="saveGeneralSettings(event)" enctype="multipart/form-data">

                            <div class="settings-row">
                                <div>
                                    <div class="settings-row-label">Company Name</div>
                                    <div class="settings-row-desc">Displayed in exports and PDF headers.</div>
                                </div>
                                <input id="companyName" name="companyName" type="text"
                                       value="@(Model.GeneralSettings?.CompanyName ?? "")"
                                       placeholder="Enter company name"
                                       style="width:260px;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);font-size:13px;" />
                            </div>

                            <div class="settings-row">
                                <div>
                                    <div class="settings-row-label">Logo</div>
                                    <div class="settings-row-desc">PNG, JPEG or GIF — max 2 MB. Used in PDF exports.</div>
                                </div>
                                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                                    @if (Model.HasLogo)
                                    {
                                        <img id="logoPreview" src="/api/settings/logo" alt="Logo"
                                             style="height:40px;border-radius:6px;border:1px solid var(--border);" />
                                    }
                                    else
                                    {
                                        <img id="logoPreview" src="" alt="" style="height:40px;border-radius:6px;border:1px solid var(--border);display:none;" />
                                    }
                                    <label class="btn btn-icon btn-sm" style="cursor:pointer;margin:0;">
                                        &#128247; Choose file
                                        <input type="file" id="logoFile" name="logo" accept="image/png,image/jpeg,image/gif"
                                               style="display:none;" onchange="previewLogo(this)" />
                                    </label>
                                    @if (Model.HasLogo)
                                    {
                                        <button type="button" class="btn btn-danger btn-sm" onclick="deleteLogo()">&#128465; Remove</button>
                                    }
                                </div>
                            </div>

                            <div class="settings-row" style="border-bottom:none;padding-bottom:0;justify-content:flex-end;gap:12px;align-items:center;">
                                <span id="generalStatus" style="font-size:12px;color:var(--text-muted);"></span>
                                <button type="submit" class="btn btn-accent">&#10003; Save Settings</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card" style="margin-top:16px;">
                    <div class="card-header"><span class="card-title">Export Members</span></div>
                    <div class="card-body">
                        <div class="settings-row" style="border-bottom:none;padding-bottom:0;">
                            <div>
                                <div class="settings-row-label">Download member data</div>
                                <div class="settings-row-desc">Choose fields and format, then download.</div>
                            </div>
                            <button class="btn btn-accent btn-sm" onclick="showModal('exportModal')">&#128229; Export</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Fields -->
            <div id="sec-fields" class="settings-section">
                <div class="card">
                    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
                        <span class="card-title">
                            Custom Fields
                            <span class="badge badge-gray" style="margin-left:6px;" id="fieldCount">@Model.CustomFields.Count</span>
                        </span>
                        <button class="btn btn-accent btn-sm" onclick="openFieldModal()">&#43; Add Field</button>
                    </div>
                    <div class="card-body" id="customFieldsList">
                        @if (Model.CustomFields.Any())
                        {
                            @foreach (var f in Model.CustomFields)
                            {
                                <div class="settings-row" id="field-row-@f.Id">
                                    <div class="field-tag">
                                        <span style="font-weight:700;">@f.FieldLabel</span>
                                        <span class="badge badge-gray">@f.FieldType</span>
                                        @if (f.IsRequired) { <span class="badge badge-red">Required</span> }
                                        @if (!f.IsActive) { <span class="badge badge-gray">Inactive</span> }
                                    </div>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <span style="font-size:12px;color:var(--text-muted);">Order: @f.DisplayOrder</span>
                                        <button class="btn btn-icon btn-sm" onclick="openFieldModal(@f.Id,'@f.FieldName','@f.FieldLabel','@f.FieldType',@(f.IsRequired ? "true" : "false"),@(f.IsActive ? "true" : "false"),@f.DisplayOrder)">&#9998;</button>
                                        <button class="btn btn-danger btn-sm" onclick="deleteField(@f.Id)">&#128465;</button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state" id="fieldsEmptyState">
                                <h3>No custom fields</h3>
                                <p>Add custom fields to extend member profiles.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Users -->
            @if (Model.HasPermission("ReadWrite"))
            {
                <div id="sec-users" class="settings-section">

                    @* ?? Pending approvals ?? *@
                    @if (Model.PendingUsers.Any())
                    {
                        <div class="card pending-card" style="margin-bottom:16px;">
                            <div class="card-header">
                                <span class="card-title">
                                    &#9888; Pending Approvals
                                    <span class="badge badge-red" style="margin-left:6px;">@Model.PendingUsers.Count</span>
                                </span>
                            </div>
                            <div class="card-body" style="padding:0;">
                                @foreach (var p in Model.PendingUsers)
                                {
                                    <div class="pending-row">
                                        <div class="pending-info">
                                            <div class="pending-name">@p.Username</div>
                                            <div class="pending-email">@p.Email</div>
                                            <div class="pending-date">Requested @p.CreatedAt.ToString("d MMM yyyy HH:mm")</div>
                                        </div>
                                        <div class="pending-actions">
                                            <form method="post" asp-page-handler="Approve" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@p.Id" />
                                                <select name="roleId" class="pending-role-select" required>
                                                    <option value="">Assign role…</option>
                                                    @foreach (var r in Model.Roles)
                                                    {
                                                        <option value="@r.Id">@r.Name</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-accent">&#10003; Approve</button>
                                            </form>
                                            <form method="post" asp-page-handler="Reject" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@p.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Reject and delete this registration request?')">
                                                    &#10005; Reject
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* ?? Active users ?? *@
                    <div class="card">
                        <div class="card-header">
                            <span class="card-title">
                                Active Users
                                <span class="badge badge-gray" style="margin-left:6px;">@Model.Users.Count</span>
                            </span>
                        </div>
                        <div class="card-body">
                            @if (Model.Users.Any())
                            {
                                @foreach (var u in Model.Users)
                                {
                                    var uInitials = u.Username?.Substring(0, 1).ToUpper() ?? "?";
                                    <div class="settings-row">
                                        <div style="display:flex;align-items:center;gap:12px;">
                                            <div class="user-avatar" style="width:36px;height:36px;font-size:14px;flex-shrink:0;">@uInitials</div>
                                            <div>
                                                <div style="font-weight:600;font-size:14px;">@u.Username</div>
                                                <div style="font-size:12px;color:var(--text-muted);">@u.Email</div>
                                            </div>
                                        </div>
                                        <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;">
                                            @foreach (var ur in u.UserRoles)
                                            {
                                                <span class="badge badge-purple">@ur.Role.Name</span>
                                            }
                                            @if (!u.IsActive) { <span class="badge badge-gray">Inactive</span> }
                                            @if (u.LastLoginAt.HasValue)
                                            {
                                                <span style="font-size:11px;color:var(--text-muted);">Last login: @u.LastLoginAt.Value.ToString("d MMM yyyy")</span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="empty-state"><h3>No active users</h3><p>Approve pending requests to add users.</p></div>
                            }
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<!-- CUSTOM FIELD MODAL -->
<div id="fieldModal" class="modal" onclick="if(event.target===this)hideModal('fieldModal')">
    <div class="modal-box modal-box-sm">
        <div class="modal-head">
            <h3 id="fieldModalTitle">Add Custom Field</h3>
            <button class="modal-close-btn" onclick="hideModal('fieldModal')">&times;</button>
        </div>
        <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
            <input type="hidden" id="fieldId" value="0" />
            <div class="form-group">
                <label>Field Name <span style="font-size:11px;color:var(--text-muted);">(internal, no spaces)</span></label>
                <input type="text" id="fieldName" placeholder="e.g. membershipType" style="width:100%;" />
            </div>
            <div class="form-group">
                <label>Label <span style="font-size:11px;color:var(--text-muted);">(shown to users)</span></label>
                <input type="text" id="fieldLabel" placeholder="e.g. Membership Type" style="width:100%;" />
            </div>
            <div class="form-group">
                <label>Type</label>
                <select id="fieldType" style="width:100%;">
                    <option value="Text">Text</option>
                    <option value="Number">Number</option>
                    <option value="Date">Date</option>
                    <option value="Boolean">Yes / No</option>
                </select>
            </div>
            <div class="form-row" style="gap:24px;">
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" id="fieldRequired" /> Required
                </label>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" id="fieldActive" checked /> Active
                </label>
            </div>
            <div class="form-group">
                <label>Display Order</label>
                <input type="number" id="fieldOrder" value="0" min="0" style="width:100px;" />
            </div>
        </div>
        <div class="modal-footer">
            <span id="fieldStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('fieldModal')">Cancel</button>
            <button class="btn btn-accent" onclick="saveField()">&#10003; Save</button>
        </div>
    </div>
</div>

<!-- EXPORT MODAL -->
<div id="exportModal" class="modal" onclick="if(event.target===this)hideModal('exportModal')">
    <div class="modal-box">
        <div class="modal-head">
            <h3>&#128229; Export Members</h3>
            <button class="modal-close-btn" onclick="hideModal('exportModal')">&times;</button>
        </div>
        <div class="modal-body">

            <!-- Format -->
            <div style="margin-bottom:20px;">
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">Format</div>
                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="pdf" checked /> PDF</label>
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="excel" /> Excel (.xlsx)</label>
                    <label class="export-format-pill"><input type="radio" name="exportFormat" value="csv" /> CSV</label>
                </div>
            </div>

            <!-- Field selection -->
            <div style="margin-bottom:20px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                    <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);">Fields to include</div>
                    <div style="display:flex;gap:8px;">
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(true)">All</button>
                        <button type="button" class="btn btn-xs btn-icon" onclick="toggleAllFields(false)">None</button>
                    </div>
                </div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="ef" value="MemberNumber" checked /> Member #</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="FirstName"    checked /> First Name</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="LastName"     checked /> Last Name</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Gender"       checked /> Gender</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Role"         checked /> Role</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="IsAlive"      checked /> Status</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="BirthDate"           /> Birth Date</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="SeniorityDate"       /> Seniority Date</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Email"               /> Email</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PhoneNumber"         /> Phone</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Street"              /> Street</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="HouseNumber"         /> House #</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="City"                /> City</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="PostalCode"          /> Postal Code</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="Country"             /> Country</label>
                    <label class="export-field-check"><input type="checkbox" name="ef" value="CreatedAt"           /> Created Date</label>
                </div>
            </div>

            <!-- Role filter -->
            <div>
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:10px;">Filter by role <span style="font-weight:400;text-transform:none;">(leave all unchecked = export everyone)</span></div>
                <div class="export-fields-grid">
                    <label class="export-field-check"><input type="checkbox" name="er" value="Steunend Lid"  /> Steunend Lid</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Kandidaat"    /> Kandidaat</label>
                    <label class="export-field-check"><input type="checkbox" name="er" value="Stappend Lid" /> Stappend Lid</label>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <span id="exportStatus" style="font-size:12px;color:var(--text-muted);flex:1;"></span>
            <button class="btn btn-icon" onclick="hideModal('exportModal')">Cancel</button>
            <button class="btn btn-accent" onclick="runExport()">&#128229; Download</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
const pageToken = '@Model.AuthToken';

function showModal(id) { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; }
function hideModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }

// ?? Section nav ???????????????????????????
function showSection(id, el) {
    event.preventDefault();
    document.querySelectorAll('.settings-section').forEach(s => {
        s.style.opacity = '0';
        s.style.transform = 'translateY(6px)';
        setTimeout(() => s.classList.remove('active'), 150);
    });
    document.querySelectorAll('.settings-nav-item').forEach(a => a.classList.remove('active'));
    setTimeout(() => {
        const target = document.getElementById('sec-' + id);
        target.classList.add('active');
        requestAnimationFrame(() => { target.style.opacity = '1'; target.style.transform = 'translateY(0)'; });
    }, 160);
    el.classList.add('active');
}

// ?? Logo preview ??????????????????????????
function previewLogo(input) {
    if (!input.files || !input.files[0]) return;
    const img = document.getElementById('logoPreview');
    img.src = URL.createObjectURL(input.files[0]);
    img.style.display = 'block';
}

// ?? Save general settings ?????????????????
async function saveGeneralSettings(e) {
    e.preventDefault();
    const statusEl = document.getElementById('generalStatus');
    statusEl.textContent = 'Saving…';
    statusEl.style.color = '';

    const fd = new FormData();
    fd.append('companyName', document.getElementById('companyName').value);
    const logoFile = document.getElementById('logoFile').files[0];
    if (logoFile) fd.append('logo', logoFile);

    try {
        const r = await fetch('/api/settings', {
            method: 'POST',
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) },
            body: fd
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok) {
            statusEl.style.color = 'green';
            statusEl.textContent = '? Saved';
            setTimeout(() => { statusEl.textContent = ''; statusEl.style.color = ''; }, 3000);
        } else {
            statusEl.style.color = 'red';
            statusEl.textContent = data.error ?? 'Save failed.';
        }
    } catch {
        statusEl.style.color = 'red';
        statusEl.textContent = 'Request failed.';
    }
}

// ?? Delete logo ???????????????????????????
async function deleteLogo() {
    if (!confirm('Remove the logo?')) return;
    try {
        const r = await fetch('/api/settings/logo', {
            method: 'DELETE',
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) }
        });
        if (r.ok) {
            const img = document.getElementById('logoPreview');
            img.src = ''; img.style.display = 'none';
            document.querySelector('[onclick="deleteLogo()"]')?.remove();
        }
    } catch { alert('Failed to remove logo.'); }
}

// ?? Custom fields ?????????????????????????
function openFieldModal(id = 0, name = '', label = '', type = 'Text', required = false, active = true, order = 0) {
    document.getElementById('fieldModalTitle').textContent = id === 0 ? 'Add Custom Field' : 'Edit Custom Field';
    document.getElementById('fieldId').value    = id;
    document.getElementById('fieldName').value  = name;
    document.getElementById('fieldLabel').value = label;
    document.getElementById('fieldType').value  = type;
    document.getElementById('fieldRequired').checked = required;
    document.getElementById('fieldActive').checked   = active;
    document.getElementById('fieldOrder').value = order;
    document.getElementById('fieldName').readOnly = id !== 0;
    document.getElementById('fieldStatus').textContent = '';
    showModal('fieldModal');
}

async function saveField() {
    const id       = parseInt(document.getElementById('fieldId').value);
    const name     = document.getElementById('fieldName').value.trim();
    const label    = document.getElementById('fieldLabel').value.trim();
    const type     = document.getElementById('fieldType').value;
    const required = document.getElementById('fieldRequired').checked;
    const active   = document.getElementById('fieldActive').checked;
    const order    = parseInt(document.getElementById('fieldOrder').value) || 0;
    const statusEl = document.getElementById('fieldStatus');

    if (!name || !label) { statusEl.textContent = 'Name and Label are required.'; return; }

    const isNew  = id === 0;
    const url    = isNew ? '/api/settings/custom-fields' : `/api/settings/custom-fields/${id}`;
    const method = isNew ? 'POST' : 'PUT';
    const body   = { id, fieldName: name, fieldLabel: label, fieldType: type, isRequired: required, isActive: active, displayOrder: order };

    statusEl.textContent = 'Saving…';
    try {
        const r = await fetch(url, {
            method,
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify(body)
        });
        if (r.ok) { hideModal('fieldModal'); location.reload(); }
        else {
            const d = await r.json().catch(() => ({}));
            statusEl.textContent = d.error ?? 'Save failed.';
        }
    } catch { statusEl.textContent = 'Request failed.'; }
}

async function deleteField(id) {
    if (!confirm('Delete this custom field? All member values for it will also be removed.')) return;
    try {
        const r = await fetch(`/api/settings/custom-fields/${id}`, {
            method: 'DELETE',
            headers: { ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {}) }
        });
        if (r.ok) {
            document.getElementById(`field-row-${id}`)?.remove();
            const remaining = document.querySelectorAll('[id^="field-row-"]').length;
            document.getElementById('fieldCount').textContent = remaining;
            if (remaining === 0)
                document.getElementById('customFieldsList').innerHTML =
                    '<div class="empty-state"><h3>No custom fields</h3><p>Add custom fields to extend member profiles.</p></div>';
        } else { alert('Failed to delete field.'); }
    } catch { alert('Request failed.'); }
}

// ?? Export ????????????????????????????????
function toggleAllFields(checked) {
    document.querySelectorAll('#exportModal input[name="ef"]').forEach(cb => cb.checked = checked);
}

async function runExport() {
    const format  = document.querySelector('input[name="exportFormat"]:checked')?.value ?? 'pdf';
    const fields  = [...document.querySelectorAll('#exportModal input[name="ef"]:checked')].map(cb => cb.value);
    const roles   = [...document.querySelectorAll('#exportModal input[name="er"]:checked')].map(cb => cb.value);

    if (fields.length === 0) { alert('Select at least one field to export.'); return; }

    const statusEl = document.getElementById('exportStatus');
    statusEl.textContent = 'Generating…';

    const endpointMap = { pdf: 'export/pdf', excel: 'export/excel', csv: 'export/csv-custom' };
    const extMap      = { pdf: 'pdf', excel: 'xlsx', csv: 'csv' };

    try {
        const r = await fetch(`/api/members/${endpointMap[format]}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(pageToken ? { 'Authorization': `Bearer ${pageToken}` } : {})
            },
            body: JSON.stringify({ selectedFields: fields, filterRoles: roles.length > 0 ? roles : null })
        });
        if (!r.ok) { const err = await r.json().catch(() => ({})); throw new Error(err.error ?? `Server error ${r.status}`); }
        const blob = await r.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url;
        a.download = `members_export_${new Date().toISOString().slice(0,10)}.${extMap[format]}`;
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
        statusEl.textContent = '';
        hideModal('exportModal');
    } catch (e) {
        statusEl.textContent = '';
        alert(e.message ?? 'Export failed.');
    }
}
</script>
}
