@page
@model AdminMembers.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - Gilde Van De Stroppendragers</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-wrap">
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none"><symbol id="icon-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol><symbol id="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></symbol></svg>
    <div class="login-card">
        <div class="login-head">
            <svg class="icon icon-2xl" style="color:#6366f1;margin-bottom:12px;"><use href="/icons.svg#icon-shield" /></svg>
            <h1>Gilde Van De Stroppendragers</h1>
            <p>Member Administration Portal</p>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-error">@Model.ErrorMessage</div>
            }
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RedirectUrl" />
                <div class="login-input-group">
                    <label for="Username">Username</label>
                    <input asp-for="Username" type="text" id="Username"
                           placeholder="Enter your username"
                           autocomplete="username" autofocus required />
                </div>
                <div class="login-input-group">
                    <label for="Password">Password</label>
                    <div class="password-wrapper">
                        <input asp-for="Password" type="password" id="Password"
                               placeholder="Enter your password"
                               autocomplete="current-password" required />
                        <button type="button" class="pwd-toggle" onclick="togglePwd()" aria-label="Toggle password visibility">
                            <svg class="icon icon-lg"><use href="/icons.svg#icon-eye" /></svg>
                        </button>
                    </div>
                </div>
                <button type="submit" class="btn-login" style="margin-top:12px;">Sign In</button>

                <div style="text-align:center;margin-top:12px;font-size:13px;">
                    <a href="/ForgotPassword" style="color:var(--accent);font-weight:600;">Forgot password?</a>
                </div>

                <div style="text-align:center;margin-top:12px;font-size:13px;color:var(--text-muted);">
                    No account? <a href="/Register" style="color:var(--accent);font-weight:600;">Request access</a>
                </div>
            </form>
        </div>
    </div>
    <script>
        function togglePwd() {
            const i = document.getElementById('Password');
            i.type = i.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
