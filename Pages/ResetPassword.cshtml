@page
@model AdminMembers.Pages.ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password – Gilde Van De Stroppendragers</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-wrap">
    <div class="login-card">
        <div class="login-head">
            <div class="logo-dot"></div>
            <h1>Reset Password</h1>
            <p>Choose a new strong password.</p>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div style="padding:12px 16px;background:#e8f5e9;color:#2e7d32;border-radius:8px;border:1px solid #2e7d32;margin-bottom:16px;">
                    &#10003; @Model.SuccessMessage
                </div>
                <div style="text-align:center;margin-top:12px;">
                    <a href="/Login" class="btn-login" style="display:inline-block;text-decoration:none;">Go to Sign In</a>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="login-error">@Model.ErrorMessage</div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />
                    <div class="login-input-group">
                        <label>New Password</label>
                        <div class="password-wrapper">
                            <input asp-for="NewPassword" type="password" id="NewPassword"
                                   placeholder="New password" required />
                            <button type="button" class="pwd-toggle" onclick="togglePwd('NewPassword')">&#128065;</button>
                        </div>
                        <small style="color:var(--text-muted);font-size:11px;">@Model.PasswordHint</small>
                    </div>
                    <div class="login-input-group">
                        <label>Confirm Password</label>
                        <div class="password-wrapper">
                            <input asp-for="ConfirmPassword" type="password" id="ConfirmPassword"
                                   placeholder="Confirm password" required />
                            <button type="button" class="pwd-toggle" onclick="togglePwd('ConfirmPassword')">&#128065;</button>
                        </div>
                    </div>
                    <button type="submit" class="btn-login" style="margin-top:12px;">Reset Password</button>
                </form>
            }
        </div>
    </div>
    <script>
        function togglePwd(id) {
            const i = document.getElementById(id);
            i.type = i.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
