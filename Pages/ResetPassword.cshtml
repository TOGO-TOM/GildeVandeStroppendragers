@page
@model AdminMembers.Pages.ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Gilde Van De Stroppendragers</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-wrap">
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none"><symbol id="icon-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol><symbol id="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></symbol></svg>
    <div class="login-card">
        <div class="login-head">
            <svg class="icon icon-2xl" style="color:#6366f1;margin-bottom:12px;"><use href="#icon-shield" /></svg>
            <h1>Reset Password</h1>
            <p>Choose a new strong password.</p>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div style="padding:12px 16px;background:#e8f5e9;color:#2e7d32;border-radius:8px;border:1px solid #2e7d32;margin-bottom:16px;">
                    &#10003; @Model.SuccessMessage
                </div>
                <div style="text-align:center;margin-top:12px;">
                    <a href="/Login" class="btn-login" style="display:inline-block;text-decoration:none;">Go to Sign In</a>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="login-error">@Model.ErrorMessage</div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />
                    <div class="login-input-group">
                        <label>New Password</label>
                        <div class="password-wrapper">
                            <input asp-for="NewPassword" type="password" id="NewPassword"
                                   placeholder="New password" required />
                            <button type="button" class="pwd-toggle" onclick="togglePwd('NewPassword')" aria-label="Toggle password visibility">
                                <svg class="icon icon-lg"><use href="/icons.svg#icon-eye" /></svg>
                            </button>
                        </div>
                        <small style="color:var(--text-muted);font-size:11px;">@Model.PasswordHint</small>
                    </div>
                    <div class="login-input-group">
                        <label>Confirm Password</label>
                        <div class="password-wrapper">
                            <input asp-for="ConfirmPassword" type="password" id="ConfirmPassword"
                                   placeholder="Confirm password" required />
                            <button type="button" class="pwd-toggle" onclick="togglePwd('ConfirmPassword')" aria-label="Toggle password visibility">
                                <svg class="icon icon-lg"><use href="/icons.svg#icon-eye" /></svg>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="btn-login" style="margin-top:12px;">Reset Password</button>
                </form>
            }
        </div>
    </div>
    <script>
        function togglePwd(id) {
            const i = document.getElementById(id);
            i.type = i.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
