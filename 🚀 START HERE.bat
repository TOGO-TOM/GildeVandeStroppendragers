@echo off
REM ========================================
REM   DOUBLE-CLICK THIS FILE TO START!
REM ========================================

title AdminMembers - Starting...
color 0B

echo.
echo  ??????????????????????????????????????????
echo  ?     AdminMembers Application           ?
echo  ?         Quick Launcher                 ?
echo  ??????????????????????????????????????????
echo.

cd /d "%~dp0"

echo [1/4] Checking .NET installation...
dotnet --version >nul 2>&1
if %errorlevel% neq 0 (
    echo.
    echo  ? .NET not found!
    echo  Please install .NET 8 SDK first.
    echo.
    pause
    exit /b 1
)
echo  ? .NET is installed

echo.
echo [2/4] Updating database (your data is safe)...
dotnet ef database update >nul 2>&1
echo  ? Database ready

echo.
echo [3/4] Starting AdminMembers server...
echo  (This may take a few seconds...)
echo.

REM Start server in separate window
start "AdminMembers Server - Keep This Window Open!" cmd /c "color 0A & title AdminMembers Server - Running & echo. & echo ?????????????????????????????????????????? & echo    AdminMembers Server is RUNNING & echo ?????????????????????????????????????????? & echo. & echo  Server Status: ONLINE & echo. & echo  To STOP the server: & echo    - Close this window, or & echo    - Press Ctrl+C & echo. & echo ?????????????????????????????????????????? & echo. & dotnet run & echo. & echo Server has stopped. & pause"

echo [4/4] Waiting for server to start...
timeout /t 10 /nobreak >nul

echo.
echo  ? Opening browser...
start https://localhost:7223/index.html

echo.
echo  ??????????????????????????????????????????
echo  ?         ?? ALL DONE! ??                ?
echo  ??????????????????????????????????????????
echo.
echo  The application is now running!
echo.
echo  ?? Opened in browser:
echo     https://localhost:7223/index.html
echo.
echo  ?? To STOP the application:
echo     Close the "AdminMembers Server" window
echo.
echo  This window will close in 3 seconds...
timeout /t 3 >nul
